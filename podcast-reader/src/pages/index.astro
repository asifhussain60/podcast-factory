---
/**
 * Library landing — editorial-modern, matches the book-cover and
 * chapter-viewer aesthetic.
 *
 * All styling lives in styles/landing.css; this file is markup only.
 */
import '~/styles/global.css';
import ThemeScript from '~/components/layout/ThemeScript.astro';
import ThemeToggle from '~/components/layout/ThemeToggle.astro';
import { discoverBundles } from '~/lib/source-extractor';
import { discoverDrafts } from '~/lib/drafts';
import { getR2Status } from '~/lib/decisions';

const [bundles, drafts, r2Status] = await Promise.all([
  discoverBundles().catch(() => []),
  discoverDrafts().catch(() => []),
  getR2Status().catch(() => null),
]);

const kashkoleSource = bundles.find((s) => s.source === 'kashkole');
const kashkoleChapters = kashkoleSource?.chapterCount ?? 122;
const kashkoleShelves = kashkoleSource?.shelves.length ?? 19;
const draftsCount = drafts.length;
const refinedDrafts = drafts.filter((d) => d.hasRefinedEnglish).length;
const r2Cov = r2Status ? `${r2Status.covered}/${r2Status.covered + r2Status.deferred}` : '9/19';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Podcast Reader · A Reading Room for the Corpus</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ThemeScript />
  </head>
  <body class="editorial-page antialiased">
    <div class="editorial-topbar"><ThemeToggle /></div>

    <header class="editorial-hero">
      <div class="editorial-shell">
        <div class="editorial-brand">
          <svg class="editorial-brand-mark" viewBox="0 0 36 36" fill="none" aria-hidden="true">
            <rect x="4" y="7" width="13" height="22" class="fill" opacity="0.92"/>
            <rect x="17" y="7" width="15" height="22" fill="none" class="stroke" stroke-width="1.6"/>
            <line x1="17" y1="7" x2="17" y2="29" class="stroke" stroke-width="1.6"/>
            <circle cx="24.5" cy="18" r="2" class="fill"/>
          </svg>
          <span class="editorial-brand-words">Podcast<span class="em"> · </span>Reader</span>
        </div>

        <div class="editorial-eyebrow">
          <span class="rule"></span>
          <span>The Library</span>
          <span class="rule"></span>
        </div>

        <h1 class="editorial-title">A reading room<br/>for the <em>corpus</em>.</h1>

        <p class="editorial-deck">
          Two navigational paths into the materials flowing through the
          <code>podcast-factory</code> pipeline — the source corpus, and the books currently in the
          workshop being shaped into episodes.
        </p>
      </div>
    </header>

    <main class="editorial-shell">
      <div class="editorial-section-head">
        <h2>Choose a path</h2>
        <span class="meta">2 paths · live</span>
      </div>

      <div class="editorial-grid editorial-grid--two">

        <a href="/kashkole/" class="editorial-card">
          <div class="editorial-card-header">
            <div>
              <span class="editorial-card-num">№ 01 · Source corpus</span>
              <h3 class="editorial-card-title">Kashkole</h3>
              <div class="editorial-card-title-arabic" lang="ar" dir="rtl">کشکول</div>
            </div>
            <span class="editorial-pill editorial-pill--gold">
              <span class="dot"></span>R1 + R2 Partial
            </span>
          </div>
          <p class="editorial-card-sub">Esoteric Ismaili Compendium</p>
          <p class="editorial-card-body">
            Tayyibi philosophical, theological, and jurisprudential treatises. A bilingual reader
            pairs each topic of the original Urdu with the proposed English title and translation,
            side by side.
          </p>
          <div class="editorial-card-stats">
            <div class="editorial-card-stat">
              <div class="v">{kashkoleShelves}</div>
              <div class="l">Binders</div>
            </div>
            <div class="editorial-card-stat">
              <div class="v accent">{kashkoleChapters}</div>
              <div class="l">Chapters</div>
            </div>
            <div class="editorial-card-stat">
              <div class="v">{r2Cov}</div>
              <div class="l">Retitled</div>
            </div>
          </div>
          <span class="editorial-card-cta">Enter the corpus →</span>
        </a>

        <a href="/podcast-drafts/" class="editorial-card">
          <div class="editorial-card-header">
            <div>
              <span class="editorial-card-num">№ 02 · The Workshop</span>
              <h3 class="editorial-card-title">Podcast Drafts</h3>
            </div>
            <span class="editorial-pill editorial-pill--live">
              <span class="dot"></span>Live
            </span>
          </div>
          <p class="editorial-card-sub">Books in the pipeline · content/drafts/</p>
          <p class="editorial-card-body">
            Books currently in the workshop, post-intake and pre-publish. Refined English text
            where the pipeline has produced it; raw extracts where it has not.
          </p>
          <div class="editorial-card-stats">
            <div class="editorial-card-stat">
              <div class="v">{draftsCount}</div>
              <div class="l">Drafts</div>
            </div>
            <div class="editorial-card-stat">
              <div class="v accent">{refinedDrafts}</div>
              <div class="l">Reader-ready</div>
            </div>
          </div>
          <span class="editorial-card-cta">Enter the workshop →</span>
        </a>

      </div>
    </main>

    <footer class="editorial-footer">
      <div class="editorial-shell">
        <div class="editorial-footer-inner">
          <span>
            Local reader · reads from
            <code>_workspace/</code> and <code>content/</code>
          </span>
          {r2Status && <span>R2 batch: {r2Status.batch}</span>}
        </div>
      </div>
    </footer>
  </body>
</html>
