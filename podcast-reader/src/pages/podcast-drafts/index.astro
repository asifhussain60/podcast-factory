---
/**
 * Podcast Drafts — bookshelf view.
 *
 * Each draft becomes a face-up hardcover book on a display shelf.
 * Title, author, era, and description come from BOOKS metadata
 * (data/books.ts) with slug-derived fallbacks. Cover palette and
 * thickness are assigned deterministically per slug so each book
 * has a stable identity across page reloads.
 */
import '~/styles/global.css';
import ThemeScript from '~/components/layout/ThemeScript.astro';
import ThemeToggle from '~/components/layout/ThemeToggle.astro';
import { discoverDrafts, type DraftRecord } from '~/lib/drafts';
import { BOOKS, type BookMeta } from '~/data/books';

const drafts = await discoverDrafts();

/** djb2-ish stable hash so the same slug always picks the same look. */
function hash(s: string): number {
  let h = 5381;
  for (let i = 0; i < s.length; i++) h = ((h << 5) + h + s.charCodeAt(i)) >>> 0;
  return h;
}

const THICKNESSES = ['thin', 'medium', 'thick'] as const;

interface BookTile {
  slug: string;
  href: string;
  meta: BookMeta | null;
  title: string;
  titleAr?: string;
  publisher: string;
  author: string;
  era?: string;
  description: string;
  cover: number;
  thickness: typeof THICKNESSES[number];
  draft: DraftRecord;
}

function fallbackDescription(d: DraftRecord): string {
  if (d.hasRefinedEnglish) return 'A draft in flight — refined English text from the pipeline is available.';
  return 'A draft awaiting translation — only the raw extract is available so far.';
}

const tiles: BookTile[] = drafts.map((d) => {
  const meta = (BOOKS[d.slug] as BookMeta | undefined) ?? null;
  const h = hash(d.slug);
  return {
    slug: d.slug,
    href: `/develop/${d.slug}/`,
    meta,
    title: meta?.titleEn ?? d.displayTitle,
    titleAr: meta?.titleAr,
    publisher: meta?.tradition ?? meta?.series ?? 'Podcast Reader',
    author: meta?.author?.name ?? '—',
    era: meta?.author?.era,
    description: meta?.description ?? fallbackDescription(d),
    cover: (h % 7) + 1,
    thickness: THICKNESSES[h % 3],
    draft: d,
  };
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Podcast Drafts · Podcast Reader</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ThemeScript />
  </head>
  <body class="editorial-page antialiased">
    <div class="editorial-topbar"><ThemeToggle /></div>

    <header class="editorial-hero">
      <div class="editorial-shell">
        <nav class="editorial-breadcrumb">
          <a href="/">Library</a>
          <span class="sep">›</span>
          <span class="here">Podcast Drafts</span>
        </nav>

        <div class="editorial-eyebrow">
          <span class="rule"></span>
          <span>№ 02 · The Workshop</span>
        </div>

        <h1 class="editorial-title">The <em>shelf</em>.</h1>

        <p class="editorial-deck">
          {tiles.length} in-flight book{tiles.length === 1 ? '' : 's'}, post-intake and pre-publish.
          Each cover is a real book — click to step inside.
        </p>
      </div>
    </header>

    <main class="editorial-shell">
      <div class="editorial-section-head">
        <h2>On the workshop shelf</h2>
        <span class="meta">content/drafts/</span>
      </div>

      {tiles.length === 0 ? (
        <p class="editorial-deck">Nothing under <code>content/drafts/</code> yet.</p>
      ) : (
        <div class="bookshelf">
          {tiles.map((t) => (
            <a
              href={t.href}
              class="book-tile"
              data-cover={String(t.cover)}
              data-thickness={t.thickness}
              aria-label={`Open ${t.title}`}
            >
              <span class="book-tile-ribbon">
                {t.draft.hasRefinedEnglish ? 'Reader-ready' : 'Pre-translation'}
              </span>

              <div class="book-tile-cover">
                <div class="book-tile-frame" aria-hidden="true"></div>

                <div class="book-tile-publisher">{t.publisher}</div>

                <h3 class="book-tile-title">{t.title}</h3>
                {t.titleAr && <div class="book-tile-title-ar" lang="ar" dir="rtl">{t.titleAr}</div>}

                <div class="book-tile-divider" aria-hidden="true">
                  <span class="seg"></span>
                  <span class="gem">◆</span>
                  <span class="seg"></span>
                </div>

                <div class="book-tile-author">{t.author}</div>
                {t.era && <div class="book-tile-era">{t.era}</div>}

                <div class="book-tile-spacer" aria-hidden="true"></div>

                <div class="book-tile-foot">
                  <span class="book-tile-icons" aria-label="Book attributes">
                    <i class="fa-solid fa-book-open-reader" title="Source text"></i>
                    {t.draft.hasRefinedEnglish && <i class="fa-solid fa-language" title="Refined English"></i>}
                    {t.draft.hasPhonetics && <i class="fa-solid fa-feather-pointed" title="Phonetics"></i>}
                    {t.draft.hasRawExtract && !t.draft.hasRefinedEnglish && <i class="fa-solid fa-scroll" title="Raw extract"></i>}
                    {t.meta && <i class="fa-solid fa-circle-check" title="Catalogued"></i>}
                  </span>
                  <span class="book-tile-open">
                    Open <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}
    </main>

    <footer class="editorial-footer">
      <div class="editorial-shell">
        <div class="editorial-footer-inner">
          <span>Each book opens at <code>/develop/&lt;slug&gt;/</code> — the canonical viewer.</span>
          <a href="/" class="editorial-breadcrumb"><span>← Library</span></a>
        </div>
      </div>
    </footer>
  </body>
</html>
