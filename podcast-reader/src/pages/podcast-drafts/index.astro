---
/**
 * Podcast Drafts index. Lists content/drafts/<slug>/ books with at-a-glance
 * metadata.
 */
import '~/styles/global.css';
import Icon from '~/components/ui/Icon.astro';
import ThemeScript from '~/components/layout/ThemeScript.astro';
import ThemeToggle from '~/components/layout/ThemeToggle.astro';
import { discoverDrafts } from '~/lib/drafts';

const drafts = await discoverDrafts();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Podcast Drafts · Reader</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ThemeScript />
  </head>
  <body class="min-h-screen antialiased" style="background: var(--color-surface-page); color: var(--color-ink);">
    <div class="fixed top-4 right-4 z-40"><ThemeToggle /></div>

    <header class="border-b" style="border-color: var(--color-rule-default); background: var(--color-surface-raised);">
      <div class="gold-hairline absolute inset-x-0 top-0" aria-hidden></div>
      <div class="mx-auto max-w-6xl px-8 py-10">
        <nav class="font-ui flex items-center gap-2 text-[11px] uppercase tracking-[0.18em]" style="color: var(--color-ink-tertiary);">
          <a href="/" class="hover:underline">Library</a>
          <Icon name="chevron-right" size={11} />
          <span style="color: var(--color-accent);">Podcast Drafts</span>
        </nav>
        <div class="mt-5">
          <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-lg" style="background: var(--color-accent); color: var(--color-ink-on-emphasis); opacity: 0.92;">
            <Icon name="book-open" size={26} />
          </div>
          <h1 class="text-5xl font-semibold tracking-tight" style="font-family: 'EB Garamond', Georgia, serif; color: var(--color-ink);">
            Podcast Drafts
          </h1>
          <div class="font-ui mt-1.5 text-[11px] uppercase tracking-[0.18em]" style="color: var(--color-ink-tertiary);">
            Books in the Pipeline Workshop · content/drafts/
          </div>
          <p class="mt-5 max-w-2xl text-base italic leading-relaxed" style="font-family: 'EB Garamond', Georgia, serif; color: var(--color-ink-secondary);">
            {drafts.length} in-flight book{drafts.length === 1 ? '' : 's'}, post-intake, pre-publish. Drafts with refined English text are reader-ready; raw extracts are pre-translation.
          </p>
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-6xl px-8 py-12">
      {drafts.length === 0 ? (
        <div class="rounded-lg border px-6 py-12 text-center" style="border-color: var(--color-rule-default); background: var(--color-surface-raised);">
          <p class="font-ui text-sm" style="color: var(--color-ink-secondary);">No drafts found under <code style="font-family: var(--font-mono);">content/drafts/</code>.</p>
        </div>
      ) : (
        <div class="grid gap-4 md:grid-cols-2">
          {drafts.map((d) => (
            <a href={`/podcast-drafts/${d.slug}/`} class="group flex flex-col rounded-lg border p-5 transition hover:-translate-y-0.5 hover:shadow-md" style="border-color: var(--color-rule-default); background: var(--color-surface-raised);">
              <div class="flex items-start justify-between gap-3">
                <h2 class="flex-1 text-xl font-semibold leading-snug tracking-tight" style="font-family: 'EB Garamond', Georgia, serif; color: var(--color-ink);">
                  {d.displayTitle}
                </h2>
                <div class="flex shrink-0 gap-1.5">
                  {d.hasRefinedEnglish && (
                    <span class="font-ui rounded px-1.5 py-0.5 text-[10px] uppercase tracking-wider" style="background: var(--color-accent-soft); color: var(--color-accent);" title="Refined English text exists">EN</span>
                  )}
                  {d.hasRawExtract && (
                    <span class="font-ui rounded px-1.5 py-0.5 text-[10px] uppercase tracking-wider border" style="border-color: var(--color-rule-default); color: var(--color-ink-tertiary);" title="Raw extract exists">RAW</span>
                  )}
                  {d.hasPhonetics && (
                    <span class="font-ui rounded px-1.5 py-0.5 text-[10px] uppercase tracking-wider border" style="border-color: var(--color-rule-default); color: var(--color-ink-tertiary);" title="Phonetics file">PHON</span>
                  )}
                </div>
              </div>
              <code class="mt-1 text-[11px]" style="font-family: var(--font-mono); color: var(--color-ink-tertiary);">{d.slug}</code>

              <div class="mt-4 flex items-center justify-between border-t pt-3" style="border-color: var(--color-rule-subtle);">
                <span class="font-ui text-[11px] uppercase tracking-wider" style="color: var(--color-ink-tertiary);">
                  {d.hasRefinedEnglish ? 'Reader-ready' : 'Pre-translation'}
                </span>
                <span class="font-ui inline-flex items-center gap-1 text-[11px] font-semibold uppercase tracking-wider transition-all group-hover:gap-2" style="color: var(--color-accent);">
                  Open <Icon name="arrow-right" size={11} />
                </span>
              </div>
            </a>
          ))}
        </div>
      )}
    </main>
  </body>
</html>
