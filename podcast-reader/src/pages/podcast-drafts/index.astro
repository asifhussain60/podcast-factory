---
/**
 * Podcast Drafts index — lists content/drafts/<slug>/ books.
 * Tiles route to the canonical viewer at /[worktree]/[book]/.
 * Styling lives in styles/landing.css.
 */
import '~/styles/global.css';
import ThemeScript from '~/components/layout/ThemeScript.astro';
import ThemeToggle from '~/components/layout/ThemeToggle.astro';
import { discoverDrafts } from '~/lib/drafts';

const drafts = await discoverDrafts();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Podcast Drafts · Podcast Reader</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ThemeScript />
  </head>
  <body class="editorial-page antialiased">
    <div class="editorial-topbar"><ThemeToggle /></div>

    <header class="editorial-hero">
      <div class="editorial-shell">
        <nav class="editorial-breadcrumb">
          <a href="/">Library</a>
          <span class="sep">›</span>
          <span class="here">Podcast Drafts</span>
        </nav>

        <div class="editorial-eyebrow">
          <span class="rule"></span>
          <span>№ 02 · The Workshop</span>
        </div>

        <h1 class="editorial-title">Podcast <em>Drafts</em>.</h1>

        <p class="editorial-deck">
          {drafts.length} in-flight book{drafts.length === 1 ? '' : 's'}, post-intake and
          pre-publish. Drafts marked <strong>Reader-ready</strong> have refined English text from
          the pipeline; <strong>Pre-translation</strong> drafts carry only the raw extract.
        </p>
      </div>
    </header>

    <main class="editorial-shell">
      <div class="editorial-section-head">
        <h2>{drafts.length === 0 ? 'No drafts found' : 'In the workshop'}</h2>
        <span class="meta">content/drafts/</span>
      </div>

      {drafts.length === 0 ? (
        <p class="editorial-deck">
          Nothing under <code>content/drafts/</code> yet. Once the pipeline ingests a book it will
          appear here.
        </p>
      ) : (
        <div class="editorial-grid">
          {drafts.map((d) => (
            <a href={`/develop/${d.slug}/`} class="editorial-card editorial-card--compact">
              <div class="editorial-card-header">
                <div>
                  <h3 class="editorial-card-title">{d.displayTitle}</h3>
                  <p class="editorial-card-slug">{d.slug}</p>
                </div>
                <div class="editorial-card-tag-stack">
                  {d.hasRefinedEnglish && <span class="editorial-tag editorial-tag--gold">EN</span>}
                  {d.hasRawExtract && <span class="editorial-tag">RAW</span>}
                  {d.hasPhonetics && <span class="editorial-tag">PHON</span>}
                </div>
              </div>
              <p class="editorial-card-sub">
                {d.hasRefinedEnglish ? 'Reader-ready' : 'Pre-translation'}
              </p>
              <span class="editorial-card-cta">Open →</span>
            </a>
          ))}
        </div>
      )}
    </main>

    <footer class="editorial-footer">
      <div class="editorial-shell">
        <div class="editorial-footer-inner">
          <span>Tiles route to <code>/develop/&lt;slug&gt;/</code> — the canonical viewer.</span>
          <a href="/" class="editorial-breadcrumb"><span>← Library</span></a>
        </div>
      </div>
    </footer>
  </body>
</html>
