---
import ThreePane from '~/components/layout/ThreePane.astro';
import GroupedTOC from '~/components/layout/GroupedTOC.astro';
import ContractView from '~/components/reader/ContractView.astro';
import ReaderControls from '~/components/reader/ReaderControls';
import CopyButton from '~/components/reader/CopyButton';
import { loadBookIndex } from '~/lib/book-content';
import { loadChapterContract } from '~/lib/contract-parser';
import { renderContract, buildCategoryDescriptors } from '~/lib/contract-render';
import { formatContractForCopy } from '~/lib/format-for-copy';

const { worktree, book, episode } = Astro.params;
if (!worktree || !book || !episode) {
  return new Response('Bad request', { status: 400 });
}

// Pilot-only gating dropped post-restructure (2026-05-24): all books surface.

const index = await loadBookIndex(worktree, book);
if (!index) {
  return new Response(`Book "${book}" not found`, { status: 404 });
}

const ep = index.episodes.find((e) => e.slug === episode);
if (!ep) {
  return new Response(`Episode "${episode}" not found`, { status: 404 });
}

const contract = await loadChapterContract(ep.filePath);
const rendered = renderContract(contract);
const categoryDescriptors = buildCategoryDescriptors(rendered.counts);
const copyText = formatContractForCopy(contract);

// Resolve adjacent episodes for prev/next nav
const orderedEps = [...index.episodes].sort((a, b) => (a.episodeNumber ?? 999) - (b.episodeNumber ?? 999));
const idx = orderedEps.findIndex((e) => e.slug === ep.slug);
const prev = idx > 0 ? orderedEps[idx - 1] : null;
const next = idx >= 0 && idx < orderedEps.length - 1 ? orderedEps[idx + 1] : null;

---

<ThreePane
  title={`${contract.title} — ${book}`}
  worktree={worktree}
  book={book}
  breadcrumb={[
    { label: 'Library', href: '/' },
    { label: book, href: `/${worktree}/${book}/` },
    { label: `E${String(contract.episodeNumber ?? '?').padStart(2, '0')}` },
  ]}
  showRail={false}
>
  <Fragment slot="toc">
    <GroupedTOC worktree={worktree} book={book} index={index} currentEpisode={ep.slug} />
  </Fragment>

  <div class="not-prose mb-8 rounded-lg border border-stone-300 bg-stone-100/70 px-4 py-3 shadow-sm">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div class="flex-1 min-w-[280px]">
        <div class="mb-2 flex items-center gap-2">
          <span class="font-ui text-[10px] font-semibold uppercase tracking-wider text-stone-500">
            Reference controls
          </span>
          <span class="text-stone-300">·</span>
          <span class="font-ui text-[10px] text-stone-500">
            click to toggle, or press <kbd class="rounded border border-stone-300 bg-white px-1 text-stone-700">?</kbd> for legend
          </span>
        </div>
        <ReaderControls client:load categories={categoryDescriptors} />
      </div>
      <div class="shrink-0 self-center">
        <CopyButton client:load text={copyText} label="Copy episode" />
      </div>
    </div>
  </div>

  <ContractView contract={contract} rendered={rendered} />

  <nav class="mt-12 flex items-center justify-between border-t border-stone-200 pt-6 text-sm">
    {prev ? (
      <a href={`/${worktree}/${book}/episode/${prev.slug}/`} class="group flex flex-col text-stone-700">
        <span class="text-xs text-stone-400">← Previous</span>
        <span class="font-medium group-hover:text-stone-900">{prev.title}</span>
      </a>
    ) : <span />}
    {next ? (
      <a href={`/${worktree}/${book}/episode/${next.slug}/`} class="group flex flex-col text-right text-stone-700">
        <span class="text-xs text-stone-400">Next →</span>
        <span class="font-medium group-hover:text-stone-900">{next.title}</span>
      </a>
    ) : <span />}
  </nav>
</ThreePane>
