---
import '~/styles/global.css';
import Icon from '~/components/ui/Icon.astro';
import ThemeScript from '~/components/layout/ThemeScript.astro';
import ThemeToggle from '~/components/layout/ThemeToggle.astro';
import { findChapter, loadChapterMarkdown, discoverBundles } from '~/lib/source-extractor';
import { renderSourceMarkdown } from '~/lib/source-render';

const { source, shelf, book } = Astro.params;
if (!source || !shelf || !book) {
  return new Response('Missing route params', { status: 400 });
}

const chapter = await findChapter(source, shelf, book);
if (!chapter) {
  return new Response(`Chapter not found: ${source}/${shelf}/${book}`, { status: 404 });
}

const md = await loadChapterMarkdown(chapter);
const html = renderSourceMarkdown(md);

// Sibling chapters within the same shelf — prev/next nav
const all = await discoverBundles();
const shelfGroup = all
  .find((s) => s.source === source)
  ?.shelves.find((sh) => sh.shelfSlug === shelf);
const siblings = shelfGroup?.chapters ?? [];
const idx = siblings.findIndex((c) => c.bookSlug === book);
const prev = idx > 0 ? siblings[idx - 1] : null;
const next = idx >= 0 && idx < siblings.length - 1 ? siblings[idx + 1] : null;

const m = chapter.manifest;
const lang = m.source_language || 'ur';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{m.book.name} · Source Extractor</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ThemeScript />
  </head>
  <body class="min-h-screen antialiased" style="background: var(--color-surface-page); color: var(--color-ink);">
    <div class="fixed top-4 left-4 z-40"><ThemeToggle /></div>

    <header class="border-b" style="border-color: var(--color-rule-default); background: var(--color-surface-raised);">
      <div class="gold-hairline absolute inset-x-0 top-0" aria-hidden></div>

      <div class="mx-auto max-w-3xl px-6 py-8">
        <nav class="font-ui flex flex-wrap items-center gap-2 text-[11px] uppercase tracking-[0.16em]" style="color: var(--color-ink-tertiary);">
          <a href="/" class="hover:underline">The Library</a>
          <span>›</span>
          <a href="/source-extractor/" class="hover:underline">Source Extractor</a>
          <span>›</span>
          <span>{source}</span>
          <span>›</span>
          <span class="rounded px-1.5 py-0.5" style="background: var(--color-gold-soft); color: var(--color-gold-deep);">
            shelf {m.shelf.prefix}
          </span>
        </nav>

        <div class="mt-5">
          <div class="font-ui text-[10px] uppercase tracking-[0.22em]" style="color: var(--color-ink-tertiary);">
            {m.shelf.kind} {m.shelf.id}
          </div>
          <h2 class="mt-1" style="font-family: var(--font-urdu); direction: rtl; font-size: 22px; line-height: 1.4; color: var(--color-ink-secondary);" lang="ur">
            {m.shelf.name}
          </h2>
        </div>

        <div class="mt-5 border-t pt-5" style="border-color: var(--color-rule-subtle);">
          <div class="flex items-baseline justify-between gap-3">
            <div class="font-ui text-[10px] uppercase tracking-[0.22em]" style="color: var(--color-gold-deep);">
              {m.book.kind} {m.book.id} · prefix {m.book.prefix}
            </div>
            <span class="font-ui rounded border px-1.5 py-0.5 text-[10px] uppercase tracking-wider" style="border-color: var(--color-rule-default); color: var(--color-ink-secondary);">
              {lang}
            </span>
          </div>
          <h1 class="mt-2" style="font-family: var(--font-urdu); direction: rtl; font-size: 42px; line-height: 1.3; color: var(--color-ink);" lang="ur">
            {m.book.name}
          </h1>

          {m.counts && (
            <div class="font-ui mt-5 flex flex-wrap gap-x-5 gap-y-1 text-[11px] uppercase tracking-wider" style="color: var(--color-ink-tertiary);">
              <span>{m.counts.sections} sections ({m.counts.sections_with_content} with content)</span>
              {m.counts.inline_images > 0 && <span>{m.counts.inline_images} images</span>}
              {m.counts.curated_citation_refs > 0 && <span>{m.counts.curated_citation_refs} curated citations</span>}
              <span>Stage: {m.stage}</span>
            </div>
          )}
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-3xl px-6 py-12">
      <article class="se-prose" data-lang={lang} set:html={html}></article>

      {(prev || next) && (
        <nav class="mt-14 flex items-stretch justify-between gap-3 border-t pt-6" style="border-color: var(--color-rule-default);">
          {prev ? (
            <a
              href={`/source-extractor/${prev.source}/${prev.shelfSlug}/${prev.bookSlug}/`}
              class="flex-1 rounded-lg border px-4 py-3 transition hover:-translate-y-px"
              style="border-color: var(--color-rule-default); background: var(--color-surface-raised); color: var(--color-ink);"
            >
              <div class="font-ui text-[10px] uppercase tracking-wider" style="color: var(--color-ink-tertiary);">
                ← Previous · {prev.manifest.book.prefix}
              </div>
              <div class="mt-1" style="font-family: var(--font-urdu); direction: rtl; font-size: 17px;" lang="ur">
                {prev.manifest.book.name}
              </div>
            </a>
          ) : (
            <span class="flex-1"></span>
          )}
          {next ? (
            <a
              href={`/source-extractor/${next.source}/${next.shelfSlug}/${next.bookSlug}/`}
              class="flex-1 rounded-lg border px-4 py-3 text-right transition hover:-translate-y-px"
              style="border-color: var(--color-rule-default); background: var(--color-surface-raised); color: var(--color-ink);"
            >
              <div class="font-ui text-[10px] uppercase tracking-wider" style="color: var(--color-ink-tertiary);">
                Next · {next.manifest.book.prefix} →
              </div>
              <div class="mt-1" style="font-family: var(--font-urdu); direction: rtl; font-size: 17px;" lang="ur">
                {next.manifest.book.name}
              </div>
            </a>
          ) : (
            <span class="flex-1"></span>
          )}
        </nav>
      )}

      <footer class="mt-12 border-t pt-5 font-ui text-[11px]" style="border-color: var(--color-rule-subtle); color: var(--color-ink-tertiary);">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div class="flex items-center gap-2">
            <Icon name="folder" size={11} />
            <code class="text-[10px]">
              {source}/{shelf}/{book}
            </code>
          </div>
          <a href="/source-extractor/" class="hover:underline">
            ← Back to bundles
          </a>
        </div>
      </footer>
    </main>
  </body>
</html>
