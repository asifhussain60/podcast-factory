---
import '~/styles/global.css';
import Icon from '~/components/ui/Icon.astro';
import ThemeScript from '~/components/layout/ThemeScript.astro';
import ThemeToggle from '~/components/layout/ThemeToggle.astro';
import { discoverBundles } from '~/lib/source-extractor';

const sources = await discoverBundles();
const totalChapters = sources.reduce((n, s) => n + s.chapterCount, 0);
const totalShelves = sources.reduce((n, s) => n + s.shelves.length, 0);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Source Extractor · Generated Text Review</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ThemeScript />
  </head>
  <body class="min-h-screen antialiased" style="background: var(--color-surface-page); color: var(--color-ink);">
    <div class="fixed top-4 left-4 z-40"><ThemeToggle /></div>

    <header class="relative overflow-hidden border-b" style="border-color: var(--color-rule-default); background: linear-gradient(to bottom, var(--color-surface-raised), var(--color-surface-page));">
      <div class="gold-hairline absolute inset-x-0 top-0" aria-hidden></div>

      <div class="relative mx-auto max-w-4xl px-6 py-12">
        <a href="/" class="font-ui inline-flex items-center gap-1.5 text-[11px] uppercase tracking-[0.18em]" style="color: var(--color-ink-tertiary);">
          <Icon name="arrow-left" size={12} />
          The Library
        </a>

        <div class="font-ui mt-5 mb-3 inline-flex items-center gap-3 text-[10px] font-bold uppercase tracking-[0.32em]" style="color: var(--color-gold-deep);">
          <span class="h-px w-12" style="background: var(--color-gold-deep); opacity: 0.6;"></span>
          <Icon name="folder" size={12} />
          <span>Source Extractor · Generated Text Review</span>
          <Icon name="folder" size={12} />
          <span class="h-px w-12" style="background: var(--color-gold-deep); opacity: 0.6;"></span>
        </div>

        <h1 class="text-5xl font-semibold leading-[1.05] tracking-tight" style="font-family: 'EB Garamond', Georgia, serif; color: var(--color-ink);">
          Source bundles
        </h1>

        <p class="mt-4 max-w-2xl text-base italic leading-relaxed" style="font-family: 'EB Garamond', Georgia, serif; color: var(--color-ink-secondary);">
          Review the raw-extract markdown for every bundle produced by{' '}
          <code class="text-sm" style="font-family: var(--font-mono);">tools/source_extractor</code>.
          Urdu prose renders in Nastaliq, embedded Arabic in naskh.
        </p>

        <div class="mt-7 inline-flex items-stretch gap-0 rounded-lg border" style="border-color: var(--color-rule-default); background: var(--color-surface-raised);">
          <div class="min-w-28 px-5 py-3 text-center">
            <div class="text-[26px] font-semibold leading-none" style="font-family: 'EB Garamond', Georgia, serif; color: var(--color-ink);">{sources.length}</div>
            <div class="font-ui mt-1 text-[10px] font-bold uppercase tracking-[0.15em]" style="color: var(--color-ink-tertiary);">Sources</div>
          </div>
          <div class="w-px self-stretch" style="background: var(--color-rule-default);"></div>
          <div class="min-w-28 px-5 py-3 text-center">
            <div class="text-[26px] font-semibold leading-none" style="font-family: 'EB Garamond', Georgia, serif; color: var(--color-ink);">{totalShelves}</div>
            <div class="font-ui mt-1 text-[10px] font-bold uppercase tracking-[0.15em]" style="color: var(--color-ink-tertiary);">Shelves</div>
          </div>
          <div class="w-px self-stretch" style="background: var(--color-rule-default);"></div>
          <div class="min-w-28 px-5 py-3 text-center">
            <div class="text-[26px] font-semibold leading-none" style="font-family: 'EB Garamond', Georgia, serif; color: var(--color-gold-deep);">{totalChapters}</div>
            <div class="font-ui mt-1 text-[10px] font-bold uppercase tracking-[0.15em]" style="color: var(--color-gold-deep);">Chapters</div>
          </div>
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-4xl px-6 py-10">
      {sources.length === 0 ? (
        <div class="rounded-lg border px-6 py-12 text-center" style="border-color: var(--color-rule-default); background: var(--color-surface-raised); color: var(--color-ink-secondary);">
          <div class="mx-auto" style="color: var(--color-ink-tertiary); width: fit-content;">
            <Icon name="folder" size={36} />
          </div>
          <p class="mt-3 text-sm font-ui">
            No bundles found under <code class="text-xs">_workspace/kashkole-ksessions/extracted/</code>.
          </p>
        </div>
      ) : (
        <div class="space-y-12">
          {sources.map((src) => (
            <section>
              <div class="mb-5 flex items-baseline gap-3">
                <h2 class="font-ui text-[11px] font-bold uppercase tracking-[0.22em]" style="color: var(--color-ink);">
                  {src.source}
                </h2>
                <span style="color: var(--color-gold-deep); opacity: 0.5;" class="text-[10px]">✦</span>
                <div class="h-px flex-1" style="background: var(--color-rule-default);"></div>
                <span class="font-ui text-[10px] uppercase tracking-wider" style="color: var(--color-ink-tertiary);">
                  {src.shelves.length} shelf · {src.chapterCount} chapter{src.chapterCount === 1 ? '' : 's'}
                </span>
              </div>

              <div class="space-y-8">
                {src.shelves.map((shelf) => (
                  <div class="rounded-lg border" style="border-color: var(--color-rule-default); background: var(--color-surface-raised);">
                    <div class="border-b px-5 py-3" style="border-color: var(--color-rule-default); background: var(--color-surface-sunken);">
                      <div class="flex items-baseline justify-between gap-4">
                        <div class="flex items-baseline gap-3">
                          <span class="font-ui rounded px-2 py-0.5 text-[10px] font-bold uppercase tracking-[0.14em]" style="background: var(--color-gold-soft); color: var(--color-gold-deep);">
                            Shelf {shelf.shelfPrefix}
                          </span>
                          <h3 style="font-family: var(--font-urdu); direction: rtl; font-size: 22px; line-height: 1.4; color: var(--color-ink);" lang="ur">
                            {shelf.shelfName}
                          </h3>
                        </div>
                        <span class="font-ui text-[10px] uppercase tracking-wider" style="color: var(--color-ink-tertiary);">
                          {shelf.chapters.length} chapter{shelf.chapters.length === 1 ? '' : 's'}
                        </span>
                      </div>
                    </div>

                    <ul class="divide-y" style="--tw-divide-opacity: 1;">
                      {shelf.chapters.map((ch) => {
                        const href = `/source-extractor/${ch.source}/${ch.shelfSlug}/${ch.bookSlug}/`;
                        const counts = ch.manifest.counts;
                        return (
                          <li class="border-t first:border-t-0" style="border-color: var(--color-rule-subtle);">
                            <a href={href} class="flex items-center justify-between gap-4 px-5 py-3 transition hover:bg-stone-50" style="color: var(--color-ink);">
                              <div class="flex items-baseline gap-3 min-w-0">
                                <span class="font-ui shrink-0 text-[11px] font-semibold tabular-nums" style="color: var(--color-ink-tertiary);">
                                  {ch.manifest.book.prefix}
                                </span>
                                <span style="font-family: var(--font-urdu); direction: rtl; font-size: 18px; line-height: 1.5;" lang="ur" class="truncate">
                                  {ch.manifest.book.name}
                                </span>
                              </div>
                              <div class="flex shrink-0 items-center gap-3 font-ui text-[10px] uppercase tracking-wider" style="color: var(--color-ink-tertiary);">
                                {counts && (
                                  <>
                                    <span>{counts.sections} sec</span>
                                    {counts.inline_images > 0 && (
                                      <span>{counts.inline_images} img</span>
                                    )}
                                    {counts.curated_citation_refs > 0 && (
                                      <span>{counts.curated_citation_refs} ref</span>
                                    )}
                                  </>
                                )}
                                <span class="font-ui rounded border px-1.5 py-0.5 text-[9px] uppercase tracking-wider" style="border-color: var(--color-rule-default); color: var(--color-ink-secondary);">
                                  {ch.manifest.source_language}
                                </span>
                                <Icon name="arrow-right" size={13} />
                              </div>
                            </a>
                          </li>
                        );
                      })}
                    </ul>
                  </div>
                ))}
              </div>
            </section>
          ))}
        </div>
      )}
    </main>
  </body>
</html>
