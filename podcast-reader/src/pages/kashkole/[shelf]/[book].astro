---
/**
 * Kashkole bilingual chapter view — dual panel.
 *
 *   Left  (English) | Right (Urdu, RTL)
 *
 * Features:
 *   - Each topic shows English title (from R2 decisions) + Urdu source title
 *   - Body: Urdu source rendered always; English body = "translation pending"
 *     for now (the pilot translation populates 3 chapters separately)
 *   - Top sticky bar: search filters topics + jump-to controls
 *   - Expand: either panel can go full-width; other panel collapses
 *   - Prev/Next chapter navigation in shelf
 *   - Keyboard shortcuts: /, j/k, e (expand english), u (expand urdu), b (both)
 */
import '~/styles/global.css';
import Icon from '~/components/ui/Icon.astro';
import ThemeScript from '~/components/layout/ThemeScript.astro';
import ThemeToggle from '~/components/layout/ThemeToggle.astro';
import { findChapter, loadChapterMarkdown, discoverBundles } from '~/lib/source-extractor';
import { parseBilingual } from '~/lib/bilingual-sections';
import {
  getBinderEnglish,
  getChapterEnglish,
  isBinderTopicRetitled,
  getDedupClustersForChapter,
} from '~/lib/decisions';

const { shelf, book } = Astro.params;
if (!shelf || !book) return new Response('Missing params', { status: 400 });

const chapter = await findChapter('kashkole', shelf, book);
if (!chapter) return new Response(`Chapter not found: kashkole/${shelf}/${book}`, { status: 404 });

const m = chapter.manifest;
const binderId = m.shelf.id;
const chapterId = m.book.id;
const rawMd = await loadChapterMarkdown(chapter);

const [bilingualParsed, binderEn, chapterEn, topicsRetitled, dedupClusters] = await Promise.all([
  parseBilingual(binderId, chapterId, rawMd),
  getBinderEnglish(m.shelf.name),
  getChapterEnglish(binderId, chapterId),
  isBinderTopicRetitled(binderId),
  getDedupClustersForChapter(binderId, chapterId),
]);

const all = await discoverBundles();
const shelfGroup = all
  .find((s) => s.source === 'kashkole')
  ?.shelves.find((sh) => sh.shelfSlug === shelf);
const siblings = shelfGroup?.chapters ?? [];
const idx = siblings.findIndex((c) => c.bookSlug === book);
const prev = idx > 0 ? siblings[idx - 1] : null;
const next = idx >= 0 && idx < siblings.length - 1 ? siblings[idx + 1] : null;

// Look up English titles for prev/next labels
const prevEn = prev ? await getChapterEnglish(prev.manifest.shelf.id, prev.manifest.book.id) : null;
const nextEn = next ? await getChapterEnglish(next.manifest.shelf.id, next.manifest.book.id) : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{chapterEn?.en_title ?? m.book.name} · Kashkole</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ThemeScript />
    <style>
      /* === Bilingual layout === */
      .bilingual-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0;
      }
      .bilingual-grid[data-mode="english-only"] {
        grid-template-columns: 1fr 0fr;
      }
      .bilingual-grid[data-mode="english-only"] .ur-panel { display: none; }
      .bilingual-grid[data-mode="urdu-only"] {
        grid-template-columns: 0fr 1fr;
      }
      .bilingual-grid[data-mode="urdu-only"] .en-panel { display: none; }

      .en-panel { padding: 1.5rem 2rem 2rem 2rem; border-right: 1px solid var(--color-rule-default); }
      .ur-panel {
        padding: 1.5rem 2rem 2rem 2rem;
        background: var(--color-surface-zebra);
        direction: rtl;
      }
      .bilingual-grid[data-mode="urdu-only"] .ur-panel,
      .bilingual-grid[data-mode="english-only"] .en-panel { border-right: 0; }

      /* Sticky topic header */
      .topic-row {
        display: contents;
      }
      .topic-en, .topic-ur {
        padding: 1.5rem 2rem;
        border-top: 1px solid var(--color-rule-subtle);
      }
      .topic-en {
        border-right: 1px solid var(--color-rule-default);
      }
      .topic-ur {
        background: var(--color-surface-zebra);
        direction: rtl;
      }
      .bilingual-grid[data-mode="english-only"] .topic-ur { display: none; }
      .bilingual-grid[data-mode="urdu-only"] .topic-en { display: none; }
      .bilingual-grid[data-mode="urdu-only"] .topic-ur { border-right: 0; }
      .bilingual-grid[data-mode="english-only"] .topic-en { border-right: 0; }

      /* Body prose */
      .se-prose .ar {
        font-family: var(--font-arabic-naskh);
        direction: rtl;
        unicode-bidi: embed;
        font-size: 1.05em;
        font-weight: 500;
      }
      .se-prose .ar-quote {
        font-family: var(--font-arabic-naskh);
        direction: rtl;
        display: block;
        padding: 0.5em 0;
        font-size: 1.15em;
        font-weight: 500;
        color: var(--color-ink);
      }
      .topic-ur .se-prose {
        font-family: var(--font-urdu);
        font-size: 22px;
        line-height: 1.95;
        color: var(--color-ink);
      }
      .topic-en .se-prose {
        font-family: 'EB Garamond', Georgia, serif;
        font-size: 17px;
        line-height: 1.75;
      }
      .topic-en .pending-translation {
        margin: 1rem 0;
        padding: 1.25rem 1.5rem;
        background: var(--color-surface-sunken);
        border-left: 3px solid var(--color-derived);
        border-radius: 0 6px 6px 0;
        font-family: var(--font-ui);
        color: var(--color-ink-secondary);
        font-style: italic;
        font-size: 14px;
      }
      .topic-en .pending-translation strong {
        color: var(--color-derived);
        font-weight: 600;
        font-style: normal;
        text-transform: uppercase;
        font-size: 11px;
        letter-spacing: 0.12em;
        display: block;
        margin-bottom: 0.4rem;
      }

      /* Quran cite chips */
      .se-prose .quran-cite {
        display: inline-block;
        padding: 0.06em 0.5em;
        margin: 0 0.15em;
        background: var(--color-quran-soft);
        color: var(--color-quran);
        border-radius: 3px;
        font-family: var(--font-ui);
        font-size: 0.78em;
        font-weight: 600;
        letter-spacing: 0.02em;
      }
      .se-prose blockquote {
        border-left: 2px solid var(--color-rule-default);
        padding-left: 1rem;
        margin: 1rem 0;
        color: var(--color-ink-secondary);
      }
      .topic-ur .se-prose blockquote {
        border-left: 0;
        border-right: 2px solid var(--color-rule-default);
        padding-left: 0;
        padding-right: 1rem;
      }
      .se-prose table {
        border-collapse: collapse;
        margin: 1.2em 0;
      }
      .se-prose th, .se-prose td {
        border: 1px solid var(--color-rule-default);
        padding: 0.5em 0.85em;
        vertical-align: top;
      }
      .se-prose th { background: var(--color-surface-sunken); font-weight: 600; }
      .se-prose h3 { margin-top: 1.3em; margin-bottom: 0.4em; font-weight: 600; font-size: 1.15em; }
      .se-prose p { margin: 0.85em 0; }

      /* TOC sidebar */
      .toc-link.is-active {
        background: var(--color-gold-soft);
        color: var(--color-gold-deep);
        font-weight: 600;
      }
      .toc-link.is-hidden { display: none; }

      /* Mobile fallback */
      @media (max-width: 900px) {
        .bilingual-grid { grid-template-columns: 1fr; }
        .bilingual-grid[data-mode] { grid-template-columns: 1fr; }
        .toc-sidebar { display: none; }
        .ur-panel, .en-panel, .topic-ur, .topic-en { border-right: 0; }
      }
    </style>
  </head>
  <body class="min-h-screen antialiased" style="background: var(--color-surface-page); color: var(--color-ink);">
    <div class="fixed top-4 right-4 z-50"><ThemeToggle /></div>

    <!-- Sticky top header -->
    <header class="sticky top-0 z-30 border-b backdrop-blur-sm" style="border-color: var(--color-rule-default); background: rgba(255,255,255,0.92);">
      <div class="gold-hairline absolute inset-x-0 top-0" aria-hidden></div>
      <div class="mx-auto max-w-[1900px] px-6 py-3">
        <div class="flex items-center justify-between gap-4">
          <nav class="font-ui flex min-w-0 items-center gap-2 text-[11px] uppercase tracking-[0.16em]" style="color: var(--color-ink-tertiary);">
            <a href="/" class="hover:underline">Library</a>
            <Icon name="chevron-right" size={11} />
            <a href="/kashkole/" class="hover:underline">Kashkole</a>
            <Icon name="chevron-right" size={11} />
            {binderEn && (
              <span class="truncate" style="color: var(--color-ink-secondary); max-width: 240px;">{binderEn}</span>
            )}
            <Icon name="chevron-right" size={11} />
            <span class="truncate font-semibold" style="color: var(--color-gold-deep); max-width: 320px;">
              {chapterEn?.en_title ?? m.book.name}
            </span>
          </nav>

          <div class="flex shrink-0 items-center gap-2">
            <!-- Search -->
            <div class="relative">
              <input
                type="search"
                id="topic-search"
                placeholder="Search topics… (/)"
                class="font-ui rounded-md border px-3 py-1.5 text-[12px] outline-none"
                style="border-color: var(--color-rule-default); background: var(--color-surface-page); color: var(--color-ink); width: 260px;"
              />
            </div>

            <!-- Panel mode controls -->
            <div class="flex rounded-md border overflow-hidden" style="border-color: var(--color-rule-default);" role="group" aria-label="Panel mode">
              <button data-mode="english-only" class="panel-mode-btn font-ui px-2.5 py-1.5 text-[11px] uppercase tracking-wider transition" style="background: var(--color-surface-raised); color: var(--color-ink-secondary);" title="English only (E)">EN</button>
              <button data-mode="both" class="panel-mode-btn is-active font-ui border-x px-2.5 py-1.5 text-[11px] uppercase tracking-wider transition" style="border-color: var(--color-rule-default); background: var(--color-gold-soft); color: var(--color-gold-deep);" title="Both panels (B)"><Icon name="panel-left" size={11} /></button>
              <button data-mode="urdu-only" class="panel-mode-btn font-ui px-2.5 py-1.5 text-[11px] uppercase tracking-wider transition" style="background: var(--color-surface-raised); color: var(--color-ink-secondary);" title="Urdu only (U)">UR</button>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Chapter title band -->
    <section class="border-b" style="border-color: var(--color-rule-default); background: var(--color-surface-raised);">
      <div class="mx-auto max-w-[1900px] px-8 py-8">
        <div class="grid gap-6 lg:grid-cols-[1fr_auto_1fr]">
          <!-- English title -->
          <div>
            <div class="font-ui text-[10px] uppercase tracking-[0.18em]" style="color: var(--color-ink-tertiary);">
              {binderEn ?? m.shelf.name} · chapter {m.book.id}
            </div>
            <h1 class="mt-2 text-4xl font-semibold leading-tight tracking-tight" style="font-family: 'EB Garamond', Georgia, serif; color: var(--color-ink);">
              {chapterEn?.en_title ?? <span class="italic" style="color: var(--color-ink-tertiary);">English title pending</span>}
            </h1>
            {chapterEn?.confidence && (
              <div class="font-ui mt-2 text-[10px] uppercase tracking-[0.14em]" style="color: var(--color-ink-tertiary);">
                Translation confidence:
                {chapterEn.confidence === 'high' && <span style="color: var(--color-gold-deep);">★★★ high</span>}
                {chapterEn.confidence === 'medium' && <span>★★ medium</span>}
                {chapterEn.confidence === 'low' && <span>★ low</span>}
              </div>
            )}
          </div>

          <!-- Center divider -->
          <div class="hidden lg:flex flex-col items-center justify-center px-4" style="color: var(--color-gold-deep); opacity: 0.4;">
            <Icon name="sparkle" size={16} />
          </div>

          <!-- Urdu title -->
          <div class="lg:text-right">
            <div class="font-ui text-[10px] uppercase tracking-[0.18em]" style="color: var(--color-ink-tertiary);">
              Source · {m.source_language.toUpperCase()}
            </div>
            <h1 class="mt-2" style="font-family: var(--font-urdu); direction: rtl; font-size: 42px; line-height: 1.3; color: var(--color-ink);" lang="ur">
              {m.book.name}
            </h1>
            {topicsRetitled ? (
              <div class="font-ui mt-2 text-[10px] uppercase tracking-[0.14em]" style="color: var(--color-gold-deep);">
                Topics retitled (R2)
              </div>
            ) : (
              <div class="font-ui mt-2 text-[10px] uppercase tracking-[0.14em]" style="color: var(--color-ink-tertiary);">
                Topic retitles pending
              </div>
            )}
          </div>
        </div>

        {dedupClusters.length > 0 && (
          <div class="mt-6 rounded-md border px-4 py-3 text-[12px]" style="border-color: var(--color-derived); background: var(--color-derived-soft); color: var(--color-ink-secondary);">
            <span class="font-ui font-semibold uppercase tracking-wider text-[10px]" style="color: var(--color-derived);">Cross-references:</span>{' '}
            This chapter is involved in {dedupClusters.length} dedup cluster{dedupClusters.length === 1 ? '' : 's'} (see <code class="text-[11px]">tools/content_classifier/data/kashkole-r1-decisions.yaml</code>).
          </div>
        )}
      </div>
    </section>

    <!-- Main: TOC sidebar + bilingual content -->
    <main class="mx-auto flex max-w-[1900px]">
      <!-- TOC sidebar -->
      <aside class="toc-sidebar sticky top-[57px] hidden h-[calc(100vh-57px)] w-72 shrink-0 overflow-y-auto border-r lg:block" style="border-color: var(--color-rule-default); background: var(--color-surface-raised);">
        <div class="border-b px-4 py-3" style="border-color: var(--color-rule-subtle);">
          <div class="font-ui text-[10px] font-bold uppercase tracking-[0.15em]" style="color: var(--color-ink-tertiary);">
            Topics in this chapter
          </div>
          <div class="font-ui mt-0.5 text-[10px]" style="color: var(--color-ink-tertiary);">
            <span id="toc-counter">{bilingualParsed.sections.length}</span> total
          </div>
        </div>
        <nav class="px-2 py-2 text-[12px]">
          {bilingualParsed.sections.map((s) => (
            <a
              href={`#topic-${s.position}`}
              data-topic-pos={s.position}
              data-topic-en={(s.englishTitle ?? '').toLowerCase()}
              data-topic-ur={s.urduLabel}
              class="toc-link block rounded-md px-3 py-1.5 transition hover:bg-stone-100"
              style="color: var(--color-ink-secondary);"
            >
              <div class="flex items-baseline gap-2">
                <span class="font-ui shrink-0 text-[10px] font-semibold tabular-nums" style="color: var(--color-ink-tertiary);">
                  {s.position}.
                </span>
                <div class="min-w-0 flex-1">
                  {s.englishTitle ? (
                    <div class="line-clamp-2 leading-snug" style="font-family: 'EB Garamond', Georgia, serif; font-size: 13px;">
                      {s.englishTitle}
                    </div>
                  ) : (
                    <div class="line-clamp-2 leading-snug" style="font-family: var(--font-urdu); direction: rtl; font-size: 13px;" lang="ur">
                      {s.urduLabel}
                    </div>
                  )}
                </div>
              </div>
            </a>
          ))}
        </nav>
      </aside>

      <!-- Bilingual content -->
      <article class="flex-1 min-w-0">
        <div id="bilingual-grid" class="bilingual-grid" data-mode="both">
          <!-- Panel headers -->
          <div class="en-panel sticky-panel-header" style="position: sticky; top: 57px; z-index: 10; background: var(--color-surface-page); border-bottom: 1px solid var(--color-rule-default); padding-top: 1rem; padding-bottom: 1rem;">
            <div class="font-ui flex items-center justify-between text-[10px] font-bold uppercase tracking-[0.18em]" style="color: var(--color-gold-deep);">
              <span>English</span>
              <span style="color: var(--color-ink-tertiary);">left panel</span>
            </div>
          </div>
          <div class="ur-panel sticky-panel-header" style="position: sticky; top: 57px; z-index: 10; background: var(--color-surface-zebra); border-bottom: 1px solid var(--color-rule-default); padding-top: 1rem; padding-bottom: 1rem;">
            <div class="font-ui flex items-center justify-between text-[10px] font-bold uppercase tracking-[0.18em]" style="color: var(--color-gold-deep); direction: ltr;">
              <span style="color: var(--color-ink-tertiary);">right panel</span>
              <span>اردو · Urdu</span>
            </div>
          </div>

          {bilingualParsed.sections.map((s) => (
            <div class="topic-row" data-topic-pos={s.position} data-topic-en={(s.englishTitle ?? '').toLowerCase()} data-topic-ur={s.urduLabel}>
              <!-- English column -->
              <div class="topic-en" id={`topic-${s.position}`}>
                <header class="mb-3 flex items-baseline gap-2 border-b pb-2" style="border-color: var(--color-rule-subtle);">
                  <span class="font-ui shrink-0 rounded px-1.5 py-0.5 text-[10px] font-bold tabular-nums" style="background: var(--color-surface-sunken); color: var(--color-ink-tertiary);">
                    {s.position.toString().padStart(2, '0')}
                  </span>
                  <h2 class="text-[19px] font-semibold leading-snug tracking-tight" style="font-family: 'EB Garamond', Georgia, serif;">
                    {s.englishTitle ?? <span class="italic" style="color: var(--color-ink-tertiary);">English title pending</span>}
                  </h2>
                  {s.englishConfidence === 'high' && <span class="shrink-0" title="High confidence translation" style="color: var(--color-gold-deep); font-size: 11px;">★★★</span>}
                  {s.englishConfidence === 'medium' && <span class="shrink-0" title="Medium confidence" style="color: var(--color-ink-secondary); font-size: 11px;">★★</span>}
                  {s.englishConfidence === 'low' && <span class="shrink-0" title="Low confidence" style="color: var(--color-ink-tertiary); font-size: 11px;">★</span>}
                </header>
                <div class="se-prose">
                  <div class="pending-translation">
                    <strong>Translation pending</strong>
                    Source Urdu content is rendered in the right panel. The polished + augmented English body for this topic will appear here once the translation pipeline (Phase 0a-translate → adaptation → kashkole-challenger) has processed it.
                  </div>
                </div>
              </div>

              <!-- Urdu column -->
              <div class="topic-ur">
                <header class="mb-3 flex items-baseline justify-between gap-2 border-b pb-2" style="border-color: var(--color-rule-subtle);">
                  <span class="font-ui shrink-0 rounded px-1.5 py-0.5 text-[10px] font-bold tabular-nums" style="background: var(--color-surface-sunken); color: var(--color-ink-tertiary); direction: ltr;">
                    {s.position.toString().padStart(2, '0')}
                  </span>
                  <h2 style="font-family: var(--font-urdu); font-size: 22px; line-height: 1.45; color: var(--color-ink);" lang="ur">
                    {s.urduLabel}
                  </h2>
                </header>
                <div class="se-prose" lang="ur" set:html={s.bodyHtml}></div>
              </div>
            </div>
          ))}
        </div>

        <!-- Prev / next chapter nav -->
        {(prev || next) && (
          <nav class="mt-12 border-t px-8 py-8" style="border-color: var(--color-rule-default);">
            <div class="flex items-stretch justify-between gap-3">
              {prev ? (
                <a href={`/kashkole/${prev.shelfSlug}/${prev.bookSlug}/`} class="flex-1 rounded-lg border p-4 transition hover:-translate-y-px hover:shadow-md" style="border-color: var(--color-rule-default); background: var(--color-surface-raised);">
                  <div class="font-ui text-[10px] uppercase tracking-wider" style="color: var(--color-ink-tertiary);">
                    ← Previous chapter
                  </div>
                  <div class="mt-1 font-semibold" style="font-family: 'EB Garamond', Georgia, serif; color: var(--color-ink); font-size: 15px;">
                    {prevEn?.en_title ?? prev.manifest.book.name}
                  </div>
                  <div class="mt-0.5 text-right" style="font-family: var(--font-urdu); direction: rtl; font-size: 16px; color: var(--color-ink-secondary);" lang="ur">
                    {prev.manifest.book.name}
                  </div>
                </a>
              ) : <span class="flex-1"></span>}
              {next ? (
                <a href={`/kashkole/${next.shelfSlug}/${next.bookSlug}/`} class="flex-1 rounded-lg border p-4 text-right transition hover:-translate-y-px hover:shadow-md" style="border-color: var(--color-rule-default); background: var(--color-surface-raised);">
                  <div class="font-ui text-[10px] uppercase tracking-wider" style="color: var(--color-ink-tertiary);">
                    Next chapter →
                  </div>
                  <div class="mt-1 font-semibold" style="font-family: 'EB Garamond', Georgia, serif; color: var(--color-ink); font-size: 15px;">
                    {nextEn?.en_title ?? next.manifest.book.name}
                  </div>
                  <div class="mt-0.5" style="font-family: var(--font-urdu); direction: rtl; font-size: 16px; color: var(--color-ink-secondary);" lang="ur">
                    {next.manifest.book.name}
                  </div>
                </a>
              ) : <span class="flex-1"></span>}
            </div>
          </nav>
        )}
      </article>
    </main>

    <script>
      // === Panel mode toggle ===
      const grid = document.getElementById('bilingual-grid')!;
      const modeButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('.panel-mode-btn'));
      function setMode(mode: 'both' | 'english-only' | 'urdu-only') {
        grid.dataset.mode = mode;
        modeButtons.forEach((b) => {
          if (b.dataset.mode === mode) {
            b.classList.add('is-active');
            b.style.background = 'var(--color-gold-soft)';
            b.style.color = 'var(--color-gold-deep)';
          } else {
            b.classList.remove('is-active');
            b.style.background = 'var(--color-surface-raised)';
            b.style.color = 'var(--color-ink-secondary)';
          }
        });
        try { localStorage.setItem('kashkole-panel-mode', mode); } catch {}
      }
      modeButtons.forEach((b) =>
        b.addEventListener('click', () => setMode(b.dataset.mode as any)),
      );
      try {
        const saved = localStorage.getItem('kashkole-panel-mode');
        if (saved === 'english-only' || saved === 'urdu-only') setMode(saved);
      } catch {}

      // === Search filter ===
      const search = document.getElementById('topic-search') as HTMLInputElement;
      const tocCounter = document.getElementById('toc-counter')!;
      const totalTopics = document.querySelectorAll('.topic-row').length;
      function applyFilter(q: string) {
        const needle = q.trim().toLowerCase();
        const rows = Array.from(document.querySelectorAll<HTMLElement>('.topic-row'));
        const links = Array.from(document.querySelectorAll<HTMLElement>('.toc-link'));
        if (!needle) {
          rows.forEach((r) => (r.style.display = ''));
          links.forEach((l) => l.classList.remove('is-hidden'));
          tocCounter.textContent = `${totalTopics}`;
          return;
        }
        let visible = 0;
        rows.forEach((r) => {
          const en = r.dataset.topicEn || '';
          const ur = r.dataset.topicUr || '';
          if (en.includes(needle) || ur.includes(needle)) {
            r.style.display = '';
            visible++;
          } else {
            r.style.display = 'none';
          }
        });
        links.forEach((l) => {
          const en = l.dataset.topicEn || '';
          const ur = l.dataset.topicUr || '';
          if (en.includes(needle) || ur.includes(needle)) l.classList.remove('is-hidden');
          else l.classList.add('is-hidden');
        });
        tocCounter.textContent = `${visible} / ${totalTopics}`;
      }
      search.addEventListener('input', () => applyFilter(search.value));

      // === Active topic in TOC on scroll ===
      const headerH = 57;
      function syncActiveToc() {
        const rows = Array.from(document.querySelectorAll<HTMLElement>('.topic-en'));
        let active = rows[0];
        for (const r of rows) {
          if (r.getBoundingClientRect().top <= headerH + 80) active = r;
        }
        if (!active) return;
        const pos = active.id.replace('topic-', '');
        document.querySelectorAll('.toc-link').forEach((l) => l.classList.remove('is-active'));
        const link = document.querySelector(`.toc-link[data-topic-pos="${pos}"]`);
        link?.classList.add('is-active');
      }
      window.addEventListener('scroll', syncActiveToc, { passive: true });
      syncActiveToc();

      // === Keyboard shortcuts ===
      window.addEventListener('keydown', (e) => {
        const tag = (document.activeElement?.tagName || '').toLowerCase();
        if (tag === 'input' || tag === 'textarea') {
          if (e.key === 'Escape') (document.activeElement as HTMLElement).blur();
          return;
        }
        if (e.key === '/') {
          e.preventDefault();
          search.focus();
          search.select();
        } else if (e.key === 'e' || e.key === 'E') setMode('english-only');
        else if (e.key === 'u' || e.key === 'U') setMode('urdu-only');
        else if (e.key === 'b' || e.key === 'B') setMode('both');
        else if (e.key === 'j' || e.key === 'J' || e.key === 'k' || e.key === 'K') {
          // jump to next/prev topic
          const rows = Array.from(document.querySelectorAll<HTMLElement>('.topic-en'))
            .filter((r) => (r.closest('.topic-row') as HTMLElement)?.style.display !== 'none');
          if (rows.length === 0) return;
          let curIdx = 0;
          for (let i = 0; i < rows.length; i++) {
            if (rows[i].getBoundingClientRect().top <= headerH + 80) curIdx = i;
          }
          const target = (e.key === 'j' || e.key === 'J')
            ? rows[Math.min(curIdx + 1, rows.length - 1)]
            : rows[Math.max(curIdx - 1, 0)];
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    </script>
  </body>
</html>
