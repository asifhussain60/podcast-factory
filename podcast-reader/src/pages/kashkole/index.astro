---
/**
 * Kashkole binder + chapter index.
 *
 * Lists all binders → chapters with both English (R1/R2) and Urdu names.
 * Includes a live search across English titles, Urdu names, and topic counts.
 */
import '~/styles/global.css';
import Icon from '~/components/ui/Icon.astro';
import ThemeScript from '~/components/layout/ThemeScript.astro';
import ThemeToggle from '~/components/layout/ThemeToggle.astro';
import { discoverBundles } from '~/lib/source-extractor';
import {
  getBinderEnglish,
  getChapterEnglish,
  isBinderTopicRetitled,
} from '~/lib/decisions';

const all = await discoverBundles();
const kashkole = all.find((s) => s.source === 'kashkole');

interface EnrichedChapter {
  binderId: number;
  chapterId: number;
  shelfSlug: string;
  bookSlug: string;
  urduName: string;
  englishTitle?: string;
  confidence?: 'high' | 'medium' | 'low';
  sections: number;
  inlineImages: number;
  stage: string;
}

interface EnrichedShelf {
  binderId: number;
  shelfSlug: string;
  shelfPrefix: string;
  urduName: string;
  englishTitle?: string;
  topicsRetitled: boolean;
  chapterCount: number;
  totalSections: number;
  chapters: EnrichedChapter[];
}

const shelves: EnrichedShelf[] = [];
if (kashkole) {
  for (const sh of kashkole.shelves) {
    const binderId = sh.chapters[0]?.manifest.shelf.id;
    if (binderId == null) continue;
    const enBinder = await getBinderEnglish(sh.shelfName);
    const topicsRetitled = await isBinderTopicRetitled(binderId);

    const chapters: EnrichedChapter[] = [];
    for (const ch of sh.chapters) {
      const chapterId = ch.manifest.book.id;
      const enChapter = await getChapterEnglish(binderId, chapterId);
      chapters.push({
        binderId,
        chapterId,
        shelfSlug: sh.shelfSlug,
        bookSlug: ch.bookSlug,
        urduName: ch.manifest.book.name,
        englishTitle: enChapter?.en_title,
        confidence: enChapter?.confidence,
        sections: ch.manifest.counts?.sections ?? 0,
        inlineImages: ch.manifest.counts?.inline_images ?? 0,
        stage: ch.manifest.stage,
      });
    }

    shelves.push({
      binderId,
      shelfSlug: sh.shelfSlug,
      shelfPrefix: sh.shelfPrefix,
      urduName: sh.shelfName,
      englishTitle: enBinder,
      topicsRetitled,
      chapterCount: sh.chapters.length,
      totalSections: chapters.reduce((n, c) => n + c.sections, 0),
      chapters,
    });
  }
}

const totalChapters = shelves.reduce((n, s) => n + s.chapterCount, 0);
const totalSections = shelves.reduce((n, s) => n + s.totalSections, 0);
const retitledBinders = shelves.filter((s) => s.topicsRetitled).length;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Kashkole · Bilingual Reader</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ThemeScript />
  </head>
  <body class="min-h-screen antialiased" style="background: var(--color-surface-page); color: var(--color-ink);">
    <div class="fixed top-4 right-4 z-40"><ThemeToggle /></div>

    <!-- Header -->
    <header class="border-b" style="border-color: var(--color-rule-default); background: var(--color-surface-raised);">
      <div class="gold-hairline absolute inset-x-0 top-0" aria-hidden></div>
      <div class="mx-auto max-w-[1600px] px-8 py-10">
        <nav class="font-ui flex items-center gap-2 text-[11px] uppercase tracking-[0.18em]" style="color: var(--color-ink-tertiary);">
          <a href="/" class="hover:underline">Library</a>
          <Icon name="chevron-right" size={11} />
          <span style="color: var(--color-gold-deep);">Kashkole</span>
        </nav>

        <div class="mt-6 flex flex-wrap items-end justify-between gap-6">
          <div>
            <h1 class="text-5xl font-semibold tracking-tight" style="font-family: 'EB Garamond', Georgia, serif; color: var(--color-ink);">
              Kashkole
            </h1>
            <div class="mt-1.5 text-2xl" style="font-family: var(--font-urdu); direction: rtl;" lang="ur">
              کشکول
            </div>
            <p class="mt-3 max-w-2xl text-base italic leading-relaxed" style="font-family: 'EB Garamond', Georgia, serif; color: var(--color-ink-secondary);">
              19 binders. 122 chapters. 1,337 topics. Tayyibi Ismaili philosophical, theological, jurisprudential, and devotional materials in Urdu — paired side-by-side with proposed English titles and (when translated) English text.
            </p>
          </div>

          <div class="flex gap-0 rounded-lg border" style="border-color: var(--color-rule-default); background: var(--color-surface-raised);">
            <div class="px-5 py-3 text-center">
              <div class="text-[28px] font-semibold leading-none tabular-nums" style="font-family: 'EB Garamond', Georgia, serif; color: var(--color-ink);">{shelves.length}</div>
              <div class="font-ui mt-1 text-[10px] font-medium uppercase tracking-[0.15em]" style="color: var(--color-ink-tertiary);">Binders</div>
            </div>
            <div class="w-px self-stretch" style="background: var(--color-rule-default);"></div>
            <div class="px-5 py-3 text-center">
              <div class="text-[28px] font-semibold leading-none tabular-nums" style="font-family: 'EB Garamond', Georgia, serif; color: var(--color-gold-deep);">{totalChapters}</div>
              <div class="font-ui mt-1 text-[10px] font-medium uppercase tracking-[0.15em]" style="color: var(--color-gold-deep);">Chapters</div>
            </div>
            <div class="w-px self-stretch" style="background: var(--color-rule-default);"></div>
            <div class="px-5 py-3 text-center">
              <div class="text-[28px] font-semibold leading-none tabular-nums" style="font-family: 'EB Garamond', Georgia, serif; color: var(--color-ink);">{totalSections}</div>
              <div class="font-ui mt-1 text-[10px] font-medium uppercase tracking-[0.15em]" style="color: var(--color-ink-tertiary);">Topics</div>
            </div>
            <div class="w-px self-stretch" style="background: var(--color-rule-default);"></div>
            <div class="px-5 py-3 text-center">
              <div class="text-[28px] font-semibold leading-none tabular-nums" style="font-family: 'EB Garamond', Georgia, serif; color: var(--color-ink);">{retitledBinders}/{shelves.length}</div>
              <div class="font-ui mt-1 text-[10px] font-medium uppercase tracking-[0.15em]" style="color: var(--color-ink-tertiary);">Topic-retitled</div>
            </div>
          </div>
        </div>

        <!-- Sticky search bar -->
        <div class="mt-8">
          <label class="relative block">
            <input
              type="search"
              id="kashkole-search"
              placeholder="Search chapters by English title or Urdu name…"
              class="font-ui w-full rounded-lg border px-5 py-3.5 text-base outline-none transition focus:ring-2"
              style="border-color: var(--color-rule-default); background: var(--color-surface-page); color: var(--color-ink);"
            />
            <span class="font-ui absolute right-4 top-1/2 -translate-y-1/2 rounded border px-2 py-0.5 text-[10px] uppercase tracking-wider" style="border-color: var(--color-rule-default); color: var(--color-ink-tertiary);">
              /
            </span>
          </label>
          <div class="font-ui mt-2 text-[11px]" style="color: var(--color-ink-tertiary);">
            <span id="search-counter">{totalChapters} chapters</span>
            <span> · Confidence: <span class="rounded px-1.5 py-0.5" style="background: var(--color-gold-soft); color: var(--color-gold-deep);">★★★ high</span> · <span class="rounded px-1.5 py-0.5 border" style="border-color: var(--color-rule-default);">★★ medium</span> · <span class="rounded px-1.5 py-0.5 border" style="border-color: var(--color-rule-default); color: var(--color-ink-tertiary);">★ low</span></span>
          </div>
        </div>
      </div>
    </header>

    <!-- Binder/chapter list -->
    <main class="mx-auto max-w-[1600px] px-8 py-10">
      {shelves.length === 0 ? (
        <div class="rounded-lg border px-6 py-12 text-center" style="border-color: var(--color-rule-default); background: var(--color-surface-raised);">
          <Icon name="folder" size={36} />
          <p class="font-ui mt-3 text-sm" style="color: var(--color-ink-secondary);">No Kashkole bundles found.</p>
        </div>
      ) : (
        <div class="space-y-10" id="binder-list">
          {shelves.map((sh) => (
            <section data-binder-id={sh.binderId} class="binder-section">
              <header class="mb-4 flex items-baseline justify-between gap-6 border-b pb-3" style="border-color: var(--color-rule-default);">
                <div class="flex items-baseline gap-4 min-w-0">
                  <span class="font-ui shrink-0 rounded px-2 py-0.5 text-[10px] font-bold uppercase tracking-[0.14em]" style="background: var(--color-gold-soft); color: var(--color-gold-deep);">
                    Binder {sh.shelfPrefix}
                  </span>
                  {sh.englishTitle && (
                    <h2 class="truncate text-2xl font-semibold tracking-tight" style="font-family: 'EB Garamond', Georgia, serif; color: var(--color-ink);">
                      {sh.englishTitle}
                    </h2>
                  )}
                  <span class="truncate" style="font-family: var(--font-urdu); direction: rtl; font-size: 20px; color: var(--color-ink-secondary);" lang="ur">
                    {sh.urduName}
                  </span>
                </div>
                <div class="font-ui flex shrink-0 items-center gap-4 text-[10px] uppercase tracking-[0.14em]" style="color: var(--color-ink-tertiary);">
                  {sh.topicsRetitled ? (
                    <span class="rounded px-1.5 py-0.5" style="background: var(--color-gold-soft); color: var(--color-gold-deep);">topics retitled</span>
                  ) : (
                    <span class="rounded border px-1.5 py-0.5" style="border-color: var(--color-rule-default);">topics pending</span>
                  )}
                  <span>{sh.chapterCount} chapter{sh.chapterCount === 1 ? '' : 's'}</span>
                  <span>{sh.totalSections} topics</span>
                </div>
              </header>

              <div class="grid gap-3 lg:grid-cols-2 xl:grid-cols-3">
                {sh.chapters.map((ch) => (
                  <a
                    href={`/kashkole/${ch.shelfSlug}/${ch.bookSlug}/`}
                    data-chapter-en={(ch.englishTitle ?? '').toLowerCase()}
                    data-chapter-ur={ch.urduName}
                    class="chapter-card group relative flex flex-col rounded-lg border p-4 transition hover:-translate-y-0.5 hover:shadow-md"
                    style="border-color: var(--color-rule-default); background: var(--color-surface-raised); color: var(--color-ink);"
                  >
                    <div class="flex items-start justify-between gap-3">
                      <div class="min-w-0 flex-1">
                        {ch.englishTitle ? (
                          <div class="text-[15px] font-semibold leading-tight" style="font-family: 'EB Garamond', Georgia, serif;">
                            {ch.englishTitle}
                          </div>
                        ) : (
                          <div class="font-ui text-[11px] uppercase tracking-wider italic" style="color: var(--color-ink-tertiary);">
                            English title pending
                          </div>
                        )}
                        <div class="mt-2 truncate" style="font-family: var(--font-urdu); direction: rtl; font-size: 17px; color: var(--color-ink-secondary);" lang="ur">
                          {ch.urduName}
                        </div>
                      </div>
                      <div class="shrink-0">
                        {ch.confidence === 'high' && <span title="High confidence translation" style="color: var(--color-gold-deep);">★★★</span>}
                        {ch.confidence === 'medium' && <span title="Medium confidence" style="color: var(--color-ink-secondary);">★★</span>}
                        {ch.confidence === 'low' && <span title="Low confidence" style="color: var(--color-ink-tertiary);">★</span>}
                      </div>
                    </div>

                    <div class="mt-3 flex items-center justify-between border-t pt-2" style="border-color: var(--color-rule-subtle);">
                      <div class="font-ui flex items-center gap-3 text-[10px] uppercase tracking-wider" style="color: var(--color-ink-tertiary);">
                        <span class="tabular-nums">{ch.sections} topics</span>
                        {ch.inlineImages > 0 && <span class="tabular-nums">{ch.inlineImages} img</span>}
                        <span class="rounded border px-1.5 py-0.5 text-[9px]" style="border-color: var(--color-rule-default);">{ch.stage}</span>
                      </div>
                      <Icon name="arrow-right" size={13} />
                    </div>
                  </a>
                ))}
              </div>
            </section>
          ))}
        </div>
      )}
    </main>

    <script>
      // Live search across chapter cards. Hides binder sections with no matches.
      const input = document.getElementById('kashkole-search') as HTMLInputElement;
      const counter = document.getElementById('search-counter')!;
      const binderList = document.getElementById('binder-list')!;
      const allCards = Array.from(binderList.querySelectorAll<HTMLElement>('.chapter-card'));
      const allSections = Array.from(binderList.querySelectorAll<HTMLElement>('.binder-section'));
      const totalChaptersN = allCards.length;

      function applyFilter(q: string) {
        const needle = q.trim().toLowerCase();
        if (!needle) {
          allCards.forEach((c) => (c.style.display = ''));
          allSections.forEach((s) => (s.style.display = ''));
          counter.textContent = `${totalChaptersN} chapters`;
          return;
        }
        let visible = 0;
        for (const card of allCards) {
          const en = card.dataset.chapterEn || '';
          const ur = card.dataset.chapterUr || '';
          if (en.includes(needle) || ur.includes(needle)) {
            card.style.display = '';
            visible++;
          } else {
            card.style.display = 'none';
          }
        }
        for (const sec of allSections) {
          const anyVisible = Array.from(sec.querySelectorAll<HTMLElement>('.chapter-card'))
            .some((c) => c.style.display !== 'none');
          sec.style.display = anyVisible ? '' : 'none';
        }
        counter.textContent = `${visible} of ${totalChaptersN} chapters`;
      }

      input.addEventListener('input', () => applyFilter(input.value));

      // Keyboard shortcut: `/` focuses search
      window.addEventListener('keydown', (e) => {
        if (e.key === '/' && document.activeElement?.tagName !== 'INPUT') {
          e.preventDefault();
          input.focus();
          input.select();
        }
      });
    </script>
  </body>
</html>
