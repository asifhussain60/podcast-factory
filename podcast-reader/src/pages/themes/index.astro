---
/**
 * Theme picker — four design directions for the landing page.
 *
 * Each preview is a full-bleed self-contained hero + grid using the
 * same real data (Kashkole + Podcast Drafts cards). All built on the
 * app's existing CSS variables so the winner drops straight into
 * /index.astro with minimal extraction.
 *
 * Asif scrolls, compares, clicks "Pick this" — winner becomes the
 * canonical landing.
 */
import '~/styles/global.css';
import { discoverBundles } from '~/lib/source-extractor';
import { discoverDrafts } from '~/lib/drafts';
import { getR2Status } from '~/lib/decisions';

const [bundles, drafts, r2Status] = await Promise.all([
  discoverBundles().catch(() => []),
  discoverDrafts().catch(() => []),
  getR2Status().catch(() => null),
]);

const kashkoleSource = bundles.find((s) => s.source === 'kashkole');
const kashkoleChapters = kashkoleSource?.chapterCount ?? 122;
const kashkoleShelves = kashkoleSource?.shelves.length ?? 19;
const draftsCount = drafts.length;
const refinedDrafts = drafts.filter((d) => d.hasRefinedEnglish).length;
const r2Cov = r2Status ? `${r2Status.covered}/${r2Status.covered + r2Status.deferred}` : '9/19';

interface Theme {
  id: string;
  name: string;
  ref: string;
  tagline: string;
}
const themes: Theme[] = [
  { id: 'press',    name: 'Press',    ref: 'Stripe Press / MIT Press', tagline: 'editorial-modern, single warm accent, hard rules' },
  { id: 'folio',    name: 'Folio',    ref: 'Penguin Classics / Knopf', tagline: 'cream paper, serif everywhere, gold monogram' },
  { id: 'atlas',    name: 'Atlas',    ref: 'Vercel / Linear',           tagline: 'modern dark hero, glow, sans+serif pair' },
  { id: 'magazine', name: 'Magazine', ref: 'NYT Magazine / LRB',       tagline: 'bold display serif, asymmetric grid' },
];
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Theme picker — Podcast Reader</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      .picker-bar {
        position: sticky; top: 0; z-index: 50;
        backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
        background: color-mix(in oklab, var(--color-surface-page) 80%, transparent);
        border-bottom: 1px solid var(--color-rule-default);
      }
      .picker-nav { display: flex; gap: 8px; align-items: center; padding: 12px 24px; }
      .picker-chip {
        padding: 6px 14px; border-radius: 9999px;
        font-family: var(--font-ui); font-size: 11px; font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.08em;
        border: 1px solid var(--color-rule-default);
        background: var(--color-surface-raised); color: var(--color-ink-secondary);
        cursor: pointer; text-decoration: none; transition: all 120ms;
      }
      .picker-chip:hover { border-color: var(--color-gold-deep); color: var(--color-gold-deep); transform: translateY(-1px); }
      .theme-section { min-height: 100vh; padding: 0; border-bottom: 4px solid var(--color-rule-emphasis); position: relative; }
      .theme-marker {
        position: sticky; top: 56px; z-index: 40;
        display: flex; justify-content: space-between; align-items: center;
        padding: 10px 24px;
        background: var(--color-surface-emphasis); color: var(--color-ink-on-emphasis);
        font-family: var(--font-ui); font-size: 11px; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.16em;
      }
      .theme-marker .pick-btn {
        padding: 6px 16px; border-radius: 6px;
        background: var(--color-gold-deep); color: white;
        font-weight: 700; cursor: pointer; border: 0; transition: transform 100ms;
      }
      .theme-marker .pick-btn:hover { transform: translateY(-1px); }

      /* ════════════════════════════════════════════════════════════
         THEME A — PRESS (Stripe Press / MIT Press)
         ════════════════════════════════════════════════════════════ */
      .t-press { background: oklch(98.5% 0.005 75); color: oklch(20% 0.012 60); padding: 60px 40px 80px; }
      .t-press-eyebrow {
        display: flex; align-items: center; gap: 16px; max-width: 1200px; margin: 0 auto 48px;
        font-family: "Inter", system-ui, sans-serif;
        font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.24em;
        color: oklch(38% 0.10 60);
      }
      .t-press-eyebrow svg { width: 28px; height: 28px; }
      .t-press-eyebrow .rule { flex: 1; height: 1px; background: oklch(50% 0.12 60); }
      .t-press-hero { max-width: 1200px; margin: 0 auto; }
      .t-press-hero h1 {
        font-family: "Source Serif 4", Charter, Georgia, serif;
        font-size: clamp(56px, 8vw, 96px);
        font-weight: 400; line-height: 0.96; letter-spacing: -0.02em;
        color: oklch(18% 0.012 60); margin: 0 0 24px;
      }
      .t-press-hero h1 em { font-style: italic; color: oklch(38% 0.12 60); font-weight: 400; }
      .t-press-hero p {
        font-family: "Source Serif 4", Charter, Georgia, serif;
        font-size: 19px; line-height: 1.55; max-width: 720px;
        color: oklch(35% 0.01 60); margin: 0 0 56px;
      }
      .t-press-grid {
        max-width: 1200px; margin: 0 auto;
        display: grid; grid-template-columns: 1fr 1fr; gap: 0;
        border-top: 1px solid oklch(28% 0.012 60); border-bottom: 1px solid oklch(28% 0.012 60);
      }
      .t-press-card { padding: 40px 32px 36px; border-right: 1px solid oklch(85% 0.008 60); }
      .t-press-card:last-child { border-right: 0; }
      .t-press-card .num {
        font-family: "Inter", system-ui, sans-serif;
        font-size: 11px; font-weight: 700; letter-spacing: 0.2em;
        color: oklch(38% 0.10 60); text-transform: uppercase;
        margin-bottom: 16px; display: block;
      }
      .t-press-card h2 {
        font-family: "Source Serif 4", Charter, Georgia, serif;
        font-size: 36px; font-weight: 400; letter-spacing: -0.01em; line-height: 1.05;
        color: oklch(18% 0.012 60); margin: 0 0 4px;
      }
      .t-press-card .sub {
        font-family: "Inter", system-ui, sans-serif;
        font-size: 12px; color: oklch(48% 0.008 60); margin-bottom: 20px;
        letter-spacing: 0.04em;
      }
      .t-press-card p {
        font-family: "Source Serif 4", serif;
        font-size: 15.5px; line-height: 1.55; color: oklch(32% 0.01 60); margin: 0 0 24px;
      }
      .t-press-stats { display: flex; gap: 32px; margin-bottom: 24px; }
      .t-press-stat .v {
        font-family: "Source Serif 4", serif;
        font-size: 30px; font-weight: 400; color: oklch(18% 0.012 60); line-height: 1;
      }
      .t-press-stat .l {
        font-family: "Inter", system-ui, sans-serif;
        font-size: 10px; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase;
        color: oklch(48% 0.008 60); margin-top: 6px;
      }
      .t-press-cta {
        display: inline-flex; align-items: center; gap: 8px;
        font-family: "Inter", system-ui, sans-serif;
        font-size: 12px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase;
        color: oklch(38% 0.10 60); text-decoration: none; border-bottom: 1px solid currentColor; padding-bottom: 2px;
      }

      /* ════════════════════════════════════════════════════════════
         THEME B — FOLIO (Penguin Classics / Knopf editorial)
         ════════════════════════════════════════════════════════════ */
      .t-folio { background: oklch(95.5% 0.025 75); color: oklch(22% 0.04 50); padding: 70px 40px 90px; position: relative; }
      .t-folio::before {
        content: ''; position: absolute; inset: 14px;
        border: 1px solid oklch(50% 0.11 60); border-radius: 2px; opacity: 0.4; pointer-events: none;
      }
      .t-folio-hero { max-width: 1100px; margin: 0 auto; text-align: center; padding: 30px 0 60px; position: relative; z-index: 1; }
      .t-folio-monogram {
        display: inline-flex; align-items: center; justify-content: center;
        width: 88px; height: 88px; border-radius: 50%;
        border: 2px solid oklch(45% 0.13 60);
        margin: 0 auto 32px;
        background: oklch(98% 0.02 75);
      }
      .t-folio-monogram svg { width: 56px; height: 56px; }
      .t-folio-flourish { font-family: "EB Garamond", serif; font-size: 24px; color: oklch(45% 0.13 60); margin: 0 0 10px; letter-spacing: 0.3em; }
      .t-folio-hero h1 {
        font-family: "EB Garamond", Georgia, serif;
        font-size: clamp(48px, 6vw, 76px); font-weight: 500; font-style: italic;
        line-height: 1.05; color: oklch(20% 0.04 50);
        margin: 0 0 16px;
      }
      .t-folio-hero .est {
        font-family: "EB Garamond", serif; font-size: 13px; font-style: italic;
        color: oklch(45% 0.04 50); margin-bottom: 28px; letter-spacing: 0.1em;
      }
      .t-folio-hero .rule {
        width: 80px; height: 1px; background: oklch(45% 0.13 60); margin: 32px auto;
        position: relative;
      }
      .t-folio-hero .rule::before, .t-folio-hero .rule::after {
        content: '◆'; position: absolute; top: -7px; color: oklch(45% 0.13 60); font-size: 10px;
      }
      .t-folio-hero .rule::before { left: -16px; } .t-folio-hero .rule::after { right: -16px; }
      .t-folio-hero p {
        font-family: "EB Garamond", serif; font-size: 18px; line-height: 1.7;
        max-width: 620px; margin: 0 auto; color: oklch(32% 0.04 50); font-style: italic;
      }
      .t-folio-grid {
        max-width: 1100px; margin: 0 auto; position: relative; z-index: 1;
        display: grid; grid-template-columns: 1fr 1fr; gap: 28px;
      }
      .t-folio-card {
        background: oklch(98% 0.02 75); padding: 36px 32px;
        border: 1px solid oklch(60% 0.08 60); border-radius: 2px;
        position: relative; transition: transform 200ms, box-shadow 200ms;
      }
      .t-folio-card::before {
        content: ''; position: absolute; top: 8px; left: 8px; right: 8px; bottom: 8px;
        border: 1px solid oklch(78% 0.07 60); border-radius: 1px; pointer-events: none;
      }
      .t-folio-card:hover { transform: translateY(-3px); box-shadow: 0 18px 32px -16px oklch(20% 0.04 50 / 0.25); }
      .t-folio-card-inner { position: relative; padding: 20px; }
      .t-folio-card .vol {
        font-family: "EB Garamond", serif; font-size: 11px; font-style: italic;
        color: oklch(45% 0.13 60); letter-spacing: 0.16em; text-transform: uppercase;
        text-align: center; margin-bottom: 14px;
      }
      .t-folio-card h2 {
        font-family: "EB Garamond", serif; font-size: 30px; font-weight: 500; font-style: italic;
        text-align: center; color: oklch(20% 0.04 50); margin: 0 0 6px; line-height: 1.1;
      }
      .t-folio-card .sub {
        font-family: "EB Garamond", serif; font-size: 13px; font-style: italic;
        text-align: center; color: oklch(45% 0.04 50); margin-bottom: 24px;
        letter-spacing: 0.04em;
      }
      .t-folio-card .body {
        font-family: "EB Garamond", serif; font-size: 15px; line-height: 1.7;
        color: oklch(28% 0.04 50); text-align: center; margin: 0 0 22px;
      }
      .t-folio-card .stats { display: flex; justify-content: center; gap: 24px; padding-top: 18px;
        border-top: 1px dashed oklch(50% 0.13 60); }
      .t-folio-card .stat { text-align: center; }
      .t-folio-card .stat .v {
        font-family: "EB Garamond", serif; font-size: 26px; color: oklch(45% 0.13 60); font-style: italic;
      }
      .t-folio-card .stat .l {
        font-family: "EB Garamond", serif; font-size: 10px; text-transform: uppercase;
        letter-spacing: 0.15em; color: oklch(45% 0.04 50); margin-top: 2px;
      }

      /* ════════════════════════════════════════════════════════════
         THEME C — ATLAS (Vercel / Linear modern dark)
         ════════════════════════════════════════════════════════════ */
      .t-atlas { background: oklch(13% 0.02 250); color: oklch(94% 0.008 75); padding: 60px 40px 80px; position: relative; overflow: hidden; }
      .t-atlas::before {
        content: ''; position: absolute; top: -200px; left: 50%; transform: translateX(-50%);
        width: 800px; height: 600px;
        background: radial-gradient(ellipse, oklch(70% 0.14 80 / 0.18) 0%, transparent 60%);
        pointer-events: none;
      }
      .t-atlas::after {
        content: ''; position: absolute; inset: 0;
        background-image:
          linear-gradient(oklch(94% 0.008 75 / 0.03) 1px, transparent 1px),
          linear-gradient(90deg, oklch(94% 0.008 75 / 0.03) 1px, transparent 1px);
        background-size: 64px 64px;
        pointer-events: none; mask-image: radial-gradient(ellipse at top, black, transparent 70%);
      }
      .t-atlas-hero { max-width: 1200px; margin: 0 auto; position: relative; z-index: 1; }
      .t-atlas-brand { display: flex; align-items: center; gap: 12px; margin-bottom: 64px; }
      .t-atlas-brand svg { width: 32px; height: 32px; }
      .t-atlas-brand .mark {
        font-family: "Inter", system-ui, sans-serif;
        font-size: 14px; font-weight: 700; letter-spacing: -0.01em;
        color: oklch(94% 0.008 75);
      }
      .t-atlas-brand .mark span { color: oklch(70% 0.14 80); }
      .t-atlas-tag {
        display: inline-block; padding: 4px 12px;
        background: oklch(94% 0.008 75 / 0.05);
        border: 1px solid oklch(94% 0.008 75 / 0.12);
        border-radius: 9999px;
        font-family: "Inter", sans-serif; font-size: 11px; font-weight: 500;
        color: oklch(85% 0.008 75); margin-bottom: 32px;
      }
      .t-atlas-tag .dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: oklch(70% 0.14 80); margin-right: 8px; vertical-align: middle; box-shadow: 0 0 8px oklch(70% 0.14 80); }
      .t-atlas-hero h1 {
        font-family: "Source Serif 4", Charter, Georgia, serif;
        font-size: clamp(56px, 8vw, 88px); font-weight: 400; line-height: 0.98; letter-spacing: -0.025em;
        color: oklch(98% 0.005 75); margin: 0 0 28px;
      }
      .t-atlas-hero h1 em {
        font-style: italic;
        background: linear-gradient(135deg, oklch(80% 0.14 80), oklch(60% 0.14 70));
        -webkit-background-clip: text; background-clip: text; color: transparent;
      }
      .t-atlas-hero p {
        font-family: "Inter", system-ui, sans-serif;
        font-size: 17px; line-height: 1.6; max-width: 680px;
        color: oklch(72% 0.008 75); margin: 0 0 56px;
      }
      .t-atlas-grid {
        max-width: 1200px; margin: 0 auto; position: relative; z-index: 1;
        display: grid; grid-template-columns: 1fr 1fr; gap: 20px;
      }
      .t-atlas-card {
        position: relative;
        padding: 32px;
        background: linear-gradient(180deg, oklch(20% 0.025 250 / 0.6), oklch(16% 0.025 250 / 0.4));
        border: 1px solid oklch(94% 0.008 75 / 0.08);
        border-radius: 16px;
        backdrop-filter: blur(12px);
        transition: all 200ms;
      }
      .t-atlas-card:hover {
        transform: translateY(-2px);
        border-color: oklch(70% 0.14 80 / 0.4);
        box-shadow: 0 20px 60px -20px oklch(70% 0.14 80 / 0.25);
      }
      .t-atlas-card .icon {
        display: inline-flex; align-items: center; justify-content: center;
        width: 40px; height: 40px; border-radius: 10px;
        background: oklch(70% 0.14 80 / 0.15);
        color: oklch(80% 0.14 80);
        margin-bottom: 20px;
      }
      .t-atlas-card h2 {
        font-family: "Source Serif 4", serif; font-size: 28px; font-weight: 500;
        color: oklch(96% 0.005 75); margin: 0 0 6px;
      }
      .t-atlas-card .sub {
        font-family: "Inter", sans-serif; font-size: 12px; font-weight: 500;
        color: oklch(60% 0.008 75); margin-bottom: 20px;
        letter-spacing: 0.04em;
      }
      .t-atlas-card p {
        font-family: "Inter", sans-serif; font-size: 14px; line-height: 1.6;
        color: oklch(72% 0.008 75); margin: 0 0 24px;
      }
      .t-atlas-card .stats { display: flex; gap: 28px; padding-top: 20px; border-top: 1px solid oklch(94% 0.008 75 / 0.08); }
      .t-atlas-card .stat .v {
        font-family: "Inter", sans-serif; font-size: 22px; font-weight: 700;
        color: oklch(96% 0.005 75); letter-spacing: -0.02em;
      }
      .t-atlas-card .stat .l {
        font-family: "Inter", sans-serif; font-size: 10px; font-weight: 500;
        text-transform: uppercase; letter-spacing: 0.1em; color: oklch(60% 0.008 75); margin-top: 4px;
      }
      .t-atlas-card .cta {
        display: inline-flex; align-items: center; gap: 6px; margin-top: 22px;
        font-family: "Inter", sans-serif; font-size: 12px; font-weight: 600;
        color: oklch(80% 0.14 80); text-decoration: none;
      }

      /* ════════════════════════════════════════════════════════════
         THEME D — MAGAZINE (NYT Magazine / LRB)
         ════════════════════════════════════════════════════════════ */
      .t-mag { background: oklch(99% 0.003 75); color: oklch(15% 0.005 60); padding: 0; }
      .t-mag-masthead { border-top: 6px solid oklch(15% 0.005 60); border-bottom: 1px solid oklch(15% 0.005 60); padding: 14px 40px;
        display: flex; align-items: center; justify-content: space-between; }
      .t-mag-masthead .wordmark {
        font-family: "EB Garamond", Times, serif;
        font-size: 28px; font-weight: 700; font-style: italic; letter-spacing: -0.01em;
        color: oklch(15% 0.005 60);
      }
      .t-mag-masthead .issue {
        font-family: "Inter", sans-serif; font-size: 11px; font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.18em; color: oklch(40% 0.005 60);
      }
      .t-mag-hero {
        padding: 80px 40px 60px; max-width: 1300px; margin: 0 auto;
        display: grid; grid-template-columns: 7fr 5fr; gap: 80px; align-items: end;
        border-bottom: 1px solid oklch(15% 0.005 60);
      }
      .t-mag-hero .kicker {
        font-family: "Inter", sans-serif; font-size: 11px; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.2em; color: oklch(45% 0.15 25);
        margin-bottom: 24px;
      }
      .t-mag-hero h1 {
        font-family: "EB Garamond", Times, serif;
        font-size: clamp(56px, 9vw, 108px); font-weight: 400; line-height: 0.92; letter-spacing: -0.02em;
        color: oklch(15% 0.005 60); margin: 0 0 28px;
      }
      .t-mag-hero h1 em { font-style: italic; }
      .t-mag-hero .deck {
        font-family: "EB Garamond", serif; font-size: 19px; line-height: 1.5;
        color: oklch(28% 0.005 60); border-left: 3px solid oklch(15% 0.005 60); padding-left: 20px;
        column-count: 1;
      }
      .t-mag-grid {
        max-width: 1300px; margin: 0 auto; padding: 60px 40px 80px;
        display: grid; grid-template-columns: 1fr 1fr; gap: 0;
      }
      .t-mag-card { padding: 0 40px; border-right: 1px solid oklch(70% 0.005 60); }
      .t-mag-card:last-child { border-right: 0; padding-right: 0; }
      .t-mag-card:first-child { padding-left: 0; }
      .t-mag-card .section {
        display: inline-block; padding: 3px 10px; margin-bottom: 16px;
        background: oklch(15% 0.005 60); color: white;
        font-family: "Inter", sans-serif; font-size: 10px; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.15em;
      }
      .t-mag-card h2 {
        font-family: "EB Garamond", Times, serif;
        font-size: 44px; font-weight: 400; line-height: 1.02; letter-spacing: -0.015em;
        color: oklch(15% 0.005 60); margin: 0 0 8px;
      }
      .t-mag-card .byline {
        font-family: "EB Garamond", serif; font-size: 13px; font-style: italic;
        color: oklch(40% 0.005 60); margin-bottom: 20px;
      }
      .t-mag-card p {
        font-family: "EB Garamond", serif; font-size: 16.5px; line-height: 1.55;
        color: oklch(22% 0.005 60); margin: 0 0 24px;
      }
      .t-mag-card p::first-letter {
        font-size: 3em; float: left; line-height: 0.9; padding: 0.05em 0.08em 0 0;
        color: oklch(15% 0.005 60); font-weight: 700;
      }
      .t-mag-card .pull {
        display: flex; gap: 36px; padding-top: 20px;
        border-top: 1px solid oklch(15% 0.005 60);
      }
      .t-mag-card .pull .n {
        font-family: "EB Garamond", serif; font-size: 32px; font-weight: 400;
        color: oklch(15% 0.005 60); line-height: 1;
      }
      .t-mag-card .pull .l {
        font-family: "Inter", sans-serif; font-size: 10px; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.18em; color: oklch(40% 0.005 60); margin-top: 6px;
      }
      .t-mag-card .read {
        display: inline-block; margin-top: 22px;
        font-family: "Inter", sans-serif; font-size: 11px; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.2em; color: oklch(45% 0.15 25);
        border-bottom: 2px solid oklch(45% 0.15 25); padding-bottom: 4px;
      }
    </style>
  </head>
  <body style="background: var(--color-surface-page); color: var(--color-ink); margin: 0;">

    <!-- Sticky picker bar -->
    <nav class="picker-bar">
      <div class="picker-nav">
        <span style="font-family: var(--font-ui); font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.16em; color: var(--color-ink-tertiary); margin-right: 8px;">Theme picker</span>
        {themes.map((t) => (
          <a href={`#${t.id}`} class="picker-chip">{t.name}</a>
        ))}
        <span style="margin-left: auto; font-family: var(--font-ui); font-size: 11px; color: var(--color-ink-tertiary);">scroll to compare · click "Pick this" on the winner</span>
      </div>
    </nav>

    <!-- ════════════ THEME A — PRESS ════════════ -->
    <section id="press" class="theme-section">
      <div class="theme-marker">
