---
/**
 * Inline pre-hydration script — applies the saved reader settings before
 * any content renders so there's no FOUC on theme/font/size changes.
 *
 * Reads a single localStorage blob `podcast-reader:settings` (schema v1)
 * and applies CSS variables + data-attributes on <html>/<body>. Migrates
 * the older `podcast-reader-theme` and `podcast-reader:arabic-overlay`
 * keys on first load.
 *
 * Keep this file tiny — it ships inline in every page <head>.
 */
---
<script is:inline>
  (function () {
    var KEY = 'podcast-reader:settings';
    var defaults = {
      schemaVersion: 1,
      font: 'source-serif',
      size: 19,
      lineHeight: 1.7,
      width: 'wide',
      theme: 'light',
      arabicOverlay: false,
      dropCap: true,
      focusMode: false,
      editHighlight: 'emerald',
    };
    var s = defaults;
    try {
      var raw = window.localStorage.getItem(KEY);
      if (raw) {
        var parsed = JSON.parse(raw);
        if (parsed && parsed.schemaVersion === 1) s = Object.assign({}, defaults, parsed);
      } else {
        // Legacy migration — read old keys once.
        var legacyTheme = window.localStorage.getItem('podcast-reader-theme');
        var legacyArabic = window.localStorage.getItem('podcast-reader:arabic-overlay');
        if (legacyTheme === 'dark' || legacyTheme === 'light' || legacyTheme === 'sepia' || legacyTheme === 'hc') s.theme = legacyTheme;
        if (legacyArabic === 'on') s.arabicOverlay = true;
        try {
          window.localStorage.setItem(KEY, JSON.stringify(s));
          window.localStorage.removeItem('podcast-reader-theme');
          window.localStorage.removeItem('podcast-reader:arabic-overlay');
        } catch (_) {}
      }
    } catch (_) {}
    var h = document.documentElement;
    h.setAttribute('data-theme', s.theme);
    h.setAttribute('data-reader-font', s.font);
    h.setAttribute('data-reader-width', s.width);
    h.setAttribute('data-dropcap', s.dropCap ? 'on' : 'off');
    h.setAttribute('data-focus-mode', s.focusMode ? 'on' : 'off');
    h.setAttribute('data-edit-highlight', s.editHighlight || 'emerald');
    h.style.setProperty('--reading-size', s.size + 'px');
    h.style.setProperty('--reading-line-height', String(s.lineHeight));
    // Body attribute used by Arabic overlay CSS.
    document.addEventListener('DOMContentLoaded', function () {
      document.body.setAttribute('data-arabic', s.arabicOverlay ? 'on' : 'off');
    });
  })();
</script>
