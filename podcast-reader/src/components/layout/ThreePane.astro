---
import '~/styles/global.css';
import Legend from '~/components/reader/Legend';
import ArabicToggle from '~/components/reader/ArabicToggle';
import Icon from '~/components/ui/Icon.astro';
import ThemeScript from '~/components/layout/ThemeScript.astro';
import ThemeToggle from '~/components/layout/ThemeToggle.astro';

interface Props {
  title: string;
  worktree: string;
  book: string;
  breadcrumb?: Array<{ label: string; href?: string }>;
  showRail?: boolean;
}

const { title, worktree, book, breadcrumb = [], showRail = true } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ThemeScript />
  </head>
  <body class="min-h-screen bg-stone-50 text-stone-900 antialiased">
    <!-- Legend button is fixed top-right of viewport so it can't be missed -->
    <Legend client:load />

    <div class="flex min-h-screen">
      <!-- Left TOC sidebar (sticky so it stays in view while scrolling content) -->
      <aside class="sticky top-0 hidden h-screen w-80 shrink-0 self-start overflow-hidden border-r border-stone-300 bg-stone-50 lg:flex lg:flex-col">
        <div class="border-b border-stone-300 bg-white px-4 py-3">
          <a href="/" class="font-ui inline-flex items-center gap-1.5 text-[11px] font-semibold uppercase tracking-[0.1em] text-stone-500 hover:text-stone-900">
            <Icon name="arrow-left" size={12} />
            Podcast Reader
          </a>
          <div class="mt-2 flex items-center gap-2">
            <Icon name="book-marked" size={18} class="shrink-0 text-amber-700" />
            <span class="text-base font-semibold text-stone-900" style="font-family: 'EB Garamond', Georgia, serif;">{book}</span>
          </div>
          <div class="mt-0.5 flex items-center justify-between gap-2">
            <div class="flex items-center gap-1.5 font-ui text-[11px] text-stone-500">
              <Icon name="folder" size={11} />
              <span>worktree · {worktree}</span>
            </div>
            <ThemeToggle />
          </div>
        </div>
        <nav class="flex-1 overflow-y-auto p-3">
          <slot name="toc">
            <div class="text-xs uppercase tracking-wider text-stone-400">Navigation</div>
            <p class="mt-2 text-sm text-stone-500">TOC loads in Phase 1.</p>
          </slot>
        </nav>
      </aside>

      <!-- Center reading column -->
      <div class="relative flex flex-1 flex-col">
        <header class="sticky top-0 z-10 border-b border-stone-200 bg-white/85 backdrop-blur">
          <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-3 text-sm text-stone-600">
            <nav class="flex items-center gap-2">
              {breadcrumb.map((b, i) => (
                <>
                  {i > 0 && <span class="text-stone-300"><Icon name="chevron-right" size={12} /></span>}
                  {b.href ? (
                    <a href={b.href} class="hover:text-stone-900">{b.label}</a>
                  ) : (
                    <span class="font-medium text-stone-900">{b.label}</span>
                  )}
                </>
              ))}
            </nav>
            <ArabicToggle client:load />
          </div>
        </header>
        <main class="mx-auto w-full max-w-5xl flex-1 px-6 py-8 lg:px-10">
          <slot />
        </main>
      </div>

      <!-- Right rail (density / comments — placeholder in Phase 1) -->
      {showRail && (
        <aside class="sticky top-0 hidden h-screen w-12 shrink-0 self-start border-l border-stone-200 bg-white xl:block">
          <div class="p-2 text-center text-[10px] uppercase tracking-wider text-stone-400">
            <slot name="rail">
              <div class="rotate-90 origin-left translate-y-12 whitespace-nowrap">density rail · Phase 2</div>
            </slot>
          </div>
        </aside>
      )}
    </div>
  </body>
</html>
