---
import '~/styles/global.css';
import ArabicToggle from '~/components/reader/ArabicToggle';
import ReaderSettings from '~/components/reader/ReaderSettings';
import Icon from '~/components/ui/Icon.astro';
import ThemeScript from '~/components/layout/ThemeScript.astro';

interface Props {
  title: string;
  worktree: string;
  book: string;
  breadcrumb?: Array<{ label: string; href?: string }>;
  showRail?: boolean;
}

const { title, worktree, book, breadcrumb = [], showRail = true } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ThemeScript />
  </head>
  <body class="min-h-screen antialiased" style="background: var(--color-surface-page); color: var(--color-ink);">

    <div class="flex min-h-screen">
      <!-- Left TOC sidebar (sticky so it stays in view while scrolling content) -->
      <aside class="sticky top-0 hidden h-screen w-80 shrink-0 self-start overflow-hidden border-r lg:flex lg:flex-col" style="background: var(--color-surface-sunken); border-color: var(--color-rule-default);">
        <div class="border-b px-4 py-3" style="background: var(--color-surface-raised); border-color: var(--color-rule-default);">
          <a href="/podcast-drafts/" class="font-ui inline-flex items-center gap-1.5 text-[11px] font-semibold uppercase tracking-[0.1em] text-stone-500 hover:text-stone-900">
            <Icon name="arrow-left" size={12} />
            Back to bookshelf
          </a>
          <div class="mt-2 flex items-center gap-2">
            <Icon name="book-marked" size={18} class="shrink-0 text-amber-700" />
            <span class="text-base font-semibold text-stone-900" style="font-family: 'EB Garamond', Georgia, serif;">{book}</span>
          </div>
          <div class="mt-0.5 flex items-center justify-between gap-2">
            <div class="flex items-center gap-1.5 font-ui text-[11px] text-stone-500">
              <Icon name="folder" size={11} />
              <span>worktree · {worktree}</span>
            </div>
          </div>
        </div>
        <nav class="flex-1 overflow-y-auto p-3">
          <slot name="toc">
            <div class="text-xs uppercase tracking-wider text-stone-400">Navigation</div>
            <p class="mt-2 text-sm text-stone-500">TOC loads in Phase 1.</p>
          </slot>
        </nav>
      </aside>

      <!-- Center reading column -->
      <div class="relative flex flex-1 flex-col">
        <header class="sticky top-0 z-10 border-b backdrop-blur" style="background: color-mix(in oklab, var(--color-surface-raised) 85%, transparent); border-color: var(--color-rule-subtle);">
          <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-3 text-sm text-stone-600">
            <nav class="flex items-center gap-2">
              {breadcrumb.map((b, i) => (
                <>
                  {i > 0 && <span class="text-stone-300"><Icon name="chevron-right" size={12} /></span>}
                  {b.href ? (
                    <a href={b.href} class="hover:text-stone-900">{b.label}</a>
                  ) : (
                    <span class="font-medium text-stone-900">{b.label}</span>
                  )}
                </>
              ))}
            </nav>
            <div class="flex items-center gap-2">
              <ArabicToggle client:load />
              <ReaderSettings client:load />
            </div>
          </div>
        </header>
        <main class="mx-auto w-full max-w-5xl flex-1 px-6 py-8 lg:px-10">
          <slot />
        </main>
      </div>

      <!-- Right rail (chapter mini-TOC + instruction panel + Ask sidebar) -->
      {showRail && (
        <aside class="sticky top-0 hidden h-screen w-80 shrink-0 self-start overflow-y-auto border-l px-4 py-5 xl:block" style="background: var(--color-surface-raised); border-color: var(--color-rule-default);">
          <slot name="rail" />
        </aside>
      )}
    </div>
  </body>
</html>
