---
import '~/styles/global.css';
import ArabicToggle from '~/components/reader/ArabicToggle';
import ReaderSettings from '~/components/reader/ReaderSettings';
import Icon from '~/components/ui/Icon.astro';
import ThemeScript from '~/components/layout/ThemeScript.astro';

interface Props {
  title: string;
  worktree: string;
  book: string;
  breadcrumb?: Array<{ label: string; href?: string }>;
  showRail?: boolean;
}

const { title, worktree, book, breadcrumb = [], showRail = true } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ThemeScript />
    <script is:inline>
      // Restore sidebar collapsed state before paint to avoid flicker.
      try {
        if (localStorage.getItem('podcast-reader:sidebar-collapsed') === '1') {
          document.documentElement.setAttribute('data-sidebar', 'collapsed');
        }
      } catch (_) {}
    </script>
  </head>
  <body class="min-h-screen antialiased" style="background: var(--color-surface-page); color: var(--color-ink);">

    <div class="three-pane">
      <!-- Left sidebar (collapsible) -->
      <aside class="left-rail">
        <div class="left-rail-head">
          <div class="left-rail-head-row">
            <a href="/podcast-drafts/" class="left-rail-back">
              <Icon name="arrow-left" size={12} />
              <span class="left-rail-back-label">Back to bookshelf</span>
            </a>
            <button id="sidebar-toggle" class="left-rail-collapse" type="button" aria-label="Collapse sidebar" title="Collapse sidebar (s)">
              <span class="left-rail-collapse-icon">‹</span>
            </button>
          </div>
          <div class="left-rail-book">
            <Icon name="book-marked" size={18} class="left-rail-book-icon" />
            <span class="left-rail-book-title">{book}</span>
          </div>
          <div class="left-rail-meta">
            <Icon name="folder" size={11} />
            <span>worktree · {worktree}</span>
          </div>
        </div>
        <nav class="left-rail-nav">
          <slot name="toc">
            <div class="left-rail-nav-fallback">Navigation</div>
            <p class="left-rail-nav-empty">TOC loads in Phase 1.</p>
          </slot>
        </nav>
      </aside>

      <!-- Center reading column -->
      <div class="center-col">
        <header class="center-header">
          <div class="center-header-inner">
            <nav class="center-breadcrumb">
              {breadcrumb.map((b, i) => (
                <>
                  {i > 0 && <span class="center-breadcrumb-sep"><Icon name="chevron-right" size={12} /></span>}
                  {b.href ? (
                    <a href={b.href}>{b.label}</a>
                  ) : (
                    <span class="here">{b.label}</span>
                  )}
                </>
              ))}
            </nav>
            <div class="center-header-actions">
              <ArabicToggle client:load />
              <ReaderSettings client:load />
            </div>
          </div>
        </header>
        <main class="center-main">
          <slot />
        </main>
      </div>

      <!-- Right rail -->
      {showRail && (
        <aside class="right-rail">
          <slot name="rail" />
        </aside>
      )}
    </div>

    <script is:inline>
      (function () {
        var btn = document.getElementById('sidebar-toggle');
        if (!btn) return;
        function setState(collapsed) {
          if (collapsed) document.documentElement.setAttribute('data-sidebar', 'collapsed');
          else document.documentElement.removeAttribute('data-sidebar');
          try { localStorage.setItem('podcast-reader:sidebar-collapsed', collapsed ? '1' : '0'); } catch (_) {}
        }
        btn.addEventListener('click', function () {
          var collapsed = document.documentElement.getAttribute('data-sidebar') === 'collapsed';
          setState(!collapsed);
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 's' && !e.metaKey && !e.ctrlKey && !e.altKey) {
            var t = (e.target && e.target.tagName) ? e.target.tagName.toLowerCase() : '';
            if (t === 'input' || t === 'textarea' || (e.target && e.target.isContentEditable)) return;
            var collapsed = document.documentElement.getAttribute('data-sidebar') === 'collapsed';
            setState(!collapsed);
          }
        });
      })();
    </script>
  </body>
</html>
