---
/**
 * Dark/light theme toggle button — vanilla JS, no React island needed.
 *
 * Reads/writes localStorage('podcast-reader-theme'), syncs the
 * <html data-theme> attribute, and swaps which Sun/Moon icon is
 * visible via CSS keyed on the data-theme attribute.
 */
---
<button
  type="button"
  id="theme-toggle"
  title="Toggle dark/light theme"
  aria-label="Toggle theme"
  class="theme-toggle font-ui inline-flex items-center gap-1.5 rounded-md border border-stone-300 bg-white px-2 py-1 text-[11px] font-medium text-stone-600 transition hover:border-stone-500 hover:text-stone-900"
>
  <span class="theme-toggle-icon-light flex items-center gap-1.5">
    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="4"/>
      <path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/>
      <path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/>
    </svg>
    <span>Light</span>
  </span>
  <span class="theme-toggle-icon-dark hidden items-center gap-1.5">
    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
    </svg>
    <span>Dark</span>
  </span>
</button>

<style is:global>
  [data-theme="light"] .theme-toggle-icon-light { display: inline-flex; }
  [data-theme="light"] .theme-toggle-icon-dark { display: none !important; }
  [data-theme="dark"] .theme-toggle-icon-light { display: none !important; }
  [data-theme="dark"] .theme-toggle-icon-dark { display: inline-flex !important; }
  /* Dark-mode chrome */
  [data-theme="dark"] .theme-toggle {
    border-color: var(--color-rule-default);
    background: var(--color-surface-raised);
    color: var(--color-ink-secondary);
  }
  [data-theme="dark"] .theme-toggle:hover {
    border-color: var(--color-rule-strong);
    color: var(--color-ink);
  }
</style>

<script is:inline>
  (function () {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    btn.addEventListener('click', function () {
      const cur = document.documentElement.getAttribute('data-theme');
      const next = cur === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      try { window.localStorage.setItem('podcast-reader-theme', next); } catch (_) {}
    });
  })();
</script>
