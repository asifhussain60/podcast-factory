---
/**
 * Lightweight inline SVG icon component, built from Lucide icon source.
 *
 * Inline SVGs (rather than a runtime library) because most usages are in
 * Astro files where shipping React + lucide-react adds JS for static
 * visuals. React islands import from `lucide-react` directly.
 *
 * To add a new icon: copy the inner SVG markup from https://lucide.dev
 * (look at the icon's source) and add a new conditional below.
 */
interface Props {
  name:
    | 'book'
    | 'book-open'
    | 'book-marked'
    | 'headphones'
    | 'mic'
    | 'file-text'
    | 'info'
    | 'circle-help'
    | 'arrow-left'
    | 'arrow-right'
    | 'play'
    | 'sliders-horizontal'
    | 'list'
    | 'folder'
    | 'user'
    | 'quote'
    | 'sparkle'
    | 'library'
    | 'panel-left'
    | 'chevron-right';
  class?: string;
  size?: number;
  strokeWidth?: number;
}
const { name, class: className = '', size = 16, strokeWidth = 1.75 } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  {name === 'book' && (
    <>
      <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20" />
    </>
  )}
  {name === 'book-open' && (
    <>
      <path d="M12 7v14" />
      <path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z" />
    </>
  )}
  {name === 'book-marked' && (
    <>
      <path d="M10 2v8l3-3 3 3V2" />
      <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20" />
    </>
  )}
  {name === 'headphones' && (
    <>
      <path d="M3 14h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H4a1 1 0 0 1-1-1zM21 14h-3a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h2a1 1 0 0 0 1-1zM3 18v-6a9 9 0 0 1 18 0v6" />
    </>
  )}
  {name === 'mic' && (
    <>
      <path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z" />
      <path d="M19 10v2a7 7 0 0 1-14 0v-2" />
      <line x1="12" x2="12" y1="19" y2="22" />
    </>
  )}
  {name === 'file-text' && (
    <>
      <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z" />
      <path d="M14 2v4a2 2 0 0 0 2 2h4" />
      <path d="M10 9H8" />
      <path d="M16 13H8" />
      <path d="M16 17H8" />
    </>
  )}
  {name === 'info' && (
    <>
      <circle cx="12" cy="12" r="10" />
      <path d="M12 16v-4" />
      <path d="M12 8h.01" />
    </>
  )}
  {name === 'circle-help' && (
    <>
      <circle cx="12" cy="12" r="10" />
      <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" />
      <path d="M12 17h.01" />
    </>
  )}
  {name === 'arrow-left' && (
    <>
      <path d="m12 19-7-7 7-7" />
      <path d="M19 12H5" />
    </>
  )}
  {name === 'arrow-right' && (
    <>
      <path d="M5 12h14" />
      <path d="m12 5 7 7-7 7" />
    </>
  )}
  {name === 'play' && (
    <>
      <polygon points="6 3 20 12 6 21 6 3" />
    </>
  )}
  {name === 'sliders-horizontal' && (
    <>
      <line x1="21" x2="14" y1="4" y2="4" />
      <line x1="10" x2="3" y1="4" y2="4" />
      <line x1="21" x2="12" y1="12" y2="12" />
      <line x1="8" x2="3" y1="12" y2="12" />
      <line x1="21" x2="16" y1="20" y2="20" />
      <line x1="12" x2="3" y1="20" y2="20" />
      <line x1="14" x2="14" y1="2" y2="6" />
      <line x1="8" x2="8" y1="10" y2="14" />
      <line x1="16" x2="16" y1="18" y2="22" />
    </>
  )}
  {name === 'list' && (
    <>
      <line x1="8" x2="21" y1="6" y2="6" />
      <line x1="8" x2="21" y1="12" y2="12" />
      <line x1="8" x2="21" y1="18" y2="18" />
      <line x1="3" x2="3.01" y1="6" y2="6" />
      <line x1="3" x2="3.01" y1="12" y2="12" />
      <line x1="3" x2="3.01" y1="18" y2="18" />
    </>
  )}
  {name === 'folder' && (
    <>
      <path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z" />
    </>
  )}
  {name === 'user' && (
    <>
      <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2" />
      <circle cx="12" cy="7" r="4" />
    </>
  )}
  {name === 'quote' && (
    <>
      <path d="M16 3a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h3c0 2.667-1.333 4.333-4 5" />
      <path d="M5 3a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h3c0 2.667-1.333 4.333-4 5" />
    </>
  )}
  {name === 'sparkle' && (
    <>
      <path d="M12 3v18" />
      <path d="M3 12h18" />
      <path d="m5.6 5.6 12.8 12.8" />
      <path d="m18.4 5.6-12.8 12.8" />
    </>
  )}
  {name === 'library' && (
    <>
      <path d="m16 6 4 14" />
      <path d="M12 6v14" />
      <path d="M8 8v12" />
      <path d="M4 4v16" />
    </>
  )}
  {name === 'panel-left' && (
    <>
      <rect width="18" height="18" x="3" y="3" rx="2" />
      <path d="M9 3v18" />
    </>
  )}
  {name === 'chevron-right' && (
    <>
      <path d="m9 18 6-6-6-6" />
    </>
  )}
</svg>
