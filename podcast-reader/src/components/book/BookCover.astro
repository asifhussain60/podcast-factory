---
/**
 * Title-cover landing for a book — designed to feel like a real book
 * title page. All styling in styles/landing.css (`.book-cover-*`).
 *
 * Mounted at the top of the book index page above the grouped table.
 */
import type { BookMeta } from '~/data/books';
import Icon from '~/components/ui/Icon.astro';

interface Props {
  meta: BookMeta;
  episodeCount: number;
  chapterCount: number;
  firstEpisodeHref?: string;
  firstChapterHref?: string;
}

const { meta, episodeCount, chapterCount, firstEpisodeHref, firstChapterHref } = Astro.props;
---

<section class="book-cover">
  <div class="book-cover-inner">
    {meta.series && <div class="book-cover-series">{meta.series}</div>}

    <h1 class="book-cover-title">{meta.titleEn}</h1>

    {meta.titleAr && (
      <div class="book-cover-title-ar" lang="ar" dir="rtl">{meta.titleAr}</div>
    )}

    {meta.subtitle && <p class="book-cover-subtitle">{meta.subtitle}</p>}

    <div class="book-cover-divider" aria-hidden="true">
      <span class="seg"></span>
      <span class="gem">◆</span>
      <span class="seg"></span>
    </div>

    <div class="book-cover-author">{meta.author.name}</div>
    {meta.author.titles && meta.author.titles.length > 0 && (
      <div class="book-cover-author-titles">{meta.author.titles.join(' · ')}</div>
    )}
    {meta.author.era && <div class="book-cover-author-era">{meta.author.era}</div>}

    <p class="book-cover-description">{meta.description}</p>

    {(meta.editor || meta.publisher || meta.tradition) && (
      <div class="book-cover-imprint">
        {meta.editor && <div>{meta.editor}</div>}
        {meta.publisher && <div>{meta.publisher}</div>}
        {meta.tradition && <div class="tradition">{meta.tradition}</div>}
      </div>
    )}

    <div class="book-cover-actions">
      {firstEpisodeHref && (
        <a href={firstEpisodeHref} class="book-cover-cta book-cover-cta--primary">
          <Icon name="play" size={14} />
          Begin with Episode 1
        </a>
      )}
      {firstChapterHref && (
        <a href={firstChapterHref} class="book-cover-cta book-cover-cta--ghost">
          <Icon name="book-open" size={14} />
          Read source chapter 1
        </a>
      )}
      <div class="book-cover-hint">
        Or pick from {chapterCount} chapters &amp; {episodeCount} episodes in the sidebar →
      </div>
    </div>
  </div>
</section>
