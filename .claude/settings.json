{
  "permissions": {
    "allow": [
      "Bash(npm start *)",
      "Bash(curl -s http://localhost:3001/health)",
      "Bash(curl -s http://localhost:3001/api/queue/pending)",
      "Bash(lsof -nP -iTCP:3001 -sTCP:LISTEN)",
      "Bash(git fetch *)",
      "Bash(ack *)",
      "Bash(ag *)",
      "Bash(security find-generic-password *)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/ui-reviewer-stop.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/cortex-view-guard.sh",
            "statusMessage": "Cortex HTML-view guard"
          }
        ]
      }
    ]
  }
}
