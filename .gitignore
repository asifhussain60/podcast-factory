# Temporary working files
scratchpad-*.txt

# OS files
.DS_Store
**/.DS_Store
Thumbs.db

# Claude Code (per-machine local state)
.claude/

# MCP config (contains API tokens)
.mcp.json

# Editor files
*.swp
*.swo
*~
*.code-workspace

# Stray scratch dirs (large binary outputs — m4a is audio rendering)
/m4a/
/content/m4a/
/CONTENT/m4a/

# Python virtual environment
.venv/

# Python bytecode caches
__pycache__/
*.pyc
*.pyo

# Test runner caches (regenerated on each run)
.pytest_cache/
.benchmarks/

# podcast-reader app (Astro app — source lives in its own dev context; only
# build artefacts currently on disk)
podcast-reader/

# Node / server proxy
server/node_modules/
server/.logs/
server/logs/*.jsonl
server/data/*.db
server/data/*.db-wal
server/data/*.db-shm
server/data/backups/
node_modules/

# Astro generated content-collection types (regenerated by `astro dev`).
.astro/
**/.astro/

# Environment files (API keys should live in macOS Keychain, not .env)
.env
.env.local
*.env
!*.template.env
# infra/azure/azure-config.env is intentionally tracked: it holds resource
# names + the subscription ID (publicly visible in any portal URL), no
# secrets. Tracking it lets a new Mac `git clone && make bootstrap` without
# manually copying the template. (Real secrets live in macOS Keychain via
# store-keychain-keys.sh or Azure Key Vault.)
!infra/azure/azure-config.env

# _workspace/ is the tracked execution-plan + per-book authoring zone.
# .DS_Store inside it is still excluded by the OS-junk rule above.
# (Historical: a `_workspace/Books/` capital-B PDF drop-zone was once planned
# but never materialized; the gitignore line was retired 2026-05-23 because
# it silently collided with `_workspace/books/` on case-insensitive macOS,
# eating new per-book files. PDFs live at the parent `raw/` per intake_book.py.)

# Podcast raw-input binaries (audio, video, archives, editing-project files)
# — large assets that live under _workspace/<category>/<slug>/_source/. Only
# derived text artifacts (refined chapters, episode txts, kept transcripts)
# get committed. Keeps the repo small regardless of where binaries land.
# Post-Phase-9.5: workspace lives at root-level _workspace/ (not content/podcast/library/).
_workspace/**/*.mp3
_workspace/**/*.wav
_workspace/**/*.m4a
_workspace/**/*.mp4
_workspace/**/*.mov

# Post-2026-05-23 restructure: per-book audio dumps live under
# content/drafts/<slug>/mp3/ (NotebookLM downloads that we Azure-transcribe).
# Same policy as _workspace audio above — keep the repo small.
content/drafts/**/mp3/
content/drafts/**/*.mp3
content/drafts/**/*.wav
content/drafts/**/*.m4a
content/drafts/**/*.mp4
content/drafts/**/*.mov
_workspace/**/*.zip
_workspace/**/*.llc
_workspace/**/*.pdf

# Transcript working artifacts — raw Speech-to-Text + translator output used
# during chapter-source authoring. The final cleaned chapters/ + episodes/
# files are committed; transcripts/ is local-only scratch.
_workspace/lectures/*/transcripts/

# Sandbox inbox — universal drop zone for raw inputs (MP3, PDF, TurboScribe
# txt, etc.) before the podcast agent triages them into the right book dir.
# Nothing inside should ever be committed; only the README documents the
# contract. See _workspace/_sandbox/README.md.
_workspace/_sandbox/*
!_workspace/_sandbox/README.md

# Phase 9.5 — per-book workspace at _workspace/books/<slug>/
# Track orchestrator state + chapters + episode drafts; ignore raw source intake.
# On case-insensitive macOS APFS, _workspace/Books/ (capital B) and _workspace/books/
# resolve to the same directory; we list both for case-sensitive filesystems too.
_workspace/books/*/source*
_workspace/books/*/*.pdf
_workspace/books/*/raw/
_workspace/Books/*/source*
_workspace/Books/*/*.pdf
_workspace/Books/*/raw/

# inbox — large-file drop zone for raw inputs pending triage/filing.
# Nothing inside should ever be committed.
_workspace/inbox/*
!_workspace/inbox/.gitkeep

# KAHSKOLE / KSESSIONS extraction work zone (added 2026-05-24).
# Scripts + extracted output are tracked; exclude the ~750MB source SQL
# dumps (backed up in Google Drive — re-importable as needed).
_workspace/kashkole-ksessions/*.sql

# Python bytecode
**/__pycache__/
*.pyc

# Trash / soft-delete staging
**/.trash/

# Per-trip queue + ephemeral artifacts (App writes, Cowork drains and deletes per §5.10)
trips/*/pending.json
trips/*/receipts/
trips/*/photos/
trips/*/voice-inbox/
trips/*/voice-inbox.json
trips/*/itinerary-inbox.json
trips/*/snapshots/


# Wrangler local cache (regenerated per invocation)
.wrangler/
_workspace/orchestrator-logs/
_workspace/scratch/
_workspace/tmp/

# Per-session chat scratch notes — now tracked for cross-Mac handoff
# (was local-only until 2026-05-19; tracked thereafter per user directive).
# Add any sensitive/per-machine subdirectories explicitly here if needed.

# Chunked-window scratch (orchestrator runtime artifacts — regenerable from
# raw-extract.md). Broader **/_chunks/ catches any future caller that writes
# _chunks/ outside the canonical book directory.
**/_chunks/

# Local-only orchestrator/runtime logs
_workspace/logs/

# Local-only audit snapshots (pre-rerun copies of book artifacts for diff/review)
_workspace/audit/

# Sanitizer backups (created by scripts/podcast/sanitize_contract_yaml.py)
*.yml.bak

# VSCode workspace favorites (user-local IDE state)
.favorites.json
raw/
