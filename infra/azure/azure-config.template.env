# azure-config.template.env — parameter template for provision-azure.sh
#
# Copy this file to `azure-config.env` (NOT git-tracked) in this directory,
# edit the values to match the app you're provisioning, then run:
#
#   ./provision-azure.sh
#
# This template documents every variable provision-azure.sh expects.
# Everything is shell-quoted so you can `source` this file directly.

# ----------------------------------------------------------------------------
# Identity — names the user (and Azure) will see
# ----------------------------------------------------------------------------

# Short app identifier. Used as a prefix in every resource name.
# 3–10 lowercase letters/digits, no hyphens.
APP_NAME="journal"

# Friendly app-context tag (e.g. "Babu memoir podcast pipeline"). For your
# own notes only — never sent to Azure. Helps when you re-read this file
# in six months.
APP_DESCRIPTION="Memoir podcast pipeline — Arabic OCR + English translation"

# Email that receives budget alerts. The provisioning script does NOT use
# this directly (Azure CLI cannot create budgets on pay-as-you-go MSA
# subscriptions); the setup doc walks you through wiring it manually.
ALERT_EMAIL="asifhussain60@gmail.com"

# ----------------------------------------------------------------------------
# Azure placement — where the resources live
# ----------------------------------------------------------------------------

# Subscription ID. Find it with: az account show --query id -o tsv
SUBSCRIPTION_ID="3440564d-c056-4173-bec6-7af92dbece77"

# Resource group name. Convention: rg-<app>-<purpose>.
RESOURCE_GROUP="rg-journal-ai"

# Region. All resources land here. Use eastus unless you have a reason not to —
# it has the broadest service availability for AI services + document translation.
LOCATION="eastus"

# ----------------------------------------------------------------------------
# Feature flags — which resources to provision
# ----------------------------------------------------------------------------
# Set each to "true" or "false". The script skips any flagged false.

ENABLE_TRANSLATOR="true"        # Azure AI Translator (Standard S1)
ENABLE_DOCINTEL="true"          # Azure AI Document Intelligence (Free F0)
ENABLE_STORAGE="true"           # Storage account + blob containers
ENABLE_KEYVAULT="false"         # Azure Key Vault — set true to enable cross-Mac secret sync

# ----------------------------------------------------------------------------
# Translator — Azure AI Translator
# ----------------------------------------------------------------------------

TRANSLATOR_NAME="journal-translator"
TRANSLATOR_SKU="S1"             # F0 (free) does NOT support document translation.
                                # Pick S1 unless you only need short text translation.

# ----------------------------------------------------------------------------
# Document Intelligence — OCR for scanned PDFs
# ----------------------------------------------------------------------------

DOCINTEL_NAME="journal-docintel"
DOCINTEL_SKU="F0"               # F0 = 500 pages/month free; S0 = pay-per-page.

# ----------------------------------------------------------------------------
# Storage account — blob containers for source + output documents
# ----------------------------------------------------------------------------

# Globally unique across all of Azure. 3–24 lowercase alphanumeric only,
# NO HYPHENS. The script will fail fast if the name is taken.
STORAGE_ACCOUNT_NAME="journalpodcaststorage"

# Replication: LRS (cheapest, single-region), ZRS (zone-redundant), GRS
# (geo-redundant). Use LRS for OCR scratch unless you need disaster recovery.
STORAGE_SKU="Standard_LRS"

# Containers to create. Space-separated. Each must be 3–63 lowercase
# letters/numbers/hyphens. The script creates each one if it doesn't exist.
STORAGE_CONTAINERS="source-arabic source-urdu translated-english"

# ----------------------------------------------------------------------------
# Key Vault (optional — only used when ENABLE_KEYVAULT="true")
# ----------------------------------------------------------------------------

# Globally unique, 3–24 chars, alphanumeric + hyphens, must start with a letter.
KEYVAULT_NAME="kv-journal-ai"

# ----------------------------------------------------------------------------
# Budget — informational only
# ----------------------------------------------------------------------------
# Azure CLI cannot create budgets on personal pay-as-you-go subscriptions.
# Set these so the post-install summary prints the right values for you to
# paste into the portal.

BUDGET_NAME="journal-ai-monthly-cap"
BUDGET_AMOUNT_USD="50"
BUDGET_THRESHOLDS="50 80 100"   # Percent thresholds, space-separated.
