# azure-config.env — LIVE config for the journal app's Azure stack.
#
# This file matches what's actually deployed in rg-journal-ai as of 2026-05-18.
# Values here are NOT secrets — they're resource names, region, and the
# subscription ID (which is also visible in every Azure portal URL). Safe to
# commit.
#
# If you're adapting this for a different app: cp azure-config.template.env
# to a new name (e.g. triplog-config.env) and edit there. Don't overwrite
# this file unless you're actually changing what's deployed.

# ----------------------------------------------------------------------------
# Identity
# ----------------------------------------------------------------------------
APP_NAME="podcast-factory"
APP_DESCRIPTION="Podcast pipeline — Arabic OCR + English translation (label-only rename 2026-05-22 in repo split; actual Azure resources retain journal-* names — see _workspace/runbooks/repo-split.md §2 decision 3)"
ALERT_EMAIL="asifhussain60@gmail.com"

# ----------------------------------------------------------------------------
# Azure placement
# ----------------------------------------------------------------------------
SUBSCRIPTION_ID="3440564d-c056-4173-bec6-7af92dbece77"
RESOURCE_GROUP="rg-journal-ai"
LOCATION="eastus"

# ----------------------------------------------------------------------------
# Feature flags
# ----------------------------------------------------------------------------
ENABLE_TRANSLATOR="true"
ENABLE_DOCINTEL="true"
ENABLE_SPEECH="true"      # Enabled 2026-05-18 for Urdu-lecture transcription (kunooz-al-hikmah)
ENABLE_STORAGE="true"
ENABLE_KEYVAULT="false"   # Flip to "true" when migrating for multi-Mac portability

# ----------------------------------------------------------------------------
# Translator
# ----------------------------------------------------------------------------
TRANSLATOR_NAME="journal-translator"
TRANSLATOR_SKU="S1"

# ----------------------------------------------------------------------------
# Document Intelligence
# ----------------------------------------------------------------------------
DOCINTEL_NAME="journal-docintel"
DOCINTEL_SKU="S0"   # Upgraded from F0 on 2026-05-18: F0 has 4MB binary cap that blocks Kitab-al-Riyad.pdf (4.4 MB). S0 cap is 500MB.

# ----------------------------------------------------------------------------
# Speech — Fast Transcription (post-publication transcript for Loop M)
# ----------------------------------------------------------------------------
SPEECH_NAME="journal-speech"
SPEECH_SKU="S0"     # F0 = 5 audio-hours/month free; S0 = $1/audio-hour pay-as-you-go.

# ----------------------------------------------------------------------------
# Storage
# ----------------------------------------------------------------------------
STORAGE_ACCOUNT_NAME="journalpodcaststorage"
STORAGE_SKU="Standard_LRS"
STORAGE_CONTAINERS="source-arabic source-urdu translated-english"

# ----------------------------------------------------------------------------
# Key Vault (currently disabled)
# ----------------------------------------------------------------------------
KEYVAULT_NAME="kv-journal-ai"

# ----------------------------------------------------------------------------
# Budget (set up manually in portal — see docs/azure/setup.md § Step 4)
# ----------------------------------------------------------------------------
BUDGET_NAME="journal-ai-monthly-cap"
BUDGET_AMOUNT_USD="50"
BUDGET_THRESHOLDS="50 80 100"
