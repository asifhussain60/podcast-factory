# Journal proxy environment — copy to .env and fill in real values.
# .env is gitignored. .env.example (this file) is tracked.
#
# The Anthropic API key is NOT set here — it lives in macOS Keychain
# (see server/src/lib/keychain.js). Only public-by-design values go in .env.

# --- Cloudflare Access (set after creating the Access application) ---
# Team domain from your Access sign-in URL, e.g. "asifhussain.cloudflareaccess.com"
CF_ACCESS_TEAM_DOMAIN=
# Application AUD tag from the Access application's Overview tab (long hex)
CF_ACCESS_AUD=

# --- CORS allowlist (comma-separated, defaults usually sufficient) ---
# ALLOWED_ORIGINS=http://localhost:3000,https://journal.kashkole.com,https://journal-dev.kashkole.com

# --- Monthly Anthropic spend cap in dollars ---
# MONTHLY_CAP=50

# --- Model override (prompts pin their own models; this is the fallback) ---
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Proxy port ---
# PORT=3001
