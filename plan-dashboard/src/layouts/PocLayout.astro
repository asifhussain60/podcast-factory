---
// PocLayout.astro — minimal shell for the WC8 Studio PoC. Loads theme tokens + the
// PoC stylesheet only; NO site nav/footer/reader-chrome (those bleed into a feel-check).
// External CSS only (repo DoD).
import '../styles/theme.css';
import '../styles/chapter-viewer.css'; // global .ref-quran + .quran-popover-* card styles (reused)
import '../styles/studio-poc.css';
interface Props { title: string; }
const { title } = Astro.props;
---
<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <!-- FC-4: clean modern Arabic webfont (asset only — no JS dependency). -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&display=swap" rel="stylesheet" />
  </head>
  <body class="poc-body">
    <slot />
  </body>
</html>
