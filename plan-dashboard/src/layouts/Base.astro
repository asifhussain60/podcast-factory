---
import '../styles/theme.css';
import dash from '../data/dashboard-snapshot.json';
import { TOP_NAV, getNavSection, getSubnavLinks } from '../lib/site-nav';
import type { ActivePage } from '../lib/site-nav';

interface Props {
  title: string;
  active: ActivePage;
  section?: string;
  description?: string;
}

const { title, active, section: _section, description } = Astro.props;
const navSection = getNavSection(active);
const subnavLinks = getSubnavLinks(active);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Podcast Factory Astro Site</title>
    {description && <meta name="description" content={description} />}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <nav class="topnav">
      <div class="topnav-inner">
        <a href="/" class="topnav-brand">Podcast Factory <small>Astro Site</small></a>
        <div class="topnav-sections">
          {TOP_NAV.map((item) => (
            <a
              href={item.href}
              data-section={item.section}
              class={`topnav-section${navSection === item.section ? ' is-active' : ''}`}
            >
              {item.label}
            </a>
          ))}
        </div>
        <div class="topnav-spacer"></div>
      </div>
    </nav>

    {subnavLinks.length > 0 && (
      <nav class="subnav-h" aria-label={`${navSection} section`}>
        <div class="subnav-h-inner">
          {subnavLinks.map((item) => (
            <a href={item.href} class={`subnav-h-link${item.pages.includes(active) ? ' is-active' : ''}`}>{item.label}</a>
          ))}
        </div>
      </nav>
    )}

    <div class={`page-shell${subnavLinks.length > 0 ? ' has-arch-subnav' : ''}`}>

      <main class="page" id="main-content" tabindex="-1">
        <slot />
      </main>
    </div>

    <footer class="page foot">
      <span>Auto-regenerated by the podcast-planner agent — every snapshot reflects the moment you loaded this page.</span>
      <span id="snap-stamp">Snapshot loaded</span>
    </footer>

    <button id="to-top" class="to-top" type="button" aria-label="Back to top">
      <i class="fa-solid fa-arrow-up" aria-hidden="true"></i>
    </button>
    <script>import '../scripts/site-chrome.ts';</script>
  </body>
</html>
