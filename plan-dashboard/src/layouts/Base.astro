---
import '../styles/theme.css';

interface Props {
  title: string;
  active: 'home' | 'architecture' | 'infrastructure' | 'dashboard' | 'library';
  description?: string;
}
const { title, active, description } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Podcast Factory Plan</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body>
    <nav class="topnav">
      <div class="topnav-inner">
        <span class="topnav-brand">Podcast Factory <small>plan</small></span>
        <div class="topnav-links">
          <a href="/" class={`topnav-link ${active === 'home' ? 'is-active' : ''}`}>Overview</a>
          <a href="/architecture" class={`topnav-link ${active === 'architecture' ? 'is-active' : ''}`}>How it works</a>
          <a href="/infrastructure" class={`topnav-link ${active === 'infrastructure' ? 'is-active' : ''}`}>What it runs on</a>
          <a href="/dashboard" class={`topnav-link ${active === 'dashboard' ? 'is-active' : ''}`}>Live progress</a>
          <a href="/library" class={`topnav-link ${active === 'library' ? 'is-active' : ''}`}>Library</a>
        </div>
        <div class="topnav-status" id="liveness">
          <span class="dot" id="liveness-dot"></span>
          <span id="liveness-label">Live</span>
        </div>
      </div>
    </nav>

    <main class="page">
      <slot />
    </main>

    <footer class="page foot">
      <span>Auto-regenerated by the podcast-planner agent — every snapshot reflects the moment you loaded this page.</span>
      <span id="snap-stamp">Snapshot loaded…</span>
    </footer>

    <script>
      // Tiny client-side SSE subscriber. Falls back silently if the
      // /api/stream endpoint is unavailable (static-preview mode).
      (() => {
        const dot = document.getElementById('liveness-dot');
        const label = document.getElementById('liveness-label');
        const stamp = document.getElementById('snap-stamp');
        if (!dot || !label) return;
        try {
          const es = new EventSource('/api/stream');
          es.onopen = () => { dot.className = 'dot'; label.textContent = 'Live'; };
          es.onerror = () => { dot.className = 'dot is-stale'; label.textContent = 'Reconnecting'; };
          es.addEventListener('snapshot', (e) => {
            const data = JSON.parse((e as MessageEvent).data);
            if (stamp) stamp.textContent = `Snapshot ${data.generated_at}`;
            // A listening page can override window.__onSnapshot to re-render.
            const cb = (window as any).__onSnapshot;
            if (typeof cb === 'function') cb(data);
          });
        } catch {
          dot.className = 'dot is-stale';
          label.textContent = 'Offline';
        }
      })();
    </script>
  </body>
</html>
