---
import '../styles/theme.css';
import PlannerSidenav from '../components/PlannerSidenav.tsx';
import dash from '../data/dashboard-snapshot.json';

type ActivePage =
  | 'home'
  | 'architecture'
  | 'intelligence'
  | 'infrastructure'
  | 'system-map'
  | 'db-schema'
  | 'annotation-ops'
  | 'dashboard'
  | 'plan'
  | 'live'
  | 'library'
  | 'kashkole';

interface Props {
  title: string;
  active: ActivePage;
  /** 'architecture' — horizontal sub-nav strip replaces old sidebar.
   *  'planner'      — animated PlannerSidenav on the left. */
  section?: 'architecture' | 'planner';
  description?: string;
}

const { title, active, section, description } = Astro.props;

const archPages: ActivePage[] = ['architecture', 'intelligence', 'infrastructure', 'system-map', 'db-schema', 'annotation-ops'];

const navSection =
  active === 'library'                                    ? 'bookshelf'    :
  active === 'kashkole'                                   ? 'kashkole'     :
  active === 'dashboard' || active === 'plan' || active === 'live' ? 'planner' :
  archPages.includes(active)                              ? 'architecture' :
  null;

const hasPlannerSidebar = section === 'planner';
const hasArchSubnav     = section === 'architecture';

// Resolve activePage for PlannerSidenav
const plannerActivePage: 'plan' | 'live' = active === 'live' ? 'live' : 'plan';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Podcast Factory Plan</title>
    {description && <meta name="description" content={description} />}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
  </head>
  <body>
    <nav class="topnav">
      <div class="topnav-inner">
        <a href="/" class="topnav-brand">Podcast Factory <small>plan</small></a>
        <div class="topnav-sections">
          <a href="/architecture"
             data-section="architecture"
             class={`topnav-section${navSection === 'architecture' ? ' is-active' : ''}`}>
            Architecture
          </a>
          <a href="/library"
             data-section="bookshelf"
             class={`topnav-section${navSection === 'bookshelf' ? ' is-active' : ''}`}>
            Bookshelf
          </a>
          <a href="/kashkole"
             data-section="kashkole"
             class={`topnav-section${navSection === 'kashkole' ? ' is-active' : ''}`}>
            Kashkole
          </a>
          <a href="/plan"
             data-section="planner"
             class={`topnav-section${navSection === 'planner' ? ' is-active' : ''}`}>
            Planner
          </a>
        </div>
        <div class="topnav-spacer"></div>
      </div>
    </nav>

    {hasArchSubnav && (
      <nav class="subnav-h" aria-label="Architecture section">
        <div class="subnav-h-inner">
          <a href="/architecture"   class={`subnav-h-link${active === 'architecture'   ? ' is-active' : ''}`}>Pipeline</a>
          <a href="/intelligence"   class={`subnav-h-link${active === 'intelligence'   ? ' is-active' : ''}`}>Intelligence</a>
          <a href="/infrastructure" class={`subnav-h-link${active === 'infrastructure' ? ' is-active' : ''}`}>Infrastructure</a>
          <a href="/system-map"     class={`subnav-h-link${active === 'system-map'     ? ' is-active' : ''}`}>System Map</a>
          <a href="/db-schema"      class={`subnav-h-link${active === 'db-schema'      ? ' is-active' : ''}`}>Database</a>
          <a href="/annotation-ops" class={`subnav-h-link${active === 'annotation-ops' ? ' is-active' : ''}`}>Annotation Ops</a>
        </div>
      </nav>
    )}

    <div class={`page-shell${hasArchSubnav ? ' has-arch-subnav' : ''}`}>

      <main class="page">
        <slot />
      </main>
    </div>

    <footer class="page foot">
      <span>Auto-regenerated by the podcast-planner agent — every snapshot reflects the moment you loaded this page.</span>
      <span id="snap-stamp">Snapshot loaded…</span>
    </footer>

    <script>
      (() => {
        const stamp = document.getElementById('snap-stamp');
        if (stamp) stamp.textContent = `Snapshot loaded`;
      })();
    </script>
  </body>
</html>
