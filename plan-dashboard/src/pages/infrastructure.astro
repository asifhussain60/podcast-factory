---
import Base from '../layouts/Base.astro';
import InfraColumns from '../components/InfraColumns.tsx';
import StackFlow from '../components/StackFlow.tsx';
import infra from '../data/infrastructure-snapshot.json';
import { sumAllVendorCosts, sumAllVendorField } from '../lib/billing';

const monthTotal   = sumAllVendorCosts(infra.vendors);
const alltimeTotal = sumAllVendorField(infra.vendors, 'alltime_cost_usd');
const callsTotal   = sumAllVendorField(infra.vendors, 'calls_30d');
---
<Base title="What it runs on" active="infrastructure" section="architecture">

  <!-- ══════════════════════════════════════════════════════════════
       L1 — EXECUTIVE LAYER
  ═══════════════════════════════════════════════════════════════════ -->

  <header class="stack">
    <span class="eyebrow">What it runs on</span>
    <h1>The toolbox behind the factory.</h1>
    <p class="lede">
      The factory itself runs entirely on your laptop — no hosted server, no shared environment.
      Three outside services do the heavy lifting: Azure reads PDFs, Anthropic does all the reasoning,
      and NotebookLM voices the finished episodes. Below is the full set, what each one is used for,
      and what the running bill looks like.
    </p>
  </header>

  <!-- Trust boundary callout — plain-language, links to security detail -->
  <div class="card card-tight trust-callout">
    <div class="trust-callout-inner">
      <i class="fa-solid fa-shield-halved" aria-hidden="true"></i>
      <div>
        <strong>Data stays on your machine — except what you explicitly send.</strong>
        <p class="small muted">
          Book content goes to Anthropic (for reasoning) and Azure (for PDF reading), both over encrypted HTTPS.
          Google / NotebookLM is browser-only — nothing is sent automatically.
          No cloud server holds your drafts. <a href="/security">See the full security &amp; trust breakdown →</a>
        </p>
      </div>
    </div>
  </div>

  <section class="grid-3">
    <div class="card metric">
      <span class="metric-label">This month, all services</span>
      <span class="metric-value">${monthTotal.toFixed(2)}</span>
      <span class="card-sub">Combined spend across every outside service</span>
    </div>
    <div class="card metric">
      <span class="metric-label">All time</span>
      <span class="metric-value">${alltimeTotal.toFixed(2)}</span>
      <span class="card-sub">Total spent since the first book entered the factory</span>
    </div>
    <div class="card metric">
      <span class="metric-label">API calls — last 30 days</span>
      <span class="metric-value">{callsTotal.toLocaleString()}</span>
      <span class="card-sub">Every reasoning, translation, and audio call combined</span>
    </div>
  </section>

  <section class="stack">
    <h2>How everything comes together</h2>
    <p>
      A book enters as a PDF on the left. Five stages later, an episode of audio comes out on the right. Each stage
      hands off to the next — Azure reads the pages, Anthropic does every piece of reasoning, NotebookLM voices the
      finished framing, GitHub holds the catalog. The labels between the lanes name what's actually moving across the
      handoff.
    </p>
    <div class="stack-flow-frame">
      <StackFlow />
    </div>
  </section>

  <section class="stack">
    <h2>The three vendors and what each one does</h2>
    <p>
      Hover any row to see the detail. Each vendor has a handful of distinct services — they're rolled up here so
      the cost picture per vendor is one number you can read at a glance.
    </p>
    <InfraColumns vendors={infra.vendors} client:load />
  </section>

  <!-- ══════════════════════════════════════════════════════════════
       L1 → L2 BOUNDARY
  ═══════════════════════════════════════════════════════════════════ -->
  <div class="l1-l2-boundary">
    <div class="l1-l2-boundary-inner">
      <span class="l1-l2-label">Technical detail below</span>
      <p class="l1-l2-sub">
        The spend numbers and service descriptions above are the complete executive picture.
        Below: the annotation handoff infrastructure and a breakdown of how the bill flows
        through the factory's four cost layers.
      </p>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════════════════
       L2 — ARCHITECT LAYER
  ═══════════════════════════════════════════════════════════════════ -->

  <section class="stack" aria-label="L2 technical detail">
    <h2>The annotation handoff infrastructure</h2>
    <p>
      Reader annotations now flow through a two-layer handoff: a local queue for instant interaction and a durable
      chapter JSON export for assistant execution and pipeline pickup. This keeps annotation UX fast while preserving
      machine-readable context across sessions.
    </p>
    <div class="grid-2">
      <div class="card card-tight">
        <strong>Fast lane</strong>
        <p class="small">Browser-side queue accumulates marker and action intent with one-click batch copy.</p>
      </div>
      <div class="card card-tight">
        <strong>Durable lane</strong>
        <p class="small">Chapter-level JSON snapshots persist markers, notes, and combined instructions for AI tools.</p>
      </div>
    </div>
  </section>

  <hr />

  <section class="stack">
    <h2>How the bill flows through the factory</h2>
    <p>
      The shape of the bill is mostly: one big reasoning model bill (Anthropic), a small audio-generation bill
      (NotebookLM is a flat monthly subscription, not metered), and a small set of per-page-of-PDF and per-character
      bills (Azure). The most expensive thing the factory does is have Claude Opus plan the episode structure for a
      long book — that's a multi-step reasoning job that runs to thousands of tokens. Everything else rounds to
      cents.
    </p>
    <p class="muted small">
      Live spend is read from the factory's own cost ledger plus an Azure billing pull. If a number above looks stale,
      it's because the planner agent hasn't regenerated the infrastructure snapshot since the last billing cycle —
      not because the dashboard is broken.
    </p>
  </section>
</Base>
