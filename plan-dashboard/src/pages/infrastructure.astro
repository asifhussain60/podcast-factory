---
import Base from '../layouts/Base.astro';
import StackFlow from '../components/StackFlow.tsx';
import InfraColumns from '../components/InfraColumns.tsx';
import infra from '../data/infrastructure-snapshot.json';
import { sumAllVendorCosts, sumAllVendorField } from '../lib/billing';

const monthTotal   = sumAllVendorCosts(infra.vendors);
const alltimeTotal = sumAllVendorField(infra.vendors, 'alltime_cost_usd');
const callsTotal   = sumAllVendorField(infra.vendors, 'calls_30d');
---
<Base title="Infrastructure" active="infrastructure" section="architecture"
     description="Overall infrastructure view — deployment topology, actor map, and database architecture for the podcast factory.">

<header class="page-hero">
  <div class="page-hero-inner">
    <span class="eyebrow">Infrastructure</span>
    <h1 class="page-hero-title">The full stack — where everything runs.</h1>
    <p class="page-hero-lede">
      A book enters as a PDF on your machine. Five handoffs later, a finished podcast is live.
      Every stage, every service, every data store shown below — from the Python engine on your laptop
      to the three cloud vendors that power it.
    </p>
  </div>
</header>

<section class="grid-3">
  <div class="card card-tight infra-callout">
    <div class="infra-callout-icon" style="color: var(--c-green)">&#x1F4BB;</div>
    <strong>Runs on your laptop</strong>
    <p class="small muted">Every script, every database, every draft — fully local. No cloud server holds your books. The factory only reaches out when it needs AI reasoning, document reading, or to publish finished work.</p>
  </div>
  <div class="card card-tight infra-callout">
    <div class="infra-callout-icon" style="color: var(--c-amber)">&#x2601;</div>
    <strong>Content goes to AI services</strong>
    <p class="small muted">Book text and episode drafts are sent to Anthropic (for reasoning) and Azure (for reading PDFs). Both connections use encrypted HTTPS. You hold the keys — they stay in a local file that git ignores.</p>
  </div>
  <div class="card card-tight infra-callout">
    <div class="infra-callout-icon" style="color: var(--c-accent)">&#x1F44D;</div>
    <strong>You approve before anything ships</strong>
    <p class="small muted">Two human review gates block the pipeline before expensive AI phases and before anything is published. Nothing is uploaded, posted, or sent without your explicit approval at each gate.</p>
  </div>
</section>

<section class="stack">
  <h2>How a book becomes a podcast</h2>
  <p>Drop in a book. Azure reads every page and translates it. Claude reasons through all the content.
     NotebookLM voices the finished episodes. The labels between lanes name what moves across each handoff.</p>
  <div class="stack-flow-frame">
    <StackFlow />
  </div>
</section>

<section class="grid-3">
  <div class="card metric">
    <span class="metric-label">This month, all services</span>
    <span class="metric-value">${monthTotal.toFixed(2)}</span>
    <span class="card-sub">Combined spend across every outside service</span>
  </div>
  <div class="card metric">
    <span class="metric-label">All time</span>
    <span class="metric-value">${alltimeTotal.toFixed(2)}</span>
    <span class="card-sub">Total spent since the first book entered the factory</span>
  </div>
  <div class="card metric">
    <span class="metric-label">API calls — last 30 days</span>
    <span class="metric-value">{callsTotal.toLocaleString()}</span>
    <span class="card-sub">Every reasoning, translation, and audio call combined</span>
  </div>
</section>

<div class="l1-l2-boundary">
  <div class="l1-l2-boundary-inner">
    <span class="l1-l2-label">Technical detail below</span>
    <p class="l1-l2-sub">
      The pipeline flow and vendor summary above are the complete executive picture.
      Below: full deployment topology, the complete system actor map showing every service connection,
      database architecture overview, and per-service cost drill-down.
    </p>
  </div>
</div>

