---
import Base from '../layouts/Base.astro';
import AudienceBadge from '../components/AudienceBadge.astro';
import InfraDeployment from '../components/InfraDeployment.astro';
import Mermaid from '../components/Mermaid.astro';
import InfraColumns from '../components/InfraColumns.tsx';
import infra from '../data/infrastructure-snapshot.json';
import { sumAllVendorCosts, sumAllVendorField } from '../lib/billing';

const monthTotal   = sumAllVendorCosts(infra.vendors);
const alltimeTotal = sumAllVendorField(infra.vendors, 'alltime_cost_usd');
const callsTotal   = sumAllVendorField(infra.vendors, 'calls_30d');

const creds = [
  { key: 'ANTHROPIC_API_KEY',   storage: '.env file (git-ignored)', service: 'Anthropic API',              risk: 'managed',   note: 'Manual rotation, on suspicion.' },
  { key: 'AZURE_SPEECH_KEY',    storage: '.env file (git-ignored)', service: 'Azure Speech',               risk: 'managed',   note: '90-day rotation recommended.' },
  { key: 'AZURE_DOCINTEL_KEY',  storage: '.env file (git-ignored)', service: 'Azure Document Intelligence', risk: 'managed',   note: 'Same rotation as Speech.' },
  { key: 'AZURE_TRANSLATOR_KEY',storage: '.env file (git-ignored)', service: 'Azure Translator',           risk: 'managed',   note: 'Shared or dedicated resource key.' },
  { key: 'GITHUB_TOKEN',        storage: '.env file (git-ignored)', service: 'GitHub',                     risk: 'attention', note: 'PAT with repo-write scope — highest privilege here.' },
  { key: '(browser cookie)',    storage: 'Browser session (no key on disk)', service: 'Google / NotebookLM', risk: 'low',     note: 'Human-only surface; nothing stored.' },
];
const riskClass = (r: string) => r === 'low' ? 'risk-low' : r === 'attention' ? 'risk-attention' : 'risk-managed';
const riskLabel = (r: string) => r === 'low' ? 'Low' : r === 'attention' ? 'Attention' : 'Managed';

const hotspots = [
  { tag: 'SEC',  cls: 'hot-sec',  item: 'GitHub PAT has repo-write scope', detail: 'Highest-privilege secret on disk. Scope-limit or rotate to fine-grained token.' },
  { tag: 'SEC',  cls: 'hot-sec',  item: 'No public-web fallback in the corpus', detail: 'Source authority is corpus-only; nothing reaches out to the open web at query time.' },
  { tag: 'COST', cls: 'hot-cost', item: 'No hard per-book cost ceiling on Anthropic', detail: 'Watchdog caps runaway runs; a per-book hard cap would bound worst-case spend.' },
  { tag: 'ARCH', cls: 'hot-arch', item: 'SQL Server reachable on LAN only', detail: 'Source Library Server mediates; the engine never holds SQL credentials.' },
  { tag: 'ARCH', cls: 'hot-arch', item: 'mirror.db is gitignored, rebuildable', detail: 'Under 50 MB, auto-populated on first sync; safe to delete and regenerate.' },
  { tag: 'OK',   cls: 'hot-ok',   item: 'All keys git-ignored, none in history', detail: 'Verified: no plaintext secret tracked in git.' },
];
---
<Base title="Infrastructure" active="infrastructure" section="architecture"
     description="Deployment topology, the access-layer transports, the ingest path, credentials, and per-service cost for the podcast factory.">

<header class="page-hero">
  <div class="page-hero-inner">
    <span class="eyebrow">Infrastructure</span>
    <h1 class="page-hero-title">The full stack — where everything runs.</h1>
    <p class="page-hero-lede">
      A book enters as a PDF on your machine. Everything heavy runs locally; the factory only reaches
      out to a handful of cloud services for AI reasoning, document reading, and publishing — and only
      ever over an encrypted, key-authorised connection.
    </p>
  </div>
</header>

<section class="grid-3" aria-label="What runs where, in plain terms">
  <div class="card card-tight infra-callout">
    <div class="infra-callout-icon is-local"><i class="fa-solid fa-laptop-code" aria-hidden="true"></i></div>
    <strong>Runs on your laptop</strong>
    <p class="small muted">Every script, database, and draft is fully local. No cloud server holds your books. The factory only reaches out when it needs AI reasoning, document reading, or to publish.</p>
  </div>
  <div class="card card-tight infra-callout">
    <div class="infra-callout-icon is-cloud"><i class="fa-solid fa-cloud" aria-hidden="true"></i></div>
    <strong>Content goes to AI services</strong>
    <p class="small muted">Book text and drafts are sent to Anthropic (reasoning) and Azure (reading PDFs) over encrypted HTTPS. You hold the keys — they live in a local file that git ignores.</p>
  </div>
  <div class="card card-tight infra-callout">
    <div class="infra-callout-icon is-gate"><i class="fa-solid fa-thumbs-up" aria-hidden="true"></i></div>
    <strong>You approve before anything ships</strong>
    <p class="small muted">Two human review gates block the pipeline before expensive AI phases and before publishing. Nothing is uploaded or posted without your explicit approval.</p>
  </div>
</section>

<section class="grid-3" aria-label="Cost summary">
  <div class="card metric">
    <span class="metric-label">This month, all services</span>
    <span class="metric-value">${monthTotal.toFixed(2)}</span>
    <span class="card-sub">Combined spend across every outside service</span>
  </div>
  <div class="card metric">
    <span class="metric-label">All time</span>
    <span class="metric-value">${alltimeTotal.toFixed(2)}</span>
    <span class="card-sub">Total spent since the first book entered the factory</span>
  </div>
  <div class="card metric">
    <span class="metric-label">API calls — last 30 days</span>
    <span class="metric-value">{callsTotal.toLocaleString()}</span>
    <span class="card-sub">Every reasoning, translation, and audio call combined</span>
  </div>
</section>

<div class="l1-l2-boundary">
  <div class="l1-l2-boundary-inner">
    <span class="l1-l2-label">Technical detail below</span>
    <AudienceBadge tier="teams" />
    <p class="l1-l2-sub">
      Below: the deployment topology and trust boundaries, how the access layer is reached, the
      knowledge-sync path, the credential map, an at-a-glance hotspots index, the database groups,
      and the per-service cost drill-down.
    </p>
  </div>
</div>

<!-- 5.1 Deployment topology -->
<section class="stack" id="s-topology" aria-label="Deployment topology">
  <h2>Deployment topology — what runs locally, what leaves the machine</h2>
  <p>Two trust zones, stacked. Everything in the top zone runs on your machine; the boundary below is crossed only over an encrypted or local-network connection, each labelled with its protocol and how it is authorised.</p>
  <InfraDeployment />
</section>

<!-- 5.2 Blackbox dual transport -->
<section class="stack" id="s-transport" aria-label="Access-layer transports">
  <h2>How the knowledge is reached — one query layer, two doors</h2>
  <p>The Source Library Server exposes a single query layer through two transports: the pipeline's agents speak to it over a local process channel, and the reader's browser reaches it over local HTTP. Both hit the same code path; neither touches the network.</p>
  <Mermaid
    id="blackbox-transport"
    title="The Source Library query layer reached two ways: pipeline agents over MCP stdio, and the reader's browser over HTTP on port 4390 — both resolving to one query layer that reads the local FTS5 mirror and, on the LAN, the SQL Server."
    caption="One query layer, two transports — agents over stdio, the reader over localhost HTTP."
  />
</section>

<!-- 5.3 Ingest path -->
<section class="stack" id="s-ingest" aria-label="Knowledge ingest path">
  <h2>How new source knowledge is absorbed</h2>
  <p>Dropping a lecture-transcript dump runs an idempotent ingest: anything already in the corpus is skipped, so re-running the same dump never duplicates content.</p>
  <Mermaid
    id="ksessions-ingest"
    title="The ingest path: drop a dump, ingest and normalise, dedup against the corpus; new content is added, already-present content is skipped, both ending at the knowledge.db corpus — making re-runs idempotent."
    caption="Idempotent by design — re-running a dump adds only what is genuinely new."
  />
</section>

<!-- 5.4 Credentials -->
<section class="stack" id="s-credentials" aria-label="Credential and auth map">
  <h2>Credentials — where every secret lives and what it authorises</h2>
  <p>Every key is stored in a single git-ignored local file (or held only as a browser session). Risk is rated by privilege and exposure.</p>
  <div class="infra-table-wrap">
    <table class="infra-table">
      <caption>Each row: the secret, where it lives, what it authorises, and its risk tier.</caption>
      <thead>
        <tr><th scope="col">Secret</th><th scope="col">Where it lives</th><th scope="col">Authorises</th><th scope="col">Risk</th><th scope="col">Note</th></tr>
      </thead>
      <tbody>
        {creds.map((c) => (
          <tr>
            <td><code>{c.key}</code></td>
            <td>{c.storage}</td>
            <td>{c.service}</td>
            <td><span class={`risk-pill ${riskClass(c.risk)}`}>{riskLabel(c.risk)}</span></td>
            <td>{c.note}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>

<!-- Hotspots index -->
<section class="stack" id="s-hotspots" aria-label="Hotspots index">
  <h2>Hotspots index — security, cost, and architecture at a glance</h2>
  <p>A standing punch-list for the technical reader: what to watch (security, cost), what is deliberately structured (architecture), and what is verified clean.</p>
  <div class="infra-table-wrap">
    <table class="infra-table">
      <caption>Tagged SEC (security), COST, ARCH (architecture), or OK (verified).</caption>
      <thead>
        <tr><th scope="col">Tag</th><th scope="col">Item</th><th scope="col">Detail</th></tr>
      </thead>
      <tbody>
        {hotspots.map((h) => (
          <tr>
            <td><span class={h.cls}>{h.tag}</span></td>
            <td>{h.item}</td>
            <td>{h.detail}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>

<!-- Database groups -->
<section class="stack" id="s-database" aria-label="Database architecture overview">
  <h2>Database architecture — what the knowledge store holds</h2>
  <p>Sixteen SOLID-compliant tables in a single SQLite database replace scattered JSONL files. Four logical groups, each with a distinct role. <a href="/db-schema">Explore the full schema →</a></p>

  <div class="db-overview-grid">
    <div class="db-overview-group grp-core">
      <div class="db-grp-header"><span class="db-grp-icon" aria-hidden="true">⚙</span><strong>Core Pipeline</strong><span class="db-grp-count">6 tables</span></div>
      <ul class="db-grp-tables">
        <li><code>books</code> — one row per ingested source</li>
        <li><code>chapters</code> — each chapter with enrichment state</li>
        <li><code>episodes</code> — output episode registry</li>
        <li><code>phonetics</code> — Islamic name pronunciations</li>
        <li><code>pipeline_runs</code> — audit log of every phase run</li>
        <li><code>cost_ledger</code> — per-call LLM cost tracking</li>
      </ul>
    </div>
    <div class="db-overview-group grp-know">
      <div class="db-grp-header"><span class="db-grp-icon" aria-hidden="true">📚</span><strong>Knowledge Store</strong><span class="db-grp-count">6 tables</span></div>
      <ul class="db-grp-tables">
        <li><code>knowledge_atoms</code> — Quran / Hadith / Doctrine atoms</li>
        <li><code>atom_sources</code> — provenance join table</li>
        <li><code>atom_topic_tags</code> — covering-indexed tag join</li>
        <li><code>external_corpora</code> — Wisdom corpus registry</li>
        <li><code>topic_type_taxonomy</code> — 18 seed rows</li>
        <li><code>corpus_chapters</code> — per-chapter state machine</li>
      </ul>
    </div>
    <div class="db-overview-group grp-qual">
      <div class="db-grp-header"><span class="db-grp-icon" aria-hidden="true">⚖</span><strong>Quality Audit</strong><span class="db-grp-count">1 table</span></div>
      <ul class="db-grp-tables">
        <li><code>challenger_findings</code> — P0/P1/P2 findings per chapter, fix status, iteration count</li>
      </ul>
      <div class="db-grp-note">Challenger findings feed the convergence loop and the cross-book health scores in the Bookshelf.</div>
    </div>
    <div class="db-overview-group grp-mirror">
      <div class="db-grp-header"><span class="db-grp-icon" aria-hidden="true">⚡</span><strong>Source Library Mirror</strong><span class="db-grp-count">4 tables</span><span class="db-grp-wave">Wave J</span></div>
      <ul class="db-grp-tables">
        <li><code>fts_quran</code> — FTS5: Arabic + Pickthall + Asad + Urdu</li>
        <li><code>fts_topics</code> — FTS5: Wisdom topic data</li>
        <li><code>fts_sessions</code> — FTS5: 343 lecture transcripts</li>
        <li><code>term_index</code> — unified term lookup w/ etymology, tradition, source</li>
      </ul>
      <div class="db-grp-note">mirror.db — separate from knowledge.db. Gitignored, under 50 MB. Auto-populated from SQL Server on first sync. Zero token cost per lookup.</div>
    </div>
    <div class="db-overview-group grp-etym db-grp-future">
      <div class="db-grp-header"><span class="db-grp-icon" aria-hidden="true">🌿</span><strong>Etymology</strong><span class="db-grp-count">3 tables</span><span class="db-grp-wave">Wave 3</span></div>
      <ul class="db-grp-tables">
        <li><code>arabic_roots</code> — Semitic roots with abjad sums</li>
        <li><code>word_etymologies</code> — morphological derivations</li>
        <li><code>letter_profiles</code> — 28 rows, makhraj + sifāt</li>
      </ul>
      <div class="db-grp-note">Created now, empty until Wave 3. No migration required.</div>
    </div>
  </div>
</section>

<!-- Vendor cost drill-down -->
<section class="stack" id="s-costs">
  <h2>Vendor cost breakdown</h2>
  <p>Per-service cost detail. Each vendor is rolled up above; expand here to see individual service calls.</p>
  <InfraColumns vendors={infra.vendors} client:load />
</section>

</Base>
