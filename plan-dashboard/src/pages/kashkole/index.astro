---
/**
 * Kashkole binder + chapter index.
 *
 * Lists all binders → chapters with English (R1/R2) and Urdu names.
 * Includes a live search across English titles, Urdu names, and topic counts.
 */
import Base from '../../layouts/Base.astro';
import Icon from '../../components/ui/Icon.astro';
import { discoverBundles } from '../../lib/reader/source-extractor';
import { getBinderEnglish, getChapterEnglish, isBinderTopicRetitled } from '../../lib/reader/decisions';

const all = await discoverBundles();
const kashkole = all.find((s) => s.source === 'kashkole');

interface EnrichedChapter {
  binderId: number;
  chapterId: number;
  shelfSlug: string;
  bookSlug: string;
  urduName: string;
  englishTitle?: string;
  confidence?: 'high' | 'medium' | 'low';
  sections: number;
  inlineImages: number;
  stage: string;
}

interface EnrichedShelf {
  binderId: number;
  shelfSlug: string;
  shelfPrefix: string;
  urduName: string;
  englishTitle?: string;
  topicsRetitled: boolean;
  chapterCount: number;
  totalSections: number;
  chapters: EnrichedChapter[];
}

const shelves: EnrichedShelf[] = [];
if (kashkole) {
  for (const sh of kashkole.shelves) {
    const binderId = sh.chapters[0]?.manifest.shelf.id;
    if (binderId == null) continue;
    const enBinder = await getBinderEnglish(sh.shelfName);
    const topicsRetitled = await isBinderTopicRetitled(binderId);

    const chapters: EnrichedChapter[] = [];
    for (const ch of sh.chapters) {
      const chapterId = ch.manifest.book.id;
      const enChapter = await getChapterEnglish(binderId, chapterId);
      chapters.push({
        binderId,
        chapterId,
        shelfSlug: sh.shelfSlug,
        bookSlug: ch.bookSlug,
        urduName: ch.manifest.book.name,
        englishTitle: enChapter?.en_title,
        confidence: enChapter?.confidence,
        sections: ch.manifest.counts?.sections ?? 0,
        inlineImages: ch.manifest.counts?.inline_images ?? 0,
        stage: ch.manifest.stage,
      });
    }

    shelves.push({
      binderId,
      shelfSlug: sh.shelfSlug,
      shelfPrefix: sh.shelfPrefix,
      urduName: sh.shelfName,
      englishTitle: enBinder,
      topicsRetitled,
      chapterCount: sh.chapters.length,
      totalSections: chapters.reduce((n, c) => n + c.sections, 0),
      chapters,
    });
  }
}

const totalChapters = shelves.reduce((n, s) => n + s.chapterCount, 0);
const totalSections = shelves.reduce((n, s) => n + s.totalSections, 0);
const retitledBinders = shelves.filter((s) => s.topicsRetitled).length;
---
<Base title="Kashkole" active="kashkole" description="Kashkole binder and chapter index">
  <header class="kash-header">
    <div class="kash-header-inner">
      <nav class="kash-breadcrumb">
        <a href="/library">Library</a>
        <Icon name="chevron-right" size={11} />
        <span class="kash-breadcrumb-active">Kashkole</span>
      </nav>

      <div class="kash-title-row">
        <div>
          <h1 class="kash-title">Kashkole</h1>
          <div class="kash-title-urdu" lang="ur">کشکول</div>
          <p class="kash-tagline">
            19 binders. 122 chapters. 1,337 topics. Tayyibi Ismaili philosophical, theological, jurisprudential, and devotional materials in Urdu — paired side-by-side with proposed English titles and (when translated) English text.
          </p>
        </div>

        <div class="kash-stats">
          <div class="kash-stat">
            <div class="kash-stat-num">{shelves.length}</div>
            <div class="kash-stat-label">Binders</div>
          </div>
          <div class="kash-stat-divider"></div>
          <div class="kash-stat">
            <div class="kash-stat-num" style="color: var(--color-gold-deep);">{totalChapters}</div>
            <div class="kash-stat-label" style="color: var(--color-gold-deep);">Chapters</div>
          </div>
          <div class="kash-stat-divider"></div>
          <div class="kash-stat">
            <div class="kash-stat-num">{totalSections}</div>
            <div class="kash-stat-label">Topics</div>
          </div>
          <div class="kash-stat-divider"></div>
          <div class="kash-stat">
            <div class="kash-stat-num">{retitledBinders}/{shelves.length}</div>
            <div class="kash-stat-label">Topic-retitled</div>
          </div>
        </div>
      </div>

      <div class="kash-search-wrap">
        <label class="kash-search-label">
          <input
            type="search"
            id="kashkole-search"
            placeholder="Search chapters by English title or Urdu name…"
            class="kash-search-input"
          />
          <span class="kash-search-hint">/</span>
        </label>
        <div class="kash-search-sub">
          <span id="search-counter">{totalChapters} chapters</span>
          <span> · Confidence:
            <span class="kash-conf-badge kash-conf-high">★★★ high</span> ·
            <span class="kash-conf-badge kash-conf-med">★★ medium</span> ·
            <span class="kash-conf-badge kash-conf-low">★ low</span>
          </span>
        </div>
      </div>
    </div>
  </header>

  <main class="kash-main">
    {shelves.length === 0 ? (
      <div class="kash-empty">
        <Icon name="folder" size={36} />
        <p>No Kashkole bundles found.</p>
      </div>
    ) : (
      <div id="binder-list">
        {shelves.map((sh) => (
          <section data-binder-id={sh.binderId} class="binder-section">
            <header class="binder-header">
              <div class="binder-title-group">
                <span class="binder-badge">Binder {sh.shelfPrefix}</span>
                {sh.englishTitle && (
                  <h2 class="binder-title-en">{sh.englishTitle}</h2>
                )}
                <span class="binder-title-ur" lang="ur">{sh.urduName}</span>
              </div>
              <div class="binder-meta">
                {sh.topicsRetitled ? (
                  <span class="kash-tag kash-tag-retitled">topics retitled</span>
                ) : (
                  <span class="kash-tag kash-tag-pending">topics pending</span>
                )}
                <span>{sh.chapterCount} chapter{sh.chapterCount === 1 ? '' : 's'}</span>
                <span>{sh.totalSections} topics</span>
              </div>
            </header>

            <div class="chapter-grid">
              {sh.chapters.map((ch) => (
                <a
                  href={`/kashkole/${ch.shelfSlug}/${ch.bookSlug}/`}
                  data-chapter-en={(ch.englishTitle ?? '').toLowerCase()}
                  data-chapter-ur={ch.urduName}
                  class="chapter-card"
                >
                  <div class="chapter-card-top">
                    <div class="chapter-card-text">
                      {ch.englishTitle ? (
                        <div class="chapter-card-en">{ch.englishTitle}</div>
                      ) : (
                        <div class="chapter-card-pending">English title pending</div>
                      )}
                      <div class="chapter-card-ur" lang="ur">{ch.urduName}</div>
                    </div>
                    <div class="chapter-card-conf">
                      {ch.confidence === 'high' && <span title="High confidence translation" style="color: var(--color-gold-deep);">★★★</span>}
                      {ch.confidence === 'medium' && <span title="Medium confidence" style="color: var(--color-ink-secondary);">★★</span>}
                      {ch.confidence === 'low' && <span title="Low confidence" style="color: var(--color-ink-tertiary);">★</span>}
                    </div>
                  </div>
                  <div class="chapter-card-foot">
                    <div class="chapter-card-stats">
                      <span>{ch.sections} topics</span>
                      {ch.inlineImages > 0 && <span>{ch.inlineImages} img</span>}
                      <span class="chapter-card-stage">{ch.stage}</span>
                    </div>
                    <Icon name="arrow-right" size={13} />
                  </div>
                </a>
              ))}
            </div>
          </section>
        ))}
      </div>
    )}
  </main>
</Base>

<script>
  const input = document.getElementById('kashkole-search') as HTMLInputElement;
  const counter = document.getElementById('search-counter')!;
  const binderList = document.getElementById('binder-list')!;
  if (input && binderList) {
    const allCards = Array.from(binderList.querySelectorAll<HTMLElement>('.chapter-card'));
    const allSections = Array.from(binderList.querySelectorAll<HTMLElement>('.binder-section'));
    const totalN = allCards.length;

    function applyFilter(q: string) {
      const needle = q.trim().toLowerCase();
      if (!needle) {
        allCards.forEach((c) => (c.style.display = ''));
        allSections.forEach((s) => (s.style.display = ''));
        counter.textContent = `${totalN} chapters`;
        return;
      }
      let visible = 0;
      for (const card of allCards) {
        const en = card.dataset.chapterEn ?? '';
        const ur = card.dataset.chapterUr ?? '';
        if (en.includes(needle) || ur.includes(needle)) {
          card.style.display = '';
          visible++;
        } else {
          card.style.display = 'none';
        }
      }
      for (const sec of allSections) {
        const anyVisible = Array.from(sec.querySelectorAll<HTMLElement>('.chapter-card'))
          .some((c) => c.style.display !== 'none');
        sec.style.display = anyVisible ? '' : 'none';
      }
      counter.textContent = `${visible} of ${totalN} chapters`;
    }

    input.addEventListener('input', () => applyFilter(input.value));
    window.addEventListener('keydown', (e) => {
      if (e.key === '/' && document.activeElement?.tagName !== 'INPUT') {
        e.preventDefault();
        input.focus();
        input.select();
      }
    });
  }
</script>

<style>
  /* ── Kashkole page layout ───────────────────────────────────────── */
  .kash-header {
    border-bottom: 1px solid var(--c-rule);
    background: var(--c-bg-card);
  }
  .kash-header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 32px 32px 24px;
  }
  .kash-breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-ui);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--c-ink-muted);
  }
  .kash-breadcrumb a { color: inherit; text-decoration: none; }
  .kash-breadcrumb a:hover { text-decoration: underline; }
  .kash-breadcrumb-active { color: var(--c-gold); }

  .kash-title-row {
    margin-top: 24px;
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
  }
  .kash-title {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 3rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--c-ink);
  }
  .kash-title-urdu {
    margin-top: 4px;
    font-family: var(--font-urdu, serif);
    font-size: 1.6rem;
    direction: rtl;
    color: var(--c-ink-dim);
  }
  .kash-tagline {
    margin-top: 12px;
    max-width: 640px;
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 1rem;
    font-style: italic;
    line-height: 1.6;
    color: var(--c-ink-dim);
  }

  .kash-stats {
    display: flex;
    border: 1px solid var(--c-rule);
    border-radius: 8px;
    background: var(--c-bg-card);
    overflow: hidden;
    flex-shrink: 0;
  }
  .kash-stat {
    padding: 12px 20px;
    text-align: center;
  }
  .kash-stat-num {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 1.75rem;
    font-weight: 600;
    line-height: 1;
    color: var(--c-ink);
  }
  .kash-stat-label {
    font-family: var(--font-ui);
    margin-top: 4px;
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--c-ink-muted);
  }
  .kash-stat-divider {
    width: 1px;
    background: var(--c-rule);
  }

  .kash-search-wrap { margin-top: 24px; }
  .kash-search-label { position: relative; display: block; }
  .kash-search-input {
    font-family: var(--font-ui);
    width: 100%;
    border: 1px solid var(--c-rule);
    border-radius: 8px;
    padding: 12px 48px 12px 20px;
    font-size: 1rem;
    background: var(--c-bg);
    color: var(--c-ink);
    outline: none;
    transition: box-shadow 0.15s;
  }
  .kash-search-input:focus { box-shadow: 0 0 0 2px var(--c-gold); }
  .kash-search-hint {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-ui);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: 1px solid var(--c-rule);
    border-radius: 3px;
    padding: 2px 6px;
    color: var(--c-ink-muted);
    pointer-events: none;
  }
  .kash-search-sub {
    margin-top: 8px;
    font-family: var(--font-ui);
    font-size: 11px;
    color: var(--c-ink-muted);
  }
  .kash-conf-badge {
    border-radius: 4px;
    padding: 1px 6px;
    font-size: 10px;
  }
  .kash-conf-high { background: var(--c-bg-sunken); color: var(--c-gold); }
  .kash-conf-med  { border: 1px solid var(--c-rule); color: var(--c-ink-dim); }
  .kash-conf-low  { border: 1px solid var(--c-rule); color: var(--c-ink-muted); }

  .kash-main {
    max-width: 1200px;
    margin: 0 auto;
    padding: 32px;
  }
  .kash-empty {
    border: 1px solid var(--c-rule);
    border-radius: 8px;
    padding: 48px 24px;
    text-align: center;
    background: var(--c-bg-card);
  }
  .kash-empty p {
    font-family: var(--font-ui);
    margin-top: 12px;
    color: var(--c-ink-dim);
  }

  .binder-section { margin-bottom: 40px; }
  .binder-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 24px;
    border-bottom: 1px solid var(--c-rule);
    padding-bottom: 12px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }
  .binder-title-group {
    display: flex;
    align-items: baseline;
    gap: 16px;
    min-width: 0;
    flex-wrap: wrap;
  }
  .binder-badge {
    font-family: var(--font-ui);
    flex-shrink: 0;
    border-radius: 4px;
    padding: 2px 8px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    background: var(--c-bg-sunken);
    color: var(--c-gold);
  }
  .binder-title-en {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--c-ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 400px;
  }
  .binder-title-ur {
    font-family: var(--font-urdu, serif);
    font-size: 1.2rem;
    direction: rtl;
    color: var(--c-ink-dim);
  }
  .binder-meta {
    font-family: var(--font-ui);
    display: flex;
    align-items: center;
    gap: 16px;
    flex-shrink: 0;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--c-ink-muted);
  }
  .kash-tag {
    border-radius: 4px;
    padding: 2px 6px;
    font-size: 9px;
  }
  .kash-tag-retitled { background: var(--c-bg-sunken); color: var(--c-gold); }
  .kash-tag-pending  { border: 1px solid var(--c-rule); color: var(--c-ink-muted); }

  .chapter-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 12px;
  }
  @media (min-width: 768px) {
    .chapter-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1100px) {
    .chapter-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .chapter-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--c-rule);
    border-radius: 8px;
    padding: 16px;
    background: var(--c-bg-card);
    color: var(--c-ink);
    text-decoration: none;
    transition: transform 0.1s, box-shadow 0.1s;
  }
  .chapter-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px -4px rgba(0,0,0,0.12);
  }
  .chapter-card-top {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }
  .chapter-card-text { flex: 1; min-width: 0; }
  .chapter-card-en {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.3;
  }
  .chapter-card-pending {
    font-family: var(--font-ui);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-style: italic;
    color: var(--c-ink-muted);
  }
  .chapter-card-ur {
    margin-top: 8px;
    font-family: var(--font-urdu, serif);
    font-size: 1.05rem;
    direction: rtl;
    color: var(--c-ink-dim);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .chapter-card-conf { flex-shrink: 0; }
  .chapter-card-foot {
    margin-top: 12px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid var(--c-rule);
    padding-top: 8px;
  }
  .chapter-card-stats {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-ui);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-ink-muted);
  }
  .chapter-card-stage {
    border: 1px solid var(--c-rule);
    border-radius: 3px;
    padding: 1px 5px;
    font-size: 9px;
  }
</style>
