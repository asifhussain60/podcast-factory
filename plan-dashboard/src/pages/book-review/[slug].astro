---
/**
 * Book Review page — Wave I (I5)
 * Shows the source review gate status for a book and allows approval.
 *
 * Route: /book-review/[slug]
 * Usage: navigate to http://localhost:4322/book-review/kitab-al-riyad
 */
import { readFileSync, existsSync } from 'fs';
import { join } from 'path';

const { slug } = Astro.params;

// Resolve book gate file
const REPO_ROOT = join(import.meta.dirname, '../../../../');
const CONTENT_DIR = join(REPO_ROOT, 'CONTENT', 'drafts', 'books');
const gateFile = join(CONTENT_DIR, slug!, '_system', 'review-gate.json');
const stateFile = join(CONTENT_DIR, slug!, '_system', 'orchestrator-state.json');

let gate: any = null;
let state: any = null;
let gateError: string | null = null;

try {
  if (existsSync(gateFile)) {
    gate = JSON.parse(readFileSync(gateFile, 'utf-8'));
  } else {
    gateError = `No review-gate.json found for book "${slug}". Run Phase 06a first.`;
  }
} catch (e: any) {
  gateError = `Error reading review-gate.json: ${e.message}`;
}

try {
  if (existsSync(stateFile)) {
    state = JSON.parse(readFileSync(stateFile, 'utf-8'));
  }
} catch (_) {
  // state is optional — no gate needed for display
}

const isApproved = gate?.approved === true;
const p0Warnings = (gate?.warnings ?? []).filter((w: any) => w.severity === 'P0');
const p1Warnings = (gate?.warnings ?? []).filter((w: any) => w.severity === 'P1');
const p2Warnings = (gate?.warnings ?? []).filter((w: any) => w.severity === 'P2');
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Book Review — {slug}</title>
  <style>
    * { box-sizing: border-box; }
    body { font-family: system-ui, sans-serif; max-width: 900px; margin: 2rem auto; padding: 0 1.5rem; background: #0f1117; color: #e1e4e8; }
    h1 { font-size: 1.6rem; font-weight: 700; margin-bottom: 0.25rem; }
    .slug { font-size: 0.85rem; color: #8b949e; margin-bottom: 1.5rem; font-family: monospace; }
    .pill { display: inline-block; padding: 0.2rem 0.7rem; border-radius: 1rem; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.04em; }
    .pill-pass { background: #1a3a28; color: #3fb950; }
    .pill-pending { background: #2a2a1a; color: #e3b341; }
    .pill-blocked { background: #3a1a1a; color: #f85149; }
    .section { background: #161b22; border: 1px solid #30363d; border-radius: 8px; padding: 1.25rem 1.5rem; margin: 1rem 0; }
    .section h2 { font-size: 1rem; font-weight: 600; margin: 0 0 0.75rem; }
    .warning-row { display: flex; gap: 0.75rem; align-items: flex-start; padding: 0.5rem 0; border-bottom: 1px solid #21262d; }
    .warning-row:last-child { border-bottom: none; }
    .sev { font-size: 0.75rem; font-weight: 700; padding: 0.1rem 0.45rem; border-radius: 4px; flex-shrink: 0; margin-top: 1px; }
    .sev-P0 { background: #3a1a1a; color: #f85149; }
    .sev-P1 { background: #2a2010; color: #e3b341; }
    .sev-P2 { background: #162032; color: #79c0ff; }
    .msg { font-size: 0.875rem; line-height: 1.5; }
    .chapter-tag { font-size: 0.7rem; color: #8b949e; font-family: monospace; margin-top: 0.2rem; }
    .status-row { display: flex; gap: 1rem; align-items: center; flex-wrap: wrap; margin-bottom: 0.5rem; }
    .meta-key { font-size: 0.75rem; color: #8b949e; min-width: 110px; }
    .meta-val { font-size: 0.875rem; color: #e1e4e8; font-family: monospace; }
    .approve-btn { background: #238636; color: #fff; border: none; border-radius: 6px; padding: 0.6rem 1.4rem; font-size: 0.9rem; font-weight: 600; cursor: pointer; margin-top: 1rem; }
    .approve-btn:hover { background: #2ea043; }
    .approve-btn:disabled { background: #21262d; color: #8b949e; cursor: not-allowed; }
    .error-box { background: #3a1a1a; border: 1px solid #f85149; border-radius: 8px; padding: 1rem 1.25rem; color: #f85149; }
    .approved-banner { background: #1a3a28; border: 1px solid #3fb950; border-radius: 8px; padding: 1rem 1.25rem; color: #3fb950; font-weight: 600; margin: 1rem 0; }
    .blocked-banner { background: #3a1a1a; border: 1px solid #f85149; border-radius: 8px; padding: 1rem 1.25rem; color: #f85149; font-weight: 600; margin: 1rem 0; }
    #approve-result { margin-top: 0.75rem; font-size: 0.875rem; }
    a { color: #79c0ff; text-decoration: none; }
    a:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <div style="margin-bottom: 1rem;">
    <a href="/dashboard">← Dashboard</a>
  </div>

  <h1>Source Review Gate</h1>
  <div class="slug">book: {slug}</div>

  {gateError && (
    <div class="error-box">
      <strong>Gate not found</strong><br />{gateError}
      <br /><br />
      <code>python3 scripts/podcast/phases/source_review_gate.py CONTENT/drafts/books/{slug}</code>
    </div>
  )}

  {gate && (
    <>
      {/* Status summary */}
      <div class="section">
        <h2>Gate Status</h2>
        <div class="status-row">
          <span class="meta-key">Phase</span>
          <span class="meta-val">{gate.phase ?? '06a'}</span>
        </div>
        <div class="status-row">
          <span class="meta-key">Approved</span>
          <span class={`pill ${isApproved ? 'pill-pass' : p0Warnings.length > 0 ? 'pill-blocked' : 'pill-pending'}`}>
            {isApproved ? 'APPROVED' : p0Warnings.length > 0 ? 'BLOCKED — P0 WARNINGS' : 'PENDING REVIEW'}
          </span>
        </div>
        {gate.reviewed_at && (
          <div class="status-row">
            <span class="meta-key">Reviewed at</span>
            <span class="meta-val">{gate.reviewed_at}</span>
          </div>
        )}
        {gate.approved_at && (
          <div class="status-row">
            <span class="meta-key">Approved at</span>
            <span class="meta-val">{gate.approved_at}</span>
          </div>
        )}
        <div class="status-row">
          <span class="meta-key">Warnings</span>
          <span class="meta-val">
            {p0Warnings.length > 0 && <span style="color:#f85149">P0: {p0Warnings.length}</span>}
            {p1Warnings.length > 0 && <span style="color:#e3b341; margin-left:0.5rem">P1: {p1Warnings.length}</span>}
            {p2Warnings.length > 0 && <span style="color:#79c0ff; margin-left:0.5rem">P2: {p2Warnings.length}</span>}
            {gate.warnings?.length === 0 && <span style="color:#3fb950">None — clean</span>}
          </span>
        </div>
      </div>

      {/* Approval banner */}
      {isApproved && (
        <div class="approved-banner">
          ✓ Approved — pipeline can proceed from Phase 06a. Run: <code>python3 scripts/podcast/orchestrate_book.py --resume {slug}</code>
        </div>
      )}
      {!isApproved && p0Warnings.length > 0 && (
        <div class="blocked-banner">
          ⛔ Blocked — {p0Warnings.length} P0 warning(s) must be resolved before approving.
        </div>
      )}

      {/* Warnings list */}
      {gate.warnings?.length > 0 && (
        <div class="section">
          <h2>Findings ({gate.warnings.length})</h2>
          {[...p0Warnings, ...p1Warnings, ...p2Warnings].map((w: any) => (
            <div class="warning-row">
              <span class={`sev sev-${w.severity}`}>{w.severity}</span>
              <div>
                <div class="msg">{w.message}</div>
                {w.chapter && <div class="chapter-tag">chapter: {w.chapter}</div>}
              </div>
            </div>
          ))}
        </div>
      )}

      {/* Approval action */}
      {!isApproved && (
        <div class="section">
          <h2>Approve for Pipeline</h2>
          <p style="font-size:0.875rem; color:#8b949e; margin-top:0;">
            After reviewing the findings above, click Approve to allow the pipeline
            to advance past Phase 06a into the series plan. This action is logged with a timestamp.
          </p>
          <button
            class="approve-btn"
            id="approve-btn"
            disabled={p0Warnings.length > 0}
            onclick={`approveBook('${slug}')`}
          >
            {p0Warnings.length > 0 ? 'Cannot approve — resolve P0 warnings first' : `Approve "${slug}" for pipeline`}
          </button>
          <div id="approve-result"></div>
          <p style="font-size:0.75rem; color:#8b949e; margin-top: 0.75rem;">
            CLI alternative: <code>python3 scripts/podcast/approve_book.py {slug}</code>
          </p>
        </div>
      )}

      {/* Orchestrator state excerpt */}
      {state && (
        <div class="section">
          <h2>Orchestrator State</h2>
          <div class="status-row">
            <span class="meta-key">Phase</span>
            <span class="meta-val">{state.phase}</span>
          </div>
          <div class="status-row">
            <span class="meta-key">Status</span>
            <span class="meta-val">{state.phase_status}</span>
          </div>
          {state.last_error && (
            <div class="status-row">
              <span class="meta-key">Last error</span>
              <span class="meta-val" style="color:#f85149; font-size:0.8rem;">{state.last_error?.slice(0, 120)}</span>
            </div>
          )}
        </div>
      )}
    </>
  )}

  <script define:vars={{ slug }}>
    async function approveBook(bookSlug) {
      const btn = document.getElementById('approve-btn');
      const result = document.getElementById('approve-result');
      btn.disabled = true;
      btn.textContent = 'Approving…';
      result.textContent = '';
      try {
        const resp = await fetch(`/api/approve/${bookSlug}`, { method: 'POST' });
        const data = await resp.json();
        if (resp.ok && data.approved) {
          result.style.color = '#3fb950';
          result.textContent = `✓ Approved at ${data.approved_at}. Reload this page to see updated status.`;
          btn.textContent = 'Approved ✓';
        } else {
          result.style.color = '#f85149';
          result.textContent = data.error ?? 'Approval failed — check server logs.';
          btn.disabled = false;
          btn.textContent = `Approve "${bookSlug}" for pipeline`;
        }
      } catch (e) {
        result.style.color = '#f85149';
        result.textContent = `Network error: ${e.message}`;
        btn.disabled = false;
        btn.textContent = `Approve "${bookSlug}" for pipeline`;
      }
    }
    window.approveBook = approveBook;
  </script>
</body>
</html>
