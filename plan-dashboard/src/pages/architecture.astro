---
import Base from '../layouts/Base.astro';
import PipelineSpine from '../components/PipelineSpine.tsx';
import LayerStack from '../components/LayerStack.tsx';
import arch from '../data/architecture-snapshot.json';
---
<Base title="Architecture" active="architecture" section="architecture">

  <!-- KPI stat strip -->
  <div class="stat-strip">
    <div class="stat-card s-green">
      <div class="stat-card-icon"><i class="fa-solid fa-route" aria-hidden="true"></i></div>
      <div class="stat-card-body">
        <div class="stat-card-value">{arch.phases.length}</div>
        <div class="stat-card-label">Pipeline Stations</div>
      </div>
    </div>
    <div class="stat-card s-blue">
      <div class="stat-card-icon"><i class="fa-solid fa-robot" aria-hidden="true"></i></div>
      <div class="stat-card-body">
        <div class="stat-card-value">{arch.agents.length}</div>
        <div class="stat-card-label">Agents</div>
      </div>
    </div>
    <div class="stat-card s-amber">
      <div class="stat-card-icon"><i class="fa-solid fa-layer-group" aria-hidden="true"></i></div>
      <div class="stat-card-body">
        <div class="stat-card-value">{arch.layers.length}</div>
        <div class="stat-card-label">Layers</div>
      </div>
    </div>
    <div class="stat-card s-brown">
      <div class="stat-card-icon"><i class="fa-solid fa-gavel" aria-hidden="true"></i></div>
      <div class="stat-card-body">
        <div class="stat-card-value">{arch.adrs.length}</div>
        <div class="stat-card-label">ADRs</div>
      </div>
    </div>
  </div>

  <header class="page-hero">
    <div class="page-hero-inner">
      <span class="eyebrow">Architecture</span>
      <h1 class="page-hero-title">The factory floor, top to bottom.</h1>
      <p class="page-hero-lede">
        A book enters at station one. A finished podcast series leaves at the bottom. Between them sit eleven
        stations, each doing one well-scoped job. The stations are fixed — every book passes through every station in
        the same order. What changes between books is which <em>modules</em> plug into each station.
      </p>
    </div>
  </header>

  <section class="stack">
    <h2>The pipeline as a timeline</h2>
    <p>
      Scroll the right column to walk through the eleven stations a book passes through. The mini-rail on the left
      keeps track of where you are and lets you jump anywhere. Each station has its full detail right where it sits
      — what plugs in, which agent does the work, what that agent knows and doesn't do.
    </p>
    <PipelineSpine phases={arch.phases} modules={arch.modules} agents={arch.agents} client:load />
  </section>

  <hr />

  <section class="stack">
    <h2>The six layers underneath</h2>
    <p>
      The code itself is organized as six stacked layers. A layer can only call into the layers below it. This is
      what keeps the system testable and changeable — adding a new book kind, a new rule, or a new vendor never
      requires touching the foundation.
    </p>
    <LayerStack layers={arch.layers} client:load />
  </section>

  <hr />

  <section class="stack">
    <h2>The book kinds we handle today</h2>
    <p>
      Each kind of book reads through the same pipeline but engages a different set of rules. New kinds are added by
      registering them — never by branching the pipeline code itself.
    </p>
    <div class="grid-2">
      {arch.archetypes.map((a) => (
        <div class="card card-tight">
          <strong>{a.id.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase())}</strong>
          <p class="small muted">Books using this kind: {a.books.join(', ')}</p>
        </div>
      ))}
    </div>
  </section>

  <hr />

  <section class="stack">
    <h2>The non-negotiables</h2>
    <p>The handful of design decisions that everything else respects.</p>
    <div class="grid-2">
      {arch.adrs.map((d) => (
        <div class="card card-tight">
          <strong>{d.title}</strong>
          <p class="small">{d.plain}</p>
        </div>
      ))}
    </div>
  </section>
</Base>
