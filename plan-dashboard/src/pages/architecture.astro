---
import Base from '../layouts/Base.astro';
import PipelineSpine from '../components/PipelineSpine.tsx';
import LayerStack from '../components/LayerStack.tsx';
import PhaseSwimlaneDiagram from '../components/PhaseSwimlaneDiagram.tsx';
import PipelineOverviewRail from '../components/PipelineOverviewRail.tsx';
import arch from '../data/architecture-snapshot.json';
---
<Base title="Architecture" active="architecture" section="architecture">

  <!-- ══════════════════════════════════════════════════════════════
       L1 — EXECUTIVE LAYER
       Any reader should understand the value and scope within 90 seconds.
  ═══════════════════════════════════════════════════════════════════ -->

  <!-- KPI stat strip -->
  <div class="stat-strip">
    <div class="stat-card s-green">
      <div class="stat-card-icon"><i class="fa-solid fa-route" aria-hidden="true"></i></div>
      <div class="stat-card-body">
        <div class="stat-card-value">{arch.phases.length}</div>
        <div class="stat-card-label">Pipeline Stations</div>
      </div>
    </div>
    <div class="stat-card s-blue">
      <div class="stat-card-icon"><i class="fa-solid fa-robot" aria-hidden="true"></i></div>
      <div class="stat-card-body">
        <div class="stat-card-value">{arch.agents.length}</div>
        <div class="stat-card-label">Agents</div>
      </div>
    </div>
    <div class="stat-card s-amber">
      <div class="stat-card-icon"><i class="fa-solid fa-layer-group" aria-hidden="true"></i></div>
      <div class="stat-card-body">
        <div class="stat-card-value">{arch.layers.length}</div>
        <div class="stat-card-label">Layers</div>
      </div>
    </div>
    <div class="stat-card s-brown">
      <div class="stat-card-icon"><i class="fa-solid fa-gavel" aria-hidden="true"></i></div>
      <div class="stat-card-body">
        <div class="stat-card-value">{arch.adrs.length}</div>
        <div class="stat-card-label">ADRs</div>
      </div>
    </div>
    <div class="stat-card s-green">
      <div class="stat-card-icon"><i class="fa-solid fa-book-open" aria-hidden="true"></i></div>
      <div class="stat-card-body">
        <div class="stat-card-value">6,236+</div>
        <div class="stat-card-label">Source Library Verses</div>
      </div>
    </div>
  </div>

  <header class="page-hero">
    <div class="page-hero-inner">
      <span class="eyebrow">Architecture</span>
      <h1 class="page-hero-title">From a book to a podcast — step by step.</h1>
      <p class="page-hero-lede">
        Drop in a book. The factory reads it, teaches itself the vocabulary, plans the episodes,
        enriches them with verified knowledge, writes the narrator framing, reviews everything for quality,
        and waits for your approval twice before anything ships.
        Two human checkpoints are built in. Nothing publishes without your sign-off.
      </p>
    </div>
  </header>

  <!-- L1: Three plain-language callouts -->
  <section class="grid-3">
    <div class="card card-tight">
      <i class="fa-solid fa-route" aria-hidden="true" style="color: var(--c-green); font-size: 20px; margin-bottom: 8px;"></i>
      <strong>Fixed stations, swappable rules</strong>
      <p class="small muted">
        Every book passes through the same {arch.phases.filter((p: any) => p.kind !== 'gate').length} production stations in the same order.
        What differs between a scholarly text and a lecture series is the set of rules each station activates — not the pipeline itself.
      </p>
    </div>
    <div class="card card-tight">
      <i class="fa-solid fa-hand" aria-hidden="true" style="color: var(--c-amber); font-size: 20px; margin-bottom: 8px;"></i>
      <strong>Two built-in review gates</strong>
      <p class="small muted">
        After vocabulary and source analysis (before expensive AI runs) and before anything is published,
        the pipeline stops and waits for you. No content moves forward without your explicit approval.
      </p>
    </div>
    <div class="card card-tight">
      <i class="fa-solid fa-layer-group" aria-hidden="true" style="color: var(--c-accent); font-size: 20px; margin-bottom: 8px;"></i>
      <strong>Six-layer codebase</strong>
      <p class="small muted">
        Foundation, style, intelligence, authoring, stations, driver.
        A layer can only call down, never sideways. Adding a new vendor or rule set never touches the foundation.
      </p>
    </div>
  </section>

  <section class="stack">
    <h2>The pipeline as a timeline</h2>
    <p>
      Walk through every station a book passes through. The mini-rail keeps track of where you are.
      Each station shows what plugs in, which agent does the work, and what the agent knows and won't do.
    </p>

    <!-- Rich animated pipeline overview rail (click a node to jump + expand) -->
    <PipelineOverviewRail phases={arch.phases} client:load />

    <PipelineSpine phases={arch.phases} modules={arch.modules} agents={arch.agents} client:load />
  </section>

  <!-- ══════════════════════════════════════════════════════════════
       L1 → L2 BOUNDARY
       A reader who stops here has a complete executive picture.
  ═══════════════════════════════════════════════════════════════════ -->
  <div class="l1-l2-boundary">
    <div class="l1-l2-boundary-inner">
      <span class="l1-l2-label">Architect detail below</span>
      <p class="l1-l2-sub">
        The pipeline view above shows today's stations. The sections below go deeper:
        the future-state phase sequence with model and cost annotations, the six code layers,
        book kind registry, and the design decisions that govern all of it.
      </p>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════════════════
       L2 — ARCHITECT LAYER
  ═══════════════════════════════════════════════════════════════════ -->

  <section class="stack" aria-label="L2 architect detail">
    <h2>Future-state phase sequence — model &amp; cost annotation</h2>
    <p>
      The swimlane below maps every planned station with the AI model it uses, the service it calls,
      and its token cost tier. Stations marked <strong>FUTURE</strong> are designed and tracked in the
      roadmap but not yet deployed. The two <strong>✋ HUMAN HALT</strong> gates are the hard
      checkpoints where the pipeline waits for your approval.
    </p>
    <PhaseSwimlaneDiagram client:visible />
  </section>

  <hr />

  <section class="stack">
    <h2>The six layers underneath</h2>
    <p>
      The code itself is organized as six stacked layers. A layer can only call into the layers below it. This is
      what keeps the system testable and changeable — adding a new book kind, a new rule, or a new vendor never
      requires touching the foundation.
    </p>
    <LayerStack layers={arch.layers} client:load />
  </section>

  <hr />

  <section class="stack">
    <h2>The book kinds we handle today</h2>
    <p>
      Each kind of book reads through the same pipeline but engages a different set of rules. New kinds are added by
      registering them — never by branching the pipeline code itself.
    </p>
    <div class="grid-2">
      {arch.archetypes.map((a) => (
        <div class="card card-tight">
          <strong>{a.id.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase())}</strong>
          <p class="small muted">Books using this kind: {a.books.join(', ')}</p>
        </div>
      ))}
    </div>
  </section>

  <hr />

  <section class="stack">
    <h2>The annotation-to-intelligence lane</h2>
    <p>
      The chapter reader now includes a right-hand annotation workspace built for one-handed review flow. It captures
      paragraph markers, autosaved notes, and queued AI instructions, then writes a durable chapter JSON handoff that
      assistant sessions and pipeline automation can consume directly.
    </p>
    <div class="card card-tight">
      <strong>See the full operational design</strong>
      <p class="small muted">
        Open <a href="/annotation-ops">Annotation Ops</a> for the visual flow, scope model (paragraph/book/global),
        and automation path into classification, retrieval, and cost-efficient production.
      </p>
    </div>
  </section>

  <hr />

  <section class="stack">
    <h2>The Source Library layer — zero-cost live intelligence</h2>
    <p>
      A local server (Python + FastAPI, port 4390) exposes three SQL Server databases as a unified query layer.
      The same server speaks two protocols: MCP stdio for pipeline agents and plain HTTP for the reader.
      Once the mirror is populated, verse lookups, root etymology, and term definitions cost zero tokens and respond in under a millisecond.
    </p>
    <div class="grid-3">
      <div class="card card-tight">
        <i class="fa-solid fa-star-and-crescent" aria-hidden="true" style="color: var(--c-green); font-size: 20px; margin-bottom: 8px;"></i>
        <strong>Full Quran database</strong>
        <p class="small muted">
          6,236 verses with Arabic, Pickthall, Muhammad Asad, Urdu, and phonetic transliteration.
          Root and derivative tables with grammar tags, definitions, and Arabic etymology.
          All served locally — replaces the quran.com API dependency entirely.
        </p>
      </div>
      <div class="card card-tight">
        <i class="fa-solid fa-database" aria-hidden="true" style="color: var(--c-planner); font-size: 20px; margin-bottom: 8px;"></i>
        <strong>Wisdom knowledge corpus</strong>
        <p class="small muted">
          Twenty years of Islamic scholarship in a structured anthology: binders, chapters, topics, glossary, and doctrinal terms.
          The reader's term hover panel draws from this directly — no Gemini call needed for terms the corpus already defines (~85–90% of hovers).
        </p>
      </div>
      <div class="card card-tight">
        <i class="fa-solid fa-microphone" aria-hidden="true" style="color: var(--c-amber); font-size: 20px; margin-bottom: 8px;"></i>
        <strong>343 session transcripts</strong>
        <p class="small muted">
          Lecture transcripts (HTML) searchable by FTS5. Key groups include Wise Reminder (44 sessions),
          Ikhwan Arithmetic (14), and Asaas Al-Taveel (32). The pipeline's style-rewrite phase
          can pull matching session phrases as style references.
        </p>
      </div>
    </div>
    <div class="card card-tight" style="margin-top: var(--sp-4);">
      <strong>Dual-protocol design (Wave J)</strong>
      <p class="small muted">
        One Python process, two interfaces. Pipeline agents call it over MCP stdio — the standard protocol that Claude and other agents speak natively. The Astro reader calls it over HTTP (port 4390) because browser apps can't speak stdio.
        A 300ms availability probe gates every HTTP call, with silent Gemini fallback for terms not in the local corpus.
      </p>
    </div>
  </section>

  <hr />

  <section class="stack">
    <h2>The non-negotiables</h2>
    <p>The handful of design decisions that everything else respects.</p>
    <div class="grid-2">
      {arch.adrs.map((d) => (
        <div class="card card-tight">
          <strong>{d.title}</strong>
          <p class="small">{d.plain}</p>
        </div>
      ))}
    </div>
  </section>
</Base>
