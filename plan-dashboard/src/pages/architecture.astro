---
import Base from '../layouts/Base.astro';
import PipelineSpine from '../components/PipelineSpine.tsx';
import LayerStack from '../components/LayerStack.tsx';
import arch from '../data/architecture-snapshot.json';
---
<Base title="How it works" active="architecture">
  <header class="stack">
    <span class="eyebrow">How it works</span>
    <h1>The factory floor, top to bottom.</h1>
    <p class="lede">
      A book enters at station one. A finished podcast series leaves at the bottom. Between them sit eleven
      stations, each doing one well-scoped job. The stations are fixed — every book passes through every station in
      the same order. What changes between books is which <em>modules</em> plug into each station.
    </p>
  </header>

  <section class="stack">
    <h2>The pipeline as a timeline</h2>
    <p>
      Click any station on the spine to focus on what it does and which modules feed it. The little dots on the
      connector lines show how many modules currently plug in at that station.
    </p>
    <PipelineSpine phases={arch.phases} modules={arch.modules} client:load />
  </section>

  <hr />

  <section class="stack">
    <h2>The six layers underneath</h2>
    <p>
      The code itself is organized as six stacked layers. A layer can only call into the layers below it. This is
      what keeps the system testable and changeable — adding a new book kind, a new rule, or a new vendor never
      requires touching the foundation.
    </p>
    <LayerStack layers={arch.layers} client:load />
  </section>

  <hr />

  <section class="stack">
    <h2>The book kinds we handle today</h2>
    <p>
      Each kind of book reads through the same pipeline but engages a different set of rules. New kinds are added by
      registering them — never by branching the pipeline code itself.
    </p>
    <div class="grid-2">
      {arch.archetypes.map((a) => (
        <div class="card card-tight">
          <strong>{a.id.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase())}</strong>
          <p class="small muted">Books using this kind: {a.books.join(', ')}</p>
        </div>
      ))}
    </div>
  </section>

  <hr />

  <section class="stack">
    <h2>The non-negotiables</h2>
    <p>The handful of design decisions that everything else respects.</p>
    <div class="grid-2">
      {arch.adrs.map((d) => (
        <div class="card card-tight">
          <strong>{d.title}</strong>
          <p class="small">{d.plain}</p>
        </div>
      ))}
    </div>
  </section>
</Base>
