---
import Base from '../layouts/Base.astro';
import AudienceBadge from '../components/AudienceBadge.astro';
import '../styles/system-map.css';
---

<Base title="System Map" active="system-map" section="architecture" description="Every actor in the podcast factory and how they connect — from raw PDF to published episode.">
  <header class="page-hero">
    <div class="page-hero-inner">
      <span class="eyebrow">System Map</span>
      <p class="home-hero-audience"><AudienceBadge tier="both" /></p>
      <h1 class="page-hero-title">Every actor, every connection.</h1>
      <p class="page-hero-lede">
              A scholarly book enters at the top. A published podcast exits at the bottom.
        Between them: four pipeline stages on your machine, three cloud services doing the heavy lifting,
        a shared knowledge store that makes each new book smarter than the last,
        and a local intelligence server that puts 6,000+ Quran verses and a scholarly corpus at your fingertips — instantly, at zero token cost.
      </p>
    </div>
  </header>

  <section class="stack">
    <div class="map-wrap">
      <svg
        class="actor-map"
        viewBox="0 0 820 760"
        xmlns="http://www.w3.org/2000/svg"
        role="img"
        aria-labelledby="system-map-title system-map-desc"
      >
        <title id="system-map-title">Podcast Factory system map</title>
        <desc id="system-map-desc">A system actor map showing source inputs, local pipeline stages, external services, the knowledge store, and the published catalog output.</desc>
        <defs>
          <marker id="ah" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto">
            <path d="M0,1 L9,5 L0,9 Z" fill="#87827a"/>
          </marker>
          <marker id="ah-stage" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="5" markerHeight="5" orient="auto">
            <path d="M0,1 L9,5 L0,9 Z" fill="#d9d3c4"/>
          </marker>
          <marker id="ah-azure" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto">
            <path d="M0,1 L9,5 L0,9 Z" fill="#0078d4"/>
          </marker>
          <marker id="ah-claude" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto">
            <path d="M0,1 L9,5 L0,9 Z" fill="#cc785c"/>
          </marker>
          <marker id="ah-google" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto">
            <path d="M0,1 L9,5 L0,9 Z" fill="#4285f4"/>
          </marker>
          <marker id="ah-nlm" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto">
            <path d="M0,1 L9,5 L0,9 Z" fill="#1a73e8"/>
          </marker>
          <marker id="ah-gold" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="5" markerHeight="5" orient="auto">
            <path d="M0,1 L9,5 L0,9 Z" fill="#b8860b"/>
          </marker>
          <marker id="ah-sqlsrv" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto">
            <path d="M0,1 L9,5 L0,9 Z" fill="#5b8dd9"/>
          </marker>
          <marker id="ah-rev-sqlsrv" viewBox="0 0 10 10" refX="1" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
            <path d="M0,1 L9,5 L0,9 Z" fill="#5b8dd9"/>
          </marker>
          <marker id="ah-rev-azure" viewBox="0 0 10 10" refX="1" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
            <path d="M0,1 L9,5 L0,9 Z" fill="#0078d4"/>
          </marker>
          <marker id="ah-rev-claude" viewBox="0 0 10 10" refX="1" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
            <path d="M0,1 L9,5 L0,9 Z" fill="#cc785c"/>
          </marker>
          <filter id="card-sh" x="-5%" y="-10%" width="110%" height="130%">
            <feDropShadow dx="0" dy="1" stdDeviation="2" flood-color="#1f1d18" flood-opacity="0.06"/>
          </filter>
        </defs>

        <!-- SECTION HEADERS -->
        <text class="col-lbl" x="249" y="16" text-anchor="middle">Your machine</text>
        <text class="col-lbl" x="659" y="16" text-anchor="middle">External services</text>

        <!-- ZONE BORDERS -->
        <rect class="zone zone-machine"  x="8"   y="24" width="482" height="672" rx="8"/>
        <rect class="zone zone-services" x="506" y="24" width="306" height="672" rx="8"/>

        <!-- INPUTS (top row, inside machine zone) -->
        <rect class="box-input" x="20"  y="36" width="150" height="52" rx="6" filter="url(#card-sh)"/>
        <text class="input-title" x="95"  y="58" text-anchor="middle">Book PDF</text>
        <text class="input-sub"   x="95"  y="76" text-anchor="middle">Scholarly Arabic text</text>
        <rect class="box-input" x="180" y="36" width="150" height="52" rx="6" filter="url(#card-sh)"/>
        <text class="input-title" x="255" y="58" text-anchor="middle">Audio / Lecture</text>
        <text class="input-sub"   x="255" y="76" text-anchor="middle">Recordings, transcripts</text>

        <!-- Input arrows converge to Stage 1 -->
        <path class="arr arr-input" d="M95,88  C95,96  244,96  244,102" marker-end="url(#ah)"/>
        <path class="arr arr-input" d="M255,88 C255,96 244,96  244,102" marker-end="url(#ah)"/>

        <!-- STAGE 1 -->
        <rect class="box-stage" x="20" y="102" width="452" height="66" rx="5" filter="url(#card-sh)"/>
        <circle class="stage-dot" cx="44" cy="135" r="12"/>
        <text class="stage-n"     x="44"  y="140" text-anchor="middle">1</text>
        <text class="stage-title" x="70"  y="124">Read &amp; Translate</text>
        <text class="stage-desc"  x="70"  y="142">Azure scans every page and translates Arabic to English.</text>
        <text class="stage-time"  x="463" y="124">~10 min</text>
        <path class="arr-stage" d="M244,168 V182" marker-end="url(#ah-stage)"/>

        <!-- STAGE 2 -->
        <rect class="box-stage" x="20" y="182" width="452" height="66" rx="5" filter="url(#card-sh)"/>
        <circle class="stage-dot" cx="44" cy="215" r="12"/>
        <text class="stage-n"     x="44"  y="220" text-anchor="middle">2</text>
        <text class="stage-title" x="70"  y="204">Plan the Episodes</text>
        <text class="stage-desc"  x="70"  y="222">Claude reads the full book and maps chapters to episodes.</text>
        <text class="stage-time"  x="463" y="204">~20 min</text>
        <path class="arr-stage" d="M244,248 V262" marker-end="url(#ah-stage)"/>

        <!-- STAGE 3 -->
        <rect class="box-stage" x="20" y="262" width="452" height="66" rx="5" filter="url(#card-sh)"/>
        <circle class="stage-dot" cx="44" cy="295" r="12"/>
        <text class="stage-n"     x="44"  y="300" text-anchor="middle">3</text>
        <text class="stage-title" x="70"  y="284">Write &amp; Challenge</text>
        <text class="stage-desc"  x="70"  y="302">Claude writes each chapter; a critic pass rejects weak output.</text>
        <text class="stage-time"  x="463" y="284">~2 hrs</text>
        <path class="arr-stage" d="M244,328 V342" marker-end="url(#ah-stage)"/>

        <!-- STAGE 4 -->
        <rect class="box-stage" x="20" y="342" width="452" height="66" rx="5" filter="url(#card-sh)"/>
        <circle class="stage-dot" cx="44" cy="375" r="12"/>
        <text class="stage-n"     x="44"  y="380" text-anchor="middle">4</text>
        <text class="stage-title" x="70"  y="364">Audit &amp; Ship</text>
        <text class="stage-desc"  x="70"  y="382">Gemini checks quality; the finished bundle ships to NotebookLM.</text>
        <text class="stage-time"  x="463" y="364">~30 min</text>
        <path class="arr-knowledge" d="M244,408 V422" marker-end="url(#ah-gold)"/>

        <!-- KNOWLEDGE STORE -->
        <rect class="box-knowledge" x="20" y="422" width="452" height="108" rx="5" filter="url(#card-sh)"/>
        <text class="know-title" x="246" y="448" text-anchor="middle">Knowledge Store</text>
        <text class="know-desc"  x="246" y="468" text-anchor="middle">Quran verses and hadith extracted from every processed book.</text>
        <text class="know-desc"  x="246" y="486" text-anchor="middle">Later books draw on this memory to enrich their own chapters.</text>
        <text class="know-note"  x="246" y="503" text-anchor="middle">SQLite database, shared across all books. Grows richer with every book processed.</text>

        <!-- Arrow from Knowledge Store to Source Library Server -->
        <path class="arr-knowledge" d="M244,530 V544" marker-end="url(#ah-gold)"/>

        <!-- SOURCE LIBRARY SERVER -->
        <rect class="box-source-lib" x="20" y="544" width="452" height="130" rx="5" filter="url(#card-sh)"/>
        <text class="src-lib-title" x="246" y="568" text-anchor="middle">Source Library Server · port 4390</text>
        <text class="src-lib-sub"   x="246" y="586" text-anchor="middle">MCP stdio (pipeline agents) + HTTP REST (Astro reader) · same query layer</text>
        <text class="know-desc"     x="246" y="606" text-anchor="middle">KQUR: 6,236 verses, Arabic + 4 translations, roots, derivatives, etymology</text>
        <text class="know-desc"     x="246" y="622" text-anchor="middle">WISDOM: scholarly anthology, glossary, 18-type topic taxonomy, term index</text>
        <text class="know-note"     x="246" y="640" text-anchor="middle">KSESSIONS: 343 lecture transcripts · FTS5 search · zero token cost · sub-ms lookup</text>

        <!-- Dashed arrow: Stage 3 → Source Library Server (live fallback path) -->
        <path class="arr arr-src-lib-fallback"
          d="M20,295 C8,295 6,611 20,611"
          marker-end="url(#ah-gold)"/>
        <text class="src-lib-edge-lbl" x="7" y="455" text-anchor="middle" transform="rotate(-90 7 455)">live fallback</text>

        <!-- PUBLISHED CATALOG -->
        <rect class="box-output" x="8" y="692" width="804" height="36" rx="5"/>
        <text class="output-title" x="410" y="715" text-anchor="middle">Published Catalog — episodes are live</text>

        <!-- AZURE CLUSTER -->
        <rect class="cluster cluster-azure" x="518" y="102" width="286" height="148" rx="6"/>
        <text class="cluster-lbl lbl-azure" x="530" y="120">Azure</text>
        <rect class="svc svc-azure" x="530" y="126" width="122" height="50" rx="4"/>
        <text class="svc-title" x="591" y="149" text-anchor="middle">Doc Intelligence</text>
        <text class="svc-sub"   x="591" y="167" text-anchor="middle">Reads Arabic PDFs</text>
        <rect class="svc svc-azure" x="660" y="126" width="132" height="50" rx="4"/>
        <text class="svc-title" x="726" y="149" text-anchor="middle">Translator</text>
        <text class="svc-sub"   x="726" y="167" text-anchor="middle">Arabic → English</text>
        <rect class="svc svc-azure" x="594" y="186" width="122" height="50" rx="4"/>
        <text class="svc-title" x="655" y="209" text-anchor="middle">Speech</text>
        <text class="svc-sub"   x="655" y="227" text-anchor="middle">Islamic name phonetics</text>

        <!-- ANTHROPIC CLUSTER -->
        <rect class="cluster cluster-claude" x="518" y="262" width="286" height="78" rx="6"/>
        <text class="cluster-lbl lbl-claude" x="530" y="280">Anthropic</text>
        <rect class="svc svc-claude" x="598" y="282" width="194" height="50" rx="4"/>
        <text class="svc-title" x="695" y="305" text-anchor="middle">Claude</text>
        <text class="svc-sub"   x="695" y="323" text-anchor="middle">Plans, writes, challenges quality</text>

        <!-- GOOGLE CLUSTER -->
        <rect class="cluster cluster-google" x="518" y="352" width="286" height="78" rx="6"/>
        <text class="cluster-lbl lbl-google" x="530" y="370">Google</text>
        <rect class="svc svc-google" x="598" y="372" width="194" height="50" rx="4"/>
        <text class="svc-title" x="695" y="395" text-anchor="middle">Gemini</text>
        <text class="svc-sub"   x="695" y="413" text-anchor="middle">Audit + term fallback (~10%)</text>

        <!-- NOTEBOOKLM CLUSTER -->
        <rect class="cluster cluster-nlm" x="518" y="442" width="286" height="78" rx="6"/>
        <text class="cluster-lbl lbl-nlm" x="530" y="460">NotebookLM</text>
        <rect class="svc svc-nlm" x="598" y="462" width="194" height="50" rx="4"/>
        <text class="svc-title" x="695" y="485" text-anchor="middle">Audio Overview</text>
        <text class="svc-sub"   x="695" y="503" text-anchor="middle">Turns the bundle into a podcast</text>

        <!-- SQL SERVER CLUSTER (home server) -->
        <rect class="cluster cluster-sqlsrv" x="518" y="540" width="286" height="118" rx="6"/>
        <text class="cluster-lbl lbl-sqlsrv" x="530" y="558">SQL Server · 192.168.1.158</text>
        <rect class="svc svc-sqlsrv" x="530" y="564" width="80" height="44" rx="4"/>
        <text class="svc-title" x="570" y="585" text-anchor="middle">KQUR</text>
        <text class="svc-sub"   x="570" y="599" text-anchor="middle">Quran + roots</text>
        <rect class="svc svc-sqlsrv" x="618" y="564" width="88" height="44" rx="4"/>
        <text class="svc-title" x="662" y="585" text-anchor="middle">WISDOM</text>
        <text class="svc-sub"   x="662" y="599" text-anchor="middle">Corpus + terms</text>
        <rect class="svc svc-sqlsrv" x="714" y="564" width="80" height="44" rx="4"/>
        <text class="svc-title" x="754" y="585" text-anchor="middle">KSESSIONS</text>
        <text class="svc-sub"   x="754" y="599" text-anchor="middle">Transcripts</text>
        <text class="svc-sub"   x="661" y="638" text-anchor="middle">Home network · LAN only</text>

        <!-- ARROWS: stage → external service (horizontal connectors) -->
        <!-- Stage 1 ↔ Azure (bidirectional) -->
        <path class="arr arr-azure"
          d="M472,135 C490,135 490,176 518,176"
          marker-end="url(#ah-azure)"
          marker-start="url(#ah-rev-azure)"/>
        <!-- Stage 2 ↔ Claude (bidirectional) -->
        <path class="arr arr-claude"
          d="M472,215 C490,215 490,301 518,301"
          marker-end="url(#ah-claude)"
          marker-start="url(#ah-rev-claude)"/>
        <!-- Stage 3 → Gemini -->
        <path class="arr arr-google"
          d="M472,295 C490,295 490,391 518,391"
          marker-end="url(#ah-google)"/>
        <!-- Stage 4 → NotebookLM -->
        <path class="arr arr-nlm"
          d="M472,375 C490,375 490,481 518,481"
          marker-end="url(#ah-nlm)"/>
        <!-- Source Library Server ↔ SQL Server (LAN, bidirectional) -->
        <path class="arr arr-sqlsrv"
          d="M472,609 C490,609 490,599 518,599"
          marker-end="url(#ah-sqlsrv)"
          marker-start="url(#ah-rev-sqlsrv)"/>
        <!-- NotebookLM → Published Catalog -->
        <path class="arr arr-nlm"
          d="M695,520 C695,670 410,670 410,692"
          marker-end="url(#ah-nlm)"/>

      </svg>
    </div>
  </section>

  <section class="stack">
    <h2>Reading the map</h2>
    <div class="legend-grid">
      <div class="legend-item">
        <span class="legend-dot ld-azure"></span>
        <div>
          <strong>Azure</strong> handles everything about the source text: scanning the PDF page by page,
          translating Arabic to English, and pronouncing Islamic names correctly in audio.
          The pipeline sends raw pages and receives clean, translated text back.
        </div>
      </div>
      <div class="legend-item">
        <span class="legend-dot ld-claude"></span>
        <div>
          <strong>Anthropic (Claude)</strong> does all the thinking: reads the whole book,
          decides which chapters become which episodes, writes the episode text, then
          challenges its own output in a separate critic pass. Arrows go both ways because
          it's a genuine back-and-forth exchange.
        </div>
      </div>
      <div class="legend-item">
        <span class="legend-dot ld-google"></span>
        <div>
          <strong>Google (Gemini)</strong> runs a completely independent audit after Claude finishes,
          and acts as a silent fallback for the roughly 10% of term hover requests the local
          source library doesn't already know.
        </div>
      </div>
      <div class="legend-item">
        <span class="legend-dot ld-nlm"></span>
        <div>
          <strong>NotebookLM</strong> receives the finished bundle and generates the actual audio podcast episode.
          The pipeline cannot control the audio directly; it hands off and NotebookLM takes over.
        </div>
      </div>
      <div class="legend-item">
        <span class="legend-dot ld-sqlsrv"></span>
        <div>
          <strong>SQL Server (home network)</strong> holds three databases — the full Quran with etymology,
          a 20-year Islamic knowledge anthology, and 343 lecture transcripts. The Source Library Server
          mirrors these locally with FTS5 search so lookups are instant and free.
        </div>
      </div>
    </div>
  </section>
</Base>

