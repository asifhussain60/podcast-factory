---
// studio.astro — WC8 Slice 5b: the Studio re-platform. Replaces the throwaway /studio-poc with
// the real editorial cockpit: a left rail of editorial-decision cards (book canonical + per-chapter
// override) beside the stage editor + inspector. Same chapter loader as the PoC; the cockpit
// follows the editor via the `studio:chapter-change` event. External CSS only (Cortex standard).
import PocLayout from '../layouts/PocLayout.astro';
import StudioPoc from '../components/reader/poc/StudioPoc.tsx';
import StudioVersePopover from '../components/reader/poc/StudioVersePopover.tsx';
import EditorialCards from '../components/reader/poc/EditorialCards.tsx';
import { CARD_DEFS } from '../lib/reader/editorial';
import {
  AYYUHAL_WALAD_CHAPTERS,
  AYYUHAL_WALAD_SLUG,
  AYYUHAL_WALAD_STAGE_DEFS,
  loadBookWorkspace,
} from '../lib/reader/book-workspace';

const workspace = await loadBookWorkspace(
  AYYUHAL_WALAD_SLUG,
  AYYUHAL_WALAD_CHAPTERS,
  AYYUHAL_WALAD_STAGE_DEFS,
);
---

<PocLayout title="Studio — Ayyuhal Walad" active="studio">
  <header class="sp-header">
    <h1 class="sp-h1">Studio — editorial cockpit</h1>
    <p class="sp-subtitle">
      The review cockpit: steer the book's canonical editorial decisions on the left, edit and
      approve each pipeline stage on the right. Override any decision per chapter; the cockpit
      follows the chapter you are editing.
    </p>
  </header>

  {workspace.loadError
    ? <p class="sp-error">Could not load the chapter: {workspace.loadError}</p>
    : (
      <div class="studio-shell">
        <EditorialCards client:only="react" slug={workspace.slug} chapters={workspace.cockpitChapters} cardDefs={CARD_DEFS} />
        <div class="prose-body">
          <StudioPoc client:only="react" slug={workspace.slug} chapters={workspace.chapters} glossary={workspace.glossary} />
          <StudioVersePopover client:only="react" />
        </div>
      </div>
    )}
</PocLayout>
