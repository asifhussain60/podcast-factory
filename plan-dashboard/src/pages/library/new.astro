---
import Base from '../../layouts/Base.astro';
import { ACTIVE_CATEGORIES, categoryLabel } from '../../lib/content-paths';
import '../../styles/library.css';
---
<Base title="New content" active="library" description="Create a new draft — book, lecture, or sabaq.">
  <header class="stack">
    <div class="lib-breadcrumb">
      <a href="/library">Library</a>
      <span class="lib-sep">›</span>
      <span>New</span>
    </div>
    <h1>Create a new draft.</h1>
    <p class="lede">
      Pick a category and a kebab-case slug. The portal scaffolds the canonical directory under
      <code>content/drafts/&lt;category&gt;/&lt;slug&gt;/</code> and writes a starter <code>meta.yml</code>.
      You can upload source files from the detail page after creation.
    </p>
  </header>

  <section class="stack">
    <form method="POST" action="/api/library/new" class="card stack lib-new-form">
      <label class="lib-field">
        <span class="lib-field-label">Category</span>
        <select name="category" class="lib-field-input" required>
          {ACTIVE_CATEGORIES.map((c) => (
            <option value={c}>{categoryLabel(c)} ({c})</option>
          ))}
        </select>
      </label>

      <label class="lib-field">
        <span class="lib-field-label">Slug</span>
        <input
          name="slug"
          class="lib-field-input"
          type="text"
          placeholder="e.g. kitab-al-iman"
          pattern="^[a-z0-9]+(?:-[a-z0-9]+)*$"
          required
        />
      </label>

      <label class="lib-field">
        <span class="lib-field-label">Title</span>
        <input
          name="title"
          class="lib-field-input"
          type="text"
          placeholder="(optional — defaults to slug)"
        />
      </label>

      <p class="card-sub">
        <strong>What this does:</strong> creates the directory tree on disk and writes <code>meta.yml</code>.
        It does NOT start the pipeline. To begin pipeline processing, use the orchestrator separately —
        that's a multi-hour LLM-spend operation and stays explicit.
      </p>

      <div class="lib-form-actions">
        <button type="submit" class="lib-btn lib-btn-primary">Create</button>
        <a href="/library" class="lib-btn">Cancel</a>
      </div>
    </form>
  </section>
</Base>

