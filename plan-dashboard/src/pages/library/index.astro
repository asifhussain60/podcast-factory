---
import Base from '../../layouts/Base.astro';
import {
  ACTIVE_CATEGORIES,
  groupByCategory,
  listAllSummaries,
  type Category,
} from '../../lib/library';
import '../../styles/library.css';

const summaries = await listAllSummaries();
const grouped = groupByCategory(summaries);

function categoryHeading(cat: Category): string {
  switch (cat) {
    case 'books': return 'Books';
    case 'lectures': return 'Lectures';
    case 'asbaaq': return 'Asbaaq';
    default: return cat;
  }
}

function categoryBlurb(cat: Category): string {
  switch (cat) {
    case 'books': return 'Scholarly works in the pipeline. PDFs, DOCX, TXT — Arabic, English, Urdu.';
    case 'lectures': return 'Recorded English lectures awaiting transcription and structuring.';
    case 'asbaaq': return 'Urdu lessons. Multi-file audio with gap-filling under design.';
    default: return '';
  }
}

const totalDrafts = summaries.filter((s) => s.publicationStatus !== 'published').length;
const totalPublished = summaries.filter((s) => s.publicationStatus === 'published').length;
---
<Base title="Library" active="library" description="Every piece of content in the factory — drafts and published — in one place.">
  <header class="stack">
    <span class="eyebrow">Library</span>
    <h1>Every piece of content in one place.</h1>
    <p class="lede">
      Books, lectures, and asbaaq — both still-in-flight drafts and published releases. Click any card to open
      its workshop view: chapters, episodes, slide-decks, source files, audio, and audits.
    </p>
  </header>

  <section class="grid-3">
    <div class="card metric">
      <span class="metric-label">In drafts</span>
      <span class="metric-value">{totalDrafts}</span>
      <span class="card-sub">Pieces of content still being worked on</span>
    </div>
    <div class="card metric">
      <span class="metric-label">Published</span>
      <span class="metric-value">{totalPublished}</span>
      <span class="card-sub">Pieces released to the audience-facing catalog</span>
    </div>
    <div class="card metric">
      <span class="metric-label">Active categories</span>
      <span class="metric-value">{ACTIVE_CATEGORIES.length}</span>
      <span class="card-sub">Books, lectures, asbaaq — others reserved for later</span>
    </div>
  </section>

  <section class="stack">
    <div class="library-actions">
      <a href="/library/new" class="lib-btn lib-btn-primary">+ New content</a>
    </div>
  </section>

  {ACTIVE_CATEGORIES.map((cat) => {
    const items = grouped.get(cat) ?? [];
    return (
      <section class="stack lib-category-section">
        <header class="lib-section-head">
          <h2>{categoryHeading(cat)}</h2>
          <p class="card-sub">{categoryBlurb(cat)}</p>
        </header>
        {items.length === 0 ? (
          <div class="card card-tight lib-empty">
            <p class="card-sub">No {categoryHeading(cat).toLowerCase()} yet. Use <a href="/library/new">+ New content</a> to create the first one.</p>
          </div>
        ) : (
          <div class="grid-3">
            {items.map((s) => (
              <a href={`/library/${s.ref.slug}`} class="card card-hover stack lib-card" data-cat={cat}>
                <div class="lib-card-head">
                  <span class={`lib-badge lib-badge-${s.publicationStatus === 'published' ? 'published' : 'drafts'}`}>{s.publicationStatus === 'published' ? 'Published' : 'Draft'}</span>
                  {s.peqAvg !== null && (
                    <span class={`lib-score-pill lib-score-${s.peqVerdict?.toLowerCase()}`}>
                      {s.peqAvg.toFixed(0)} — {s.peqVerdictLabel}
                    </span>
                  )}
                </div>
                <h3 class="card-title">{s.title}</h3>
                <p class="card-sub lib-slug">{s.ref.slug}</p>
                <div class="lib-stats">
                  {s.hasChapters && <span class="lib-chip">{s.chapterCount} chapter{s.chapterCount === 1 ? '' : 's'}</span>}
                  {s.hasEpisodes && <span class="lib-chip">{s.episodeCount} episode{s.episodeCount === 1 ? '' : 's'}</span>}
                  {s.hasAudio && <span class="lib-chip">{s.audioCount} audio</span>}
                  {s.hasSlideDecks && <span class="lib-chip">slide decks</span>}
                </div>
              </a>
            ))}
          </div>
        )}
      </section>
    );
  })}
</Base>

