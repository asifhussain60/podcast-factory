---
// studio-poc.astro — WC8 Slice 0 proof-of-concept page (THROWAWAY feel-check).
// Loads a real Ayyuhal Walad chapter, renders markdown -> HTML, mounts the TipTap
// Studio spike. External CSS imported (no inline styles — repo DoD). Run: npm run dev
// then open /studio-poc.
import { readFileSync } from 'node:fs';
import Base from '../layouts/Base.astro';
import StudioPoc from '../components/reader/poc/StudioPoc.tsx';
import { renderMarkdown } from '../lib/reader/markdown';
import '../styles/studio-poc.css';

const chapterUrl = new URL(
  '../../../content/drafts/books/ayyuhal-walad/chapters/ch01-frame-and-first-counsel.txt',
  import.meta.url,
);

let md = '';
let loadError = '';
try {
  md = readFileSync(chapterUrl, 'utf8');
} catch (e) {
  loadError = e instanceof Error ? e.message : String(e);
}

const html = md ? renderMarkdown(md) : '';
const chapterTitle = 'The Frame and the First Counsel';
---

<Base title="Studio PoC — Ayyuhal Walad" description="WC8 Slice 0 editor-engine feel-check">
  <header class="page-header">
    <div class="container">
      <h1 class="page-title">Studio editor — proof of concept</h1>
      <p class="sp-subtitle">
        A throwaway spike on a real chapter. Edit the prose (real undo/redo), watch the
        reference markers, and select text to see the inspector follow you. Feel-check only.
      </p>
    </div>
  </header>

  {loadError
    ? <p class="container sp-error">Could not load the chapter: {loadError}</p>
    : <StudioPoc client:only="react" html={html} chapterTitle={chapterTitle} />}
</Base>
