---
// studio-poc.astro — WC8 Slice 0 proof-of-concept page (THROWAWAY feel-check).
// Loads a real Ayyuhal Walad chapter, renders markdown -> HTML, mounts the TipTap
// Studio spike. External CSS imported (no inline styles — repo DoD). Run: npm run dev
// then open /studio-poc.
import { readFileSync } from 'node:fs';
import PocLayout from '../layouts/PocLayout.astro';
import StudioPoc from '../components/reader/poc/StudioPoc.tsx';
import StudioVersePopover from '../components/reader/poc/StudioVersePopover.tsx';
import { renderMarkdown } from '../lib/reader/markdown';
import { loadGlossary } from '../lib/reader/glossary';
import { readReview } from '../lib/reader/stage-review';

const SLUG = 'ayyuhal-walad';
const CHAPTER = 'ch01-frame-and-first-counsel';
const chapterTitle = 'The Frame and the First Counsel';

// Stage-aware loader (SN-5): Source -> Denoised -> Core -> Normalized -> Augmented. Each stage's
// text lives at content/drafts/books/<slug>/_stages/<chapter>/<id>.(md|txt); 'augmented' falls
// back to the existing finished chapter. Stages that the slices haven't produced yet are 'pending'
// — the tabs render them disabled and fill in as the pipeline runs. No LLM in Slice 0.
const STAGE_DEFS = [
  { id: 'source', label: 'Source', slice: 'Slice 1 (intake)' },
  { id: 'denoised', label: 'Denoised', slice: 'Slice 2 (noise-strip)' },
  { id: 'core', label: 'Core', slice: 'Slice 3 (reconcile)' },
  { id: 'normalized', label: 'Normalized', slice: 'WC8.8 (house voice)' },
  { id: 'augmented', label: 'Augmented', slice: 'Slice 4 (knowledge)' },
];
const base = new URL(`../../../content/drafts/books/${SLUG}/`, import.meta.url);
function readIfExists(url: URL): string | null {
  try { return readFileSync(url, 'utf8'); } catch { return null; }
}
function loadStageMd(id: string): string | null {
  for (const ext of ['md', 'txt']) {
    const md = readIfExists(new URL(`_stages/${CHAPTER}/${id}.${ext}`, base));
    if (md) return md;
  }
  // Back-compat: the prior full run's finished chapter IS the augmented stage.
  if (id === 'augmented') return readIfExists(new URL(`chapters/${CHAPTER}.txt`, base));
  return null;
}
const stages = STAGE_DEFS.map((d) => {
  const md = loadStageMd(d.id);
  return { id: d.id, label: d.label, slice: d.slice, available: !!md, html: md ? renderMarkdown(md) : '' };
});
const loadError = stages.some((s) => s.available) ? '' : `No stage artifacts found for ${SLUG}/${CHAPTER}.`;
// FC-4: Arabic-script overlay glossary (seed for the feel-check; Phase 0c bakes the real one).
const glossary = await loadGlossary(SLUG);
// WC8 write-back loop: per-stage approval state for this chapter.
const review = readReview(SLUG, CHAPTER);
---

<PocLayout title="Studio PoC — Ayyuhal Walad">
  <header class="sp-header">
    <h1 class="sp-h1">Studio editor — proof of concept</h1>
    <p class="sp-subtitle">
      Throwaway spike on a real chapter — judge the engine feel: edit (real undo/redo),
      the non-destructive markers, and the inspector following your selection.
    </p>
  </header>

  {loadError
    ? <p class="sp-error">Could not load the chapter: {loadError}</p>
    : (
      <div class="prose-body">
        <StudioPoc client:only="react" slug={SLUG} chapter={CHAPTER} stages={stages} chapterTitle={chapterTitle} glossary={glossary} reviewed={review.stages} />
        <StudioVersePopover client:only="react" />
      </div>
    )}
</PocLayout>
