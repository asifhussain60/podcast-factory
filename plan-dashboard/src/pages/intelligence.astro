function renderZones(canvas) {
  const zones = [
    { label:'Sources',        cls:'zone-sources',    y:0,    h:210,  nodes:['kashkole','books'] },
    { label:'Ingestion',      cls:'zone-ingest',     y:210,  h:210,  nodes:['b0','b1'] },
    { label:'Merge',          cls:'zone-merge',      y:420,  h:180,  nodes:['b2'] },
    { label:'Store',          cls:'zone-store',      y:600,  h:220,  nodes:['db'] },
    { label:'Augmentation',   cls:'zone-augment',    y:820,  h:200,  nodes:['b3'] },
    { label:'Consumers',      cls:'zone-consumers',  y:1020, h:240,  nodes:['enrich','author','challenger'] },
    { label:'Source Library', cls:'zone-source-lib', y:1260, h:200,  nodes:['source_lib_server','term_index'] },
  ];
  zones.forEach(z => {
    const band = document.createElement('div');
    band.className = `zone-band ${z.cls}`;
    band.style.cssText = `top:${z.y}px;height:${z.h}px;`;
    const lbl = document.createElement('div');
    lbl.className = 'zone-band-label';
    lbl.textContent = z.label;
    band.appendChild(lbl);
    canvas.appendChild(band);
  });
}

/* =========================================================
   NODES
   ========================================================= */
function renderNodes(canvas) {
  const zoneAccentColors = {
    source:'#4a7c4a', ingest:'#5b8dd9', merge:'#7c3aed',
    store:'#7c3aed', augment:'#c08020', consume:'#888',
  };
  Object.entries(NODES).forEach(([id, n], idx) => {
    const el = document.createElement('div');
    el.className = `dnode zone-${n.zone}`;
    el.id = `node-${id}`;
    el.style.cssText = `left:${n.x}px;top:${n.y}px;width:${n.w}px;min-height:${n.h}px;animation-delay:${Math.min(idx*0.05,0.3)}s`;
    el.setAttribute('tabindex', '0');
    el.setAttribute('role', 'button');
    el.setAttribute('aria-label', `${n.label} — click for details`);
    el.dataset.atoms = (n.atoms || []).join(',');
    el.dataset.id = id;

    const dots  = (n.atoms||[]).map(a => `<span class="atom-dot ${a}" aria-hidden="true"></span>`).join('');
    const chips = (n.chips||[]).map(c => `<span class="node-chip ${c.cls}">${c.text}</span>`).join('');

    el.innerHTML = `
      <div class="node-header">
        <div class="node-icon" aria-hidden="true">${n.icon}</div>
        <div class="node-label">${n.label}</div>
        <div class="node-sublabel">${n.sublabel}</div>
      </div>
      <div class="node-body">
        <div class="atom-dots" aria-label="Atom types">${dots}</div>
        <div>${chips}</div>
      </div>`;

    el.addEventListener('click',      () => openDetail(id));
    el.addEventListener('keydown', e => { if (e.key==='Enter'||e.key===' ') { e.preventDefault(); openDetail(id); } });
    el.addEventListener('mouseenter', e => showTooltip(id, el));
    el.addEventListener('mouseleave',   () => hideTooltip());
    canvas.appendChild(el);
  });
}

/* =========================================================
   SVG EDGES
   ========================================================= */
function renderEdges(canvas) {
  const svg = document.createElementNS(NS, 'svg');
  svg.classList.add('diagram-svg');
  svg.setAttribute('id', 'edgeSvg');
  svg.setAttribute('aria-hidden', 'true');

  const defs = document.createElementNS(NS, 'defs');

  // Arrow markers
  const markerDefs = [
    { id:'arr-quran',    fill:'var(--green)' },
    { id:'arr-hadith',   fill:'#c9930a' },
    { id:'arr-doctrine', fill:'var(--purple)' },
    { id:'arr-mixed',    fill:'#5b8dd9' },
    { id:'arr-blocker',  fill:'var(--orange)' },
    { id:'arr-disabled', fill:'#888' },
  ];
  markerDefs.forEach(({ id, fill }) => {
    const m = document.createElementNS(NS, 'marker');
    m.setAttribute('id', id);
    m.setAttribute('viewBox', '0 0 10 10');
    m.setAttribute('refX', '9'); m.setAttribute('refY', '5');
    m.setAttribute('markerWidth', '6'); m.setAttribute('markerHeight', '6');
    m.setAttribute('orient', 'auto-start-reverse');
    const p = document.createElementNS(NS, 'path');
    p.setAttribute('d', 'M 0 0 L 10 5 L 0 10 z');
    p.setAttribute('fill', fill);
    m.appendChild(p); defs.appendChild(m);
  });

  // Glow filter for particles
  const glow = document.createElementNS(NS, 'filter');
  glow.setAttribute('id', 'particle-glow');
  glow.setAttribute('x', '-30%'); glow.setAttribute('y', '-30%');
  glow.setAttribute('width', '160%'); glow.setAttribute('height', '160%');
  const fe = document.createElementNS(NS, 'feGaussianBlur');
  fe.setAttribute('stdDeviation', '2.5'); fe.setAttribute('result', 'blur');
  const feMerge = document.createElementNS(NS, 'feMerge');
  const m1 = document.createElementNS(NS, 'feMergeNode'); m1.setAttribute('in', 'blur');
  const m2 = document.createElementNS(NS, 'feMergeNode'); m2.setAttribute('in', 'SourceGraphic');
  feMerge.appendChild(m1); feMerge.appendChild(m2);
  glow.appendChild(fe); glow.appendChild(feMerge);
  defs.appendChild(glow);

  // Per-edge linearGradients
  const zoneColors = {
    source:'#4a7c4a', ingest:'#5b8dd9', merge:'#7c3aed',
    store:'#7c3aed', augment:'#c08020', consume:'#888', 'source-lib':'#5b8dd9',
  };
  EDGES.forEach((edge, i) => {
    const fn = NODES[edge.from], tn = NODES[edge.to];
    if (!fn || !tn) return;
    const from = portCoord(fn, edge.fp || 'right');
    const to   = portCoord(tn, edge.tp || 'left');
    const grad = document.createElementNS(NS, 'linearGradient');
    grad.setAttribute('id', `eg${i}`);
    grad.setAttribute('gradientUnits', 'userSpaceOnUse');
    grad.setAttribute('x1', from.x); grad.setAttribute('y1', from.y);
    grad.setAttribute('x2', to.x);   grad.setAttribute('y2', to.y);
    const s1 = document.createElementNS(NS, 'stop');
    s1.setAttribute('offset', '0%');
    s1.setAttribute('stop-color', zoneColors[fn.zone] || '#888');
    const s2 = document.createElementNS(NS, 'stop');
    s2.setAttribute('offset', '100%');
    s2.setAttribute('stop-color', zoneColors[tn.zone] || '#888');
    grad.appendChild(s1); grad.appendChild(s2);
    defs.appendChild(grad);
  });
  svg.appendChild(defs);

  const particleColors = {
    quran:'#4a7c4a', hadith:'#c9930a', doctrine:'#7c3aed', mixed:'#5b8dd9', blocker:'#c08020',
  };

  EDGES.forEach((edge, i) => {
    const fn = NODES[edge.from], tn = NODES[edge.to];
    if (!fn || !tn) return;

    const from = portCoord(fn, edge.fp || 'right');
    const to   = portCoord(tn, edge.tp || 'left');
    const dy   = to.y - from.y;
    const cp1y = from.y + dy * 0.5;
    const cp2y = to.y   - dy * 0.5;
    const d    = `M ${from.x} ${from.y} C ${from.x} ${cp1y} ${to.x} ${cp2y} ${to.x} ${to.y}`;
    const style = edge.style || 'mixed';

    // Wide invisible hit-area
    const bg = document.createElementNS(NS, 'path');
    bg.setAttribute('d', d); bg.setAttribute('fill', 'none');
    bg.setAttribute('stroke', 'transparent'); bg.setAttribute('stroke-width', '14');
    bg.dataset.idx = i; bg.dataset.types = (edge.types||[]).join(','); bg.dataset.style = style;
    svg.appendChild(bg);

    // The main edge path — with gradient stroke
    const path = document.createElementNS(NS, 'path');
    path.setAttribute('id', `edge-path-${i}`);
    path.setAttribute('d', d);
    path.setAttribute('class', `edge-path t-${style} flowing`);
    path.setAttribute('marker-end', `url(#arr-${style})`);
    if (style !== 'blocker' && style !== 'disabled') {
      path.setAttribute('stroke', `url(#eg${i})`);
      path.style.stroke = `url(#eg${i})`;
    }
    path.dataset.idx   = i;
    path.dataset.types = (edge.types||[]).join(',');
    path.dataset.style = style;
    svg.appendChild(path);

    // Edge label
    if (edge.label) {
      const mx = from.x + (to.x - from.x) * 0.5 + 12;
      const my = from.y + (to.y - from.y) * 0.5;
      const t  = document.createElementNS(NS, 'text');
      t.setAttribute('x', mx); t.setAttribute('y', my);
      t.setAttribute('text-anchor', 'middle'); t.setAttribute('class', 'edge-label');
      t.dataset.idx = i; t.textContent = edge.label;
      svg.appendChild(t);
    }

    // Animated particles (skip disabled)
    if (style !== 'disabled') {
      const pColor = particleColors[style] || particleColors[(edge.types||[])[0]] || '#888';
      const dur    = style === 'blocker' ? '4s' : '2.8s';
      for (let p = 0; p < 2; p++) {
        const circle = document.createElementNS(NS, 'circle');
        circle.setAttribute('r', style === 'blocker' ? '4.5' : '3.5');
        circle.setAttribute('fill', pColor);
        circle.setAttribute('class', 'edge-particle');
        circle.setAttribute('filter', 'url(#particle-glow)');

        const motion = document.createElementNS(NS, 'animateMotion');
        motion.setAttribute('dur', dur);
        motion.setAttribute('begin', `${i * 0.3 + p * (parseFloat(dur) * 0.5)}s`);
        motion.setAttribute('repeatCount', 'indefinite');
        motion.setAttribute('rotate', 'auto');
        motion.setAttribute('calcMode', 'spline');
        motion.setAttribute('keyTimes', '0;1');
        motion.setAttribute('keySplines', '0.4 0 0.6 1');
        const mpath = document.createElementNS(NS, 'mpath');
        mpath.setAttribute('href', `#edge-path-${i}`);
        motion.appendChild(mpath);

        const fadeIn = document.createElementNS(NS, 'animate');
        fadeIn.setAttribute('attributeName', 'opacity');
        fadeIn.setAttribute('values', '0;0;1;1;0;0');
        fadeIn.setAttribute('keyTimes', '0;0.05;0.15;0.85;0.95;1');
        fadeIn.setAttribute('dur', dur);
        fadeIn.setAttribute('begin', `${i * 0.3 + p * (parseFloat(dur) * 0.5)}s`);
        fadeIn.setAttribute('repeatCount', 'indefinite');

        circle.appendChild(motion);
        circle.appendChild(fadeIn);
        svg.appendChild(circle);
      }
    }
  });

  canvas.appendChild(svg);
}

/* =========================================================
   DETAIL PANEL
   ========================================================= */
function openDetail(id) {
  const n = NODES[id]; if (!n || !n.detail) return;
  const d = n.detail;

  const atomBadges = (n.atoms||[]).map(a => `<span class="atom-badge ${a}">● ${a}</span>`).join('');
  const chipHTML   = (n.chips||[]).filter(c=>c.cls).map(c =>
    `<span class="status-chip ${c.cls}" style="margin-right:6px">${c.text}</span>`
  ).join('');

  const kvHTML = d.kv ? `
    <div class="detail-section">
      <h3>Key facts</h3>
      <div class="detail-kv">
        ${d.kv.map(r => `<div class="kv-row"><div class="k">${r.k}</div><div class="v">${r.v}</div></div>`).join('')}
      </div>
    </div>` : '';

  const cliHTML = d.cli ? `
    <div class="detail-section">
      <h3>CLI</h3>
      <pre class="detail-code">${d.cli.join('\n')}</pre>
    </div>` : '';

  const sectHTML = (d.sections||[]).map(s => `
    <div class="detail-section">
      <h3>${s.title}</h3>
      <div class="body">${s.body}</div>
    </div>`).join('');

  const mergeHTML = d.mergeOutcomes ? `
    <div class="detail-section">
      <h3>Four merge outcomes</h3>
      <table class="outcome-table">
        <thead><tr><th>Outcome</th><th>What happens</th></tr></thead>
        <tbody>
          <tr><td>new</td><td>INSERT into knowledge_atoms + new atom_sources row</td></tr>
          <tr><td>duplicate</td><td>Existing row unchanged; INSERT new atom_sources provenance row</td></tr>
          <tr><td>variant</td><td>Same canonical ID, different text_en — INSERT new knowledge_atoms row with variant marker</td></tr>
          <tr><td>conflict</td><td>Differing text_ar or hadith grade — write to manual_review_queue and halt phase</td></tr>
        </tbody>
      </table>
    </div>` : '';

  const tableGroupHTML = d.tableGroups ? `
    <div class="detail-section">
      <h3>Table groups</h3>
      <table class="outcome-table">
        <thead><tr><th>Group</th><th>Tables (count)</th></tr></thead>
        <tbody>
          <tr><td>Core (6)</td><td>books, chapters, episodes, phonetics, pipeline_runs, cost_ledger</td></tr>
          <tr><td>Knowledge (6)</td><td>knowledge_atoms, atom_sources, atom_topic_tags, external_corpora, topic_type_taxonomy, corpus_chapters</td></tr>
          <tr><td>Quality (1)</td><td>challenger_findings</td></tr>
          <tr><td>Etymology (3)</td><td>arabic_roots, word_etymologies, letter_profiles</td></tr>
        </tbody>
      </table>
    </div>` : '';

  const blockerHTML = d.blocker ? `
    <div class="intel-blocker-row">
      <span class="status-chip blocker">⛔ BLOCKER — OPEN</span>
    </div>` : '';

  const overlay   = document.getElementById('detailOverlay');
  const panel     = document.getElementById('detailPanel');
  const detailEl  = document.getElementById('detailContent');

  detailEl.innerHTML = `
    <h2 id="detailHeading">${d.title}</h2>
    <div class="detail-zone-label">${d.zone}</div>
    ${blockerHTML}
    ${chipHTML ? `<div class="intel-chips-row">${chipHTML}</div>` : ''}
    <div class="detail-atom-badges">${atomBadges}</div>
    <p class="detail-desc">${d.desc}</p>
    ${kvHTML}${mergeHTML}${tableGroupHTML}${cliHTML}${sectHTML}
  `;

  overlay.removeAttribute('hidden');
  overlay.setAttribute('aria-hidden', 'false');
  panel.focus();
}

function closeDetail() {
  const overlay = document.getElementById('detailOverlay');
  overlay.setAttribute('hidden', '');
  overlay.setAttribute('aria-hidden', 'true');
}

/* =========================================================
   FILTER LOGIC
   ========================================================= */
document.getElementById('filterBar').addEventListener('click', e => {
  const btn = e.target.closest('.filter-btn');
  if (!btn) return;
  document.querySelectorAll('.filter-btn').forEach(b => {
    b.classList.remove('active');
    b.setAttribute('aria-pressed', 'false');
  });
  btn.classList.add('active');
  btn.setAttribute('aria-pressed', 'true');
  applyFilter(btn.dataset.filter);
});

function applyFilter(filter) {
  const allEdges  = document.querySelectorAll('.edge-path');
  const allNodes  = document.querySelectorAll('.dnode');
  const allLabels = document.querySelectorAll('.edge-label');

  if (filter === 'all') {
    allEdges.forEach(p  => p.classList.remove('dimmed'));
    allNodes.forEach(n  => n.classList.remove('dimmed'));
    allLabels.forEach(l => { l.style.opacity = ''; });
    return;
  }

  allEdges.forEach(p => {
    const types = (p.dataset.types || '').split(',');
    const style = p.dataset.style || '';
    const keep  = types.includes(filter) || style === 'blocker';
    p.classList.toggle('dimmed', !keep);
  });

  allNodes.forEach(n => {
    const atoms = (n.dataset.atoms || '').split(',');
    n.classList.toggle('dimmed', !atoms.includes(filter));
  });

  allLabels.forEach(l => {
    const idx  = parseInt(l.dataset.idx, 10);
    const edge = EDGES[idx];
    const keep = edge && (edge.types||[]).includes(filter);
    l.style.opacity = keep ? '' : '0.1';
  });
}

/* =========================================================
   CLOSE / KEYBOARD
   ========================================================= */
document.getElementById('detailClose').addEventListener('click', closeDetail);
document.getElementById('detailOverlay').addEventListener('click', e => {
  if (e.target === document.getElementById('detailOverlay')) closeDetail();
});
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeDetail(); });

/* =========================================================
   TOOLTIP
   ========================================================= */
const tooltip = document.getElementById('nodeTooltip');
function showTooltip(id, el) {
  const n = NODES[id]; if (!n) return;
  tooltip.innerHTML = `<strong>${n.label}</strong>${n.tooltip ? n.tooltip : ''}`;
  const rect = el.getBoundingClientRect();
  const wrapRect = document.querySelector('.diagram-wrap').getBoundingClientRect();
  const tx = rect.left - wrapRect.left;
  const ty = rect.top  - wrapRect.top - 10;
  tooltip.style.left = `${tx}px`;
  tooltip.style.top  = `${ty - tooltip.offsetHeight || ty - 60}px`;
  tooltip.classList.add('visible');
  tooltip.removeAttribute('aria-hidden');
}
function hideTooltip() {
  tooltip.classList.remove('visible');
  tooltip.setAttribute('aria-hidden', 'true');
}

/* =========================================================
   ZOOM / PAN
   ========================================================= */
let zoom = 1; const ZOOM_MIN = 0.35, ZOOM_MAX = 2.0, ZOOM_STEP = 0.15;
const canvasEl = document.getElementById('canvas');
const svgEl    = document.getElementById('edgeSvg');

function applyZoom() {
  canvasEl.style.transformOrigin = 'top center';
  canvasEl.style.transform = `scale(${zoom})`;
  if (svgEl) { svgEl.style.transformOrigin = 'top center'; svgEl.style.transform = `scale(${zoom})`; }
  document.getElementById('zoomLevel').textContent = `${Math.round(zoom * 100)}%`;
}
document.getElementById('zoomIn')?.addEventListener('click', () => {
  zoom = Math.min(ZOOM_MAX, zoom + ZOOM_STEP); applyZoom();
});
document.getElementById('zoomOut')?.addEventListener('click', () => {
  zoom = Math.max(ZOOM_MIN, zoom - ZOOM_STEP); applyZoom();
});
document.getElementById('zoomReset')?.addEventListener('click', () => {
  zoom = 1; applyZoom();
});
// Ctrl+wheel to zoom
document.querySelector('.diagram-wrap')?.addEventListener('wheel', e => {
  if (!e.ctrlKey && !e.metaKey) return;
  e.preventDefault();
  zoom = Math.max(ZOOM_MIN, Math.min(ZOOM_MAX, zoom - e.deltaY * 0.001));
  applyZoom();
}, { passive: false });

/* =========================================================
   INIT
   ========================================================= */
const canvas = document.getElementById('canvas');
renderZones(canvas);
renderNodes(canvas);
renderEdges(canvas);
</script>

