---
import Base from '../layouts/Base.astro';
---
<Base title="Intelligence Pipeline" active="intelligence" section="architecture"
     description="Exploded interactive diagram of the intelligence pipeline — from source corpora through extraction, deduplication, and storage, to augmentation of every chapter the factory writes.">

<div class="intel-page">

<header class="intel-header">
  <span class="eyebrow">Architecture · Intelligence Pipeline</span>
  <h1 class="intel-hero-h1">How the Knowledge Brain Works</h1>
  <p class="intel-hero-lede">
    An interactive map of the full intelligence pipeline — from source corpora through extraction,
    deduplication, and storage, to augmentation of every chapter the factory writes.
    <strong>Click any node</strong> for the full spec. Use the filters to trace each atom type.
  </p>
</header>

<div class="intel-body">
  <section aria-labelledby="diagram-title">
    <h2 id="diagram-title" class="sr-only">Interactive pipeline diagram</h2>

    <div class="filter-bar" id="filterBar" role="toolbar" aria-label="Atom type filter">
      <span class="filter-label">Highlight flow:</span>
      <button class="filter-btn active" data-filter="all"      aria-pressed="true">All flows</button>
      <button class="filter-btn f-quran"    data-filter="quran"    aria-pressed="false">● Quran atoms</button>
      <button class="filter-btn f-hadith"   data-filter="hadith"   aria-pressed="false">● Hadith atoms</button>
      <button class="filter-btn f-doctrine" data-filter="doctrine" aria-pressed="false">● Doctrine atoms</button>
      <button class="filter-btn f-source-lib" data-filter="source-lib" aria-pressed="false">● Source Library</button>
    </div>

    <div class="zoom-controls" role="group" aria-label="Diagram zoom controls">
      <button class="zoom-btn" id="zoomIn"    aria-label="Zoom in">+</button>
      <span   class="zoom-level" id="zoomLevel">100%</span>
      <button class="zoom-btn" id="zoomOut"   aria-label="Zoom out">−</button>
      <span   class="zoom-sep" aria-hidden="true"></span>
      <button class="zoom-btn" id="zoomReset" aria-label="Reset zoom" title="Reset zoom">⌂</button>
    </div>

    <div class="diagram-wrap">
      <div class="diagram-canvas" id="canvas" aria-label="Intelligence pipeline diagram"></div>
      <div class="node-tooltip" id="nodeTooltip" aria-hidden="true"></div>
    </div>

    <div class="legend-bar" aria-label="Diagram legend">
      <div class="legend-item"><span class="legend-line quran"></span> Quran atom flow</div>
      <div class="legend-item"><span class="legend-line hadith"></span> Hadith atom flow</div>
      <div class="legend-item"><span class="legend-line doctrine"></span> Doctrine atom flow</div>
      <div class="legend-item"><span class="legend-line mixed"></span> All types combined</div>
      <div class="legend-item"><span class="legend-line blocker"></span> Blocked — pending discussion</div>
      <div class="legend-item"><span class="legend-line disabled"></span> Default-disabled (DR-007)</div>
      <div class="legend-item"><span class="live-dot" aria-hidden="true"></span> Click any node for details</div>
    </div>
  </section>
</div>

</div><!-- /intel-page -->

<!-- ===================================================== DETAIL PANEL -->
<div class="detail-overlay intel-page" id="detailOverlay" hidden aria-hidden="true">
  <div class="detail-panel" id="detailPanel" role="dialog" aria-modal="true"
       aria-labelledby="detailHeading" tabindex="-1">
    <button class="detail-close" id="detailClose" aria-label="Close detail panel">×</button>
    <div id="detailContent"></div>
  </div>
</div>

<style is:global>
/* =========================================================
   INTELLIGENCE DIAGRAM — all rules prefixed with .intel-page
   so they never leak to other pages. is:global is required
   because nodes/zones/edges are created by JavaScript and
   won't carry Astro's scoped data-attribute.
   ========================================================= */
.intel-page {
  --bg:          var(--c-bg);
  --bg-card:     var(--c-bg-card);
  --bg-elevated: var(--c-bg-elev);
  --text-bright: var(--c-ink);
  --text-dim:    var(--c-ink-dim);
  --text-muted:  var(--c-ink-muted);
  --accent:      var(--c-accent);
  --border:      var(--c-rule);
  --green:       var(--c-green);
  --orange:      var(--c-amber);
  --purple:      #7c3aed;
  --font-mono:   ui-monospace, 'SF Mono', monospace;
  --radius-lg:   var(--r-lg);
  --radius-md:   var(--r-md);
  --radius-sm:   var(--r-sm);
  --space-2:     var(--sp-2);
  --space-3:     var(--sp-3);
  --space-4:     var(--sp-4);
  --space-5:     var(--sp-5);
  --space-6:     var(--sp-6);
  --space-7:     var(--sp-7);
  --space-8:     var(--sp-8);
}

/* sr-only */
.sr-only {
  position: absolute; width: 1px; height: 1px;
  padding: 0; margin: -1px; overflow: hidden;
  clip: rect(0,0,0,0); white-space: nowrap; border: 0;
}

/* ---- Filter bar ---- */
.filter-bar {
  display: flex; align-items: center; gap: var(--space-2);
  margin-bottom: var(--space-3); flex-wrap: wrap;
}
.filter-label { font-size: 12px; color: var(--text-muted); margin-right: 2px; }
.filter-btn {
  padding: 5px 14px; border-radius: 999px; border: 1px solid var(--border);
  background: var(--bg-card); color: var(--text-dim); font-size: 12px; cursor: pointer;
  transition: all 0.15s ease; font-family: inherit;
}
.filter-btn:hover  { border-color: var(--accent); color: var(--accent); }
.filter-btn.active { background: var(--accent); color: #fff; border-color: var(--accent); }
.filter-btn.f-quran.active    { background: var(--green);  border-color: var(--green); }
.filter-btn.f-hadith.active   { background: #c9930a;        border-color: #c9930a; }
.filter-btn.f-doctrine.active { background: var(--purple); border-color: var(--purple); }
.filter-btn.f-source-lib.active { background: #5b8dd9; border-color: #5b8dd9; }

/* ---- Diagram wrap ---- */
.diagram-wrap {
  position: relative; overflow-x: auto; overflow-y: visible;
  border: 1px solid var(--border); border-radius: var(--radius-lg);
  background: var(--bg-elevated); padding: 30px 16px 24px;
  box-shadow: inset 0 1px 3px rgba(0,0,0,0.06);
  margin-bottom: var(--space-3);
}
/* subtle grid — uses dark dots on light background */
.diagram-wrap::before {
  content: ''; position: absolute; inset: 0; border-radius: var(--radius-lg);
  background-image: radial-gradient(circle, rgba(0,0,0,0.055) 1px, transparent 1px);
  background-size: 28px 28px; pointer-events: none;
}

/* ---- Canvas ---- */
.diagram-canvas {
  position: relative; width: 900px; height: 1460px; margin: 0 auto;
}

/* ---- Zone bands ---- */
.zone-band {
  position: absolute; left: 0; right: 0; border-radius: 6px; pointer-events: none;
  border-left: 3px solid currentColor;
  transition: background 0.3s;
}
.zone-sources  { color: var(--green);   background: linear-gradient(135deg, rgba(56,139,58,0.09)   0%, rgba(56,139,58,0.02)   100%); }
.zone-ingest   { color: #5b8dd9;        background: linear-gradient(135deg, rgba(91,141,217,0.09)  0%, rgba(91,141,217,0.02)  100%); }
.zone-merge    { color: var(--purple);  background: linear-gradient(135deg, rgba(139,91,196,0.09)  0%, rgba(139,91,196,0.02)  100%); }
.zone-store    { color: var(--purple);  background: linear-gradient(135deg, rgba(139,91,196,0.12)  0%, rgba(139,91,196,0.04)  100%); }
.zone-augment  { color: var(--orange);  background: linear-gradient(135deg, rgba(219,109,40,0.09)  0%, rgba(219,109,40,0.02)  100%); }
.zone-consumers{ color: #888;           background: linear-gradient(135deg, rgba(120,120,120,0.06) 0%, rgba(120,120,120,0.01) 100%); }
.zone-source-lib{ color: #5b8dd9;       background: linear-gradient(135deg, rgba(91,141,217,0.09) 0%, rgba(91,141,217,0.02) 100%); }
.zone-band-label {
  position: absolute; top: 8px; left: 14px;
  font-size: 10px; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.1em; white-space: nowrap;
  color: currentColor; opacity: 0.7;
}
.zone-band-label::before {
  content: attr(data-count);
  display: inline-block; margin-right: 6px;
  opacity: 0.55; font-variant-numeric: tabular-nums;
}

/* ---- Nodes ---- */
.dnode {
  position: absolute; border-radius: var(--radius-md);
  border: 1.5px solid var(--border); background: var(--bg-card);
  cursor: pointer;
  transition: box-shadow 0.2s, transform 0.15s, border-color 0.2s, opacity 0.3s;
  overflow: hidden; user-select: none;
  box-shadow: 0 2px 8px rgba(0,0,0,0.07), 0 1px 2px rgba(0,0,0,0.04);
  animation: nodeEnter 0.4s ease;
}
@keyframes nodeEnter {
  from { transform: translateY(10px) scale(0.96); }
  to   { transform: translateY(0)    scale(1); }
}
.dnode:hover, .dnode:focus-visible {
  box-shadow: 0 0 0 2.5px var(--node-accent, var(--accent)),
              0 8px 28px rgba(0,0,0,0.18),
              0 0 20px rgba(var(--node-accent-rgb, 192,128,32), 0.12);
  transform: translateY(-3px) scale(1.005); z-index: 20; outline: none;
  border-color: var(--node-accent, var(--accent));
}
.dnode.highlighted {
  border-color: var(--node-accent, var(--accent));
  box-shadow: 0 0 0 2.5px var(--node-accent, var(--accent)), 0 6px 20px rgba(0,0,0,0.15);
}
.dnode.graph-dimmed { opacity: 0.15; transform: none !important; }
.dnode .node-header { padding: 9px 13px 7px; border-bottom: 1px solid var(--border); }
.dnode .node-icon    { font-size: 18px; margin-bottom: 3px; line-height: 1; }
.dnode .node-label   { font-size: 13px; font-weight: 700; color: var(--text-bright); line-height: 1.3; }
.dnode .node-sublabel { font-size: 10.5px; color: var(--text-muted); margin-top: 2px; }
.dnode .node-body    { padding: 7px 13px 9px; }

/* Zone accent borders */
.dnode.zone-source  { --node-accent: var(--green); }
.dnode.zone-ingest  { --node-accent: #5b8dd9; }
.dnode.zone-merge   { --node-accent: var(--purple); }
.dnode.zone-store   { --node-accent: var(--purple); }
.dnode.zone-augment { --node-accent: var(--orange); }
.dnode.zone-consume { --node-accent: #888; }

.dnode.zone-source  .node-header { background: rgba(56,139,58,0.07);   border-left: 3px solid var(--green); }
.dnode.zone-ingest  .node-header { background: rgba(91,141,217,0.07);  border-left: 3px solid #5b8dd9; }
.dnode.zone-merge   .node-header { background: rgba(139,91,196,0.07);  border-left: 3px solid var(--purple); }
.dnode.zone-store   .node-header { background: rgba(139,91,196,0.10);  border-left: 3px solid var(--purple); }
.dnode.zone-augment .node-header { background: rgba(219,109,40,0.07);  border-left: 3px solid var(--orange); }
.dnode.zone-consume .node-header { background: rgba(120,120,120,0.05); border-left: 3px solid #aaa; }
.dnode.zone-source-lib { --node-accent: #5b8dd9; }
.dnode.zone-source-lib .node-header { background: rgba(91,141,217,0.07); border-left: 3px solid #5b8dd9; }

.dnode.zone-future { opacity: 0.4; border-style: dashed; --node-accent: #555; }
.dnode.zone-future:hover { opacity: 0.75; }

/* Atom dots */
.atom-dots { display: flex; gap: 4px; margin-top: 5px; }
.atom-dot  { width: 7px; height: 7px; border-radius: 50%; }
.atom-dot.quran    { background: var(--green); }
.atom-dot.hadith   { background: #c9930a; }
.atom-dot.doctrine { background: var(--purple); }

/* Node chips */
.node-chip {
  display: inline-flex; align-items: center; gap: 3px;
  padding: 2px 7px; border-radius: 999px; font-size: 9.5px; font-weight: 700; margin-top: 5px;
}
.node-chip.blocker  { background: rgba(219,109,40,0.15); color: var(--orange); }
.node-chip.disabled { background: rgba(100,100,100,0.12); color: var(--text-muted); }
.node-chip.tier1    { background: rgba(91,141,217,0.15);  color: #5b8dd9; }

.dnode.dimmed { opacity: 0.2; transform: none; }

/* ---- SVG overlay ---- */
.diagram-svg {
  position: absolute; top: 0; left: 0; width: 100%; height: 100%;
  pointer-events: none; overflow: visible;
}
.edge-path {
  fill: none; stroke-width: 2; opacity: 0.75;
  transition: opacity 0.25s, stroke-width 0.2s;
}
.edge-path.t-quran    { stroke: var(--green); }
.edge-path.t-hadith   { stroke: #c9930a; }
.edge-path.t-doctrine { stroke: var(--purple); }
.edge-path.t-mixed    { stroke: #5b8dd9; opacity: 0.5; }
.edge-path.t-blocker  { stroke: var(--orange); stroke-dasharray: 6 5; opacity: 0.85; }
.edge-path.t-disabled { stroke: #888; stroke-dasharray: 4 8; opacity: 0.3; }

.edge-path.flowing { animation: flowMove 2.4s linear infinite; }
.edge-path.t-blocker.flowing { animation: flowMove 3.5s linear infinite; }
@keyframes flowMove { to { stroke-dashoffset: -60; } }
.edge-path.t-mixed.flowing    { stroke-dasharray: 6 10; }
.edge-path.t-quran.flowing    { stroke-dasharray: 6 12; }
.edge-path.t-hadith.flowing   { stroke-dasharray: 6 12; }
.edge-path.t-doctrine.flowing { stroke-dasharray: 6 12; }
.edge-path.dimmed { opacity: 0.06; animation: none; }
.edge-label { font-size: 10px; fill: var(--text-muted); font-family: var(--font-mono); pointer-events: none; }

/* ---- Legend ---- */
.legend-bar {
  display: flex; gap: var(--space-5); flex-wrap: wrap;
  font-size: 12px; color: var(--text-dim);
  padding: var(--space-3) var(--space-4);
  background: var(--bg-card); border: 1px solid var(--border);
  border-radius: var(--radius-md);
}
.legend-item { display: flex; align-items: center; gap: 8px; }
.legend-line { width: 22px; height: 3px; border-radius: 2px; }
.legend-line.quran    { background: var(--green); }
.legend-line.hadith   { background: #c9930a; }
.legend-line.doctrine { background: var(--purple); }
.legend-line.mixed    { background: #5b8dd9; }
.legend-line.blocker  { background: transparent; border-top: 2px dashed var(--orange); }
.legend-line.disabled { background: transparent; border-top: 2px dashed #888; }

/* ---- Detail panel ---- */
.detail-overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,0.45);
  z-index: 200; display: flex; align-items: stretch; justify-content: flex-end;
  backdrop-filter: blur(3px);
}
.detail-overlay[hidden] { display: none; }
.detail-panel {
  width: min(500px, 100vw); background: var(--bg-card);
  border-left: 1px solid var(--border); overflow-y: auto; padding: var(--space-6);
  position: relative; animation: slideIn 0.22s ease;
}
@keyframes slideIn {
  from { transform: translateX(24px); opacity: 0; }
  to   { transform: translateX(0);    opacity: 1; }
}
.detail-close {
  position: absolute; top: var(--space-4); right: var(--space-4);
  background: none; border: 1px solid var(--border); border-radius: var(--radius-sm);
  color: var(--text-dim); cursor: pointer; font-size: 18px; padding: 2px 10px;
  line-height: 1.5; transition: background 0.15s; font-family: inherit;
}
.detail-close:hover { background: var(--bg-elevated); }
.detail-panel h2    { font-size: 20px; margin: 0 0 4px; padding-right: 44px; }
.detail-zone-label  { font-size: 11px; text-transform: uppercase; letter-spacing: 0.09em; color: var(--text-muted); margin-bottom: var(--space-4); }
.detail-desc        { font-size: 13.5px; color: var(--text-dim); line-height: 1.7; margin-bottom: var(--space-5); }
.detail-atom-badges { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: var(--space-4); }
.atom-badge         { display: inline-flex; align-items: center; gap: 4px; font-size: 11px; padding: 3px 10px; border-radius: 999px; font-weight: 700; }
.atom-badge.quran    { background: rgba(56,139,58,0.15);  color: var(--green); }
.atom-badge.hadith   { background: rgba(201,147,10,0.15); color: #c9930a; }
.atom-badge.doctrine { background: rgba(139,91,196,0.15); color: var(--purple); }

.detail-kv { display: grid; grid-template-columns: 1fr 1fr; gap: 7px var(--space-4); margin-bottom: var(--space-5); }
.kv-row .k { font-size: 11px; color: var(--text-muted); margin-bottom: 2px; }
.kv-row .v { font-size: 13px; color: var(--text-bright); font-weight: 600; }
.detail-section       { margin-bottom: var(--space-5); }
.detail-section h3    { font-size: 11.5px; text-transform: uppercase; letter-spacing: 0.07em; color: var(--text-muted); margin: 0 0 var(--space-2); }
.detail-section .body { font-size: 13px; color: var(--text-dim); line-height: 1.7; }
.detail-code {
  font-family: var(--font-mono); font-size: 11.5px; color: var(--text-dim);
  background: var(--bg-elevated); border-radius: var(--radius-sm);
  padding: var(--space-3); overflow-x: auto; white-space: pre; margin: 0;
}
.status-chip {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 3px 10px; border-radius: 999px; font-size: 11px; font-weight: 700;
}
.status-chip.blocker  { background: rgba(219,109,40,0.15); color: var(--orange); }
.status-chip.disabled { background: rgba(100,100,100,0.12); color: var(--text-muted); }
.status-chip.tier1    { background: rgba(91,141,217,0.15);  color: #5b8dd9; }
.status-chip.tier2    { background: rgba(219,109,40,0.15);  color: var(--orange); }
.outcome-table { width: 100%; border-collapse: collapse; font-size: 12.5px; }
.outcome-table th { text-align: left; padding: 5px 10px; font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-muted); background: var(--bg-elevated); }
.outcome-table td { padding: 7px 10px; border-top: 1px solid var(--border); color: var(--text-dim); vertical-align: top; }
.outcome-table td:first-child { color: var(--text-bright); font-weight: 700; font-family: var(--font-mono); font-size: 11.5px; }
@keyframes pulse { 0%,100% { opacity:1; } 50% { opacity:0.3; } }
.live-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--green); display: inline-block; animation: pulse 2s ease infinite; }

/* ---- Animated particles along edges ---- */
.edge-particle {
  pointer-events: none;
  transition: opacity 0.2s;
}
.edge-particle.particle-disabled { display: none; }

/* ---- Zoom controls ---- */
.zoom-controls {
  display: flex; align-items: center; gap: 4px;
  margin-bottom: var(--space-3);
  padding: 5px 8px; background: var(--bg-card);
  border: 1px solid var(--border); border-radius: var(--radius-md);
  width: fit-content; user-select: none;
}
.zoom-btn {
  width: 26px; height: 26px; border: 1px solid var(--border);
  background: var(--bg-elevated); border-radius: var(--radius-sm);
  color: var(--text-dim); cursor: pointer; font-size: 14px; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  transition: background 0.12s, color 0.12s; line-height: 1; font-family: inherit;
}
.zoom-btn:hover { background: var(--accent); color: white; border-color: var(--accent); }
.zoom-level {
  font-size: 11px; color: var(--text-muted); min-width: 36px;
  text-align: center; font-variant-numeric: tabular-nums;
}
.zoom-sep { width: 1px; height: 18px; background: var(--border); margin: 0 2px; }

/* ---- Hover tooltip ---- */
.node-tooltip {
  position: absolute; z-index: 60; pointer-events: none;
  background: var(--bg-card); border: 1px solid var(--border);
  border-radius: var(--radius-md); padding: 8px 11px;
  font-size: 12px; color: var(--text-dim); max-width: 210px;
  box-shadow: 0 4px 14px rgba(0,0,0,0.14);
  opacity: 0; transition: opacity 0.12s;
  line-height: 1.5;
}
.node-tooltip.visible { opacity: 1; }
.node-tooltip strong { color: var(--text-bright); font-size: 12.5px; display: block; margin-bottom: 3px; }

@media (max-width: 820px) {
  .detail-panel { width: 100vw; }
  .detail-kv    { grid-template-columns: 1fr; }
}
</style>

<script>
/* =========================================================
   DATA — NODES
   ========================================================= */
const NODES = {
  kashkole: {
    label: 'Kashkole Corpus', sublabel: '122 chapters · 17 binders',
    zone: 'source', icon: '📚',
    x: 80, y: 35, w: 230, h: 145,
    atoms: ['doctrine'],
    chips: [],
    tooltip: 'Ismaili scholarly corpus — the doctrine substrate. Not produced as a podcast; seeds the knowledge library.',
    detail: {
      title: 'Kashkole Corpus', zone: 'Source corpus · doctrine substrate',
      desc: '122 chapters of adapted Ismaili scholarly text across 17 thematic binders. Not produced as a podcast — it seeds the intelligence library with doctrinal knowledge atoms that enrich every future pipeline book.',
      kv: [
        { k: 'Total chapters', v: '122' }, { k: 'Binders', v: '17' },
        { k: 'Verdict: PASS',  v: '9'   }, { k: 'Verdict: WARN',  v: '66' },
        { k: 'Verdict: FAIL',  v: '18'  }, { k: 'Unchallenged',   v: '29' },
        { k: 'Ready to ingest', v: '75 (PASS + WARN)' },
        { k: 'Topic types', v: '18 (from topic-type-map.json)' },
      ],
      atoms: ['doctrine','quran','hadith'],
      blocker: true,
      sections: [
        { title: 'Refinement state machine',
          body: 'Each chapter tracks five states:<br><code>pending → ingested → needs_correction → correction_draft → re_ingested</code>.<br>Correcting one chapter never touches any other chapter\'s atoms.' },
        { title: 'Topic taxonomy (18 types)',
          body: 'Taʾwīl, Kalam, Ethics, Jurisprudence, Hadith commentary, Quranic exegesis, Wilāya, Bāṭin knowledge, Ḥudūd/Daʿwa hierarchy, Aphorisms, Poetry/Manqabat, Virtues, Terminology, History, and 4 more. Each chapter receives 1–4 topic type tags that drive Augmenter scoring.' },
      ]
    }
  },

  books: {
    label: 'Pipeline Books', sublabel: '6 shipped + queue',
    zone: 'source', icon: '🎙',
    x: 590, y: 40, w: 230, h: 120,
    atoms: ['quran','hadith'],
    chips: [],
    tooltip: 'Every production book contributes atoms. The Extractor reads enriched chapter text — never audio scripts.',
    detail: {
      title: 'Pipeline Books', zone: 'Source · production output',
      desc: 'Every book the pipeline processes is also a source of knowledge atoms. The Extractor (B1) reads the enriched chapter text after Phase 08-enrichment.',
      kv: [
