---
/**
 * Three-pane chapter-viewer layout — left rail (TOC), center reading
 * column, right rail (AI panels). Renders inside Base.astro's <main>.
 *
 * No inline styles, no Tailwind utility soup. All visual rules live in
 * styles/chapter-viewer.css and use plan-dashboard CSS tokens.
 */
import Icon from '../ui/Icon.astro';

interface Props {
  bookSlug: string;
  breadcrumb?: Array<{ label: string; href?: string }>;
  showRail?: boolean;
}

const { bookSlug, breadcrumb = [], showRail = true } = Astro.props;
---

<script is:inline>
  // Restore sidebar collapsed state before paint to avoid flicker.
  try {
    if (localStorage.getItem('pf-reader:sidebar-collapsed') === '1') {
      document.documentElement.setAttribute('data-sidebar', 'collapsed');
    }
  } catch (_) {}
</script>

<div class="three-pane">
  <aside class="left-rail">
    <div class="left-rail-head">
      <div class="left-rail-head-row">
        <a href={`/library/${bookSlug}`} class="left-rail-back">
          <Icon name="arrow-left" size={12} />
          <span class="left-rail-back-label">Back to overview</span>
        </a>
        <button id="sidebar-toggle" class="left-rail-collapse" type="button" aria-label="Collapse sidebar" title="Collapse sidebar (s)">
          <span class="left-rail-collapse-icon">‹</span>
        </button>
      </div>
      <div class="left-rail-book">
        <Icon name="book-marked" size={18} class="left-rail-book-icon" />
        <span class="left-rail-book-title">{bookSlug}</span>
      </div>
    </div>
    <nav class="left-rail-nav">
      <slot name="toc">
        <p class="left-rail-nav-empty">No navigation provided.</p>
      </slot>
    </nav>
  </aside>

  <div class="center-col">
    <header class="center-header">
      <div class="center-header-inner">
        <nav class="center-breadcrumb">
          {breadcrumb.map((b, i) => (
            <>
              {i > 0 && <span class="center-breadcrumb-sep"><Icon name="chevron-right" size={12} /></span>}
              {b.href ? (
                <a href={b.href}>{b.label}</a>
              ) : (
                <span class="here">{b.label}</span>
              )}
            </>
          ))}
        </nav>
        <div class="center-header-actions">
          <slot name="header-actions" />
        </div>
      </div>
    </header>
    <main class="center-main">
      <slot />
    </main>
  </div>

  {showRail && (
    <aside class="right-rail">
      <button id="right-rail-toggle" class="right-rail-collapse" type="button" aria-label="Collapse right panel" title="Collapse right panel (r)">
        <span class="right-rail-collapse-icon">›</span>
      </button>
      <div class="right-rail-content">
        <slot name="rail" />
      </div>
    </aside>
  )}
</div>

<script is:inline>
  /* Left/right rail collapse — both persist independently via localStorage,
     both restorable on load, both keyboard-toggleable (s = left, r = right). */
  (function () {
    var h = document.documentElement;

    try {
      if (localStorage.getItem('pf-reader:sidebar-collapsed') === '1') h.setAttribute('data-sidebar', 'collapsed');
      if (localStorage.getItem('pf-reader:right-rail-collapsed') === '1') h.setAttribute('data-right-rail', 'collapsed');
    } catch (_) {}

    function setLeft(collapsed) {
      if (collapsed) h.setAttribute('data-sidebar', 'collapsed'); else h.removeAttribute('data-sidebar');
      try { localStorage.setItem('pf-reader:sidebar-collapsed', collapsed ? '1' : '0'); } catch (_) {}
    }
    function setRight(collapsed) {
      if (collapsed) h.setAttribute('data-right-rail', 'collapsed'); else h.removeAttribute('data-right-rail');
      try { localStorage.setItem('pf-reader:right-rail-collapsed', collapsed ? '1' : '0'); } catch (_) {}
    }

    var leftBtn = document.getElementById('sidebar-toggle');
    if (leftBtn) leftBtn.addEventListener('click', function () {
      setLeft(h.getAttribute('data-sidebar') !== 'collapsed');
    });
    var rightBtn = document.getElementById('right-rail-toggle');
    if (rightBtn) rightBtn.addEventListener('click', function () {
      setRight(h.getAttribute('data-right-rail') !== 'collapsed');
    });

    document.addEventListener('keydown', function (e) {
      if (e.metaKey || e.ctrlKey || e.altKey) return;
      var t = (e.target && e.target.tagName) ? e.target.tagName.toLowerCase() : '';
      if (t === 'input' || t === 'textarea' || (e.target && e.target.isContentEditable)) return;
      if (e.key === 's') setLeft(h.getAttribute('data-sidebar') !== 'collapsed');
      else if (e.key === 'r') setRight(h.getAttribute('data-right-rail') !== 'collapsed');
    });
  })();
</script>
